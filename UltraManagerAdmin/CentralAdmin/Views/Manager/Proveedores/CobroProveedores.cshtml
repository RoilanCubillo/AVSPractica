        function fillTableFichaProveedores() {
            try {
                StartLoadTable(elements.div_table, true);
                $("#" + elements.spn_table).show();
                if (lists.ficha_proveedores) {
                    $("#" + elements.div_table + " > table > tbody").html("");
                    lists.ficha_proveedores.forEach(function (p) {
                        var prov = findProveedor(p.ProveedorID),
                            casa = findCasaComercial(p.CasaComercialID),
                            forma = findFormaRebajo(p.FormaRebajoID),
                            row = $("<tr />");
                        $("#" + elements.div_table + " > table").append(row);
                        row.append($("<td> " + p.NumeroContrato + "</td>"));
                        row.append($("<td> " + (prov === null ? "-@Resources.views.no_def-" : prov.Name) + "</td>"));
                        row.append($("<td> " + ((casa === null || p.CasaComercialID === 0) ? "-@Resources.views.no_def-" : casa.Name) + "</td>"));
                        row.append($("<td> " + (forma === null ? "-@Resources.views.no_def-" : forma.Nombre) + "</td>"));
