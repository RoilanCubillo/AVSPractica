
@{
    ViewBag.Title = Resources.views.horarios;
    Layout = "~/Views/Layout/MainLayout.cshtml";
    var Name = "Ficha de Proveedores";
    var culture = System.Threading.Thread.CurrentThread.CurrentCulture;
    var CurrencySymbol = culture.NumberFormat.CurrencySymbol;
    var CurrencyDecimalSeparator = culture.Name.ToUpper() == "ES-CR" ? "." : culture.NumberFormat.CurrencyDecimalSeparator;
    var CurrencyThousandSeparator = culture.Name.ToUpper() == "ES-CR" ? "," : culture.NumberFormat.NumberGroupSeparator;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">

    @* < CSS > *@
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
    <!-- Tempusdominus Bootstrap 4 -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
    <!-- Select2 -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/select2/css/select2.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css">
    @* < CSS / >*@

    @* < SCRIPTS > *@
    <!-- moment.js -->
    <script src="~/Content/AdminLTE/plugins/moment/moment.min.js"></script>
    <!-- DataTables  & Plugins -->
    <script src="~/Content/AdminLTE/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/jszip/jszip.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/pdfmake/pdfmake.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/pdfmake/vfs_fonts.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.html5.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.print.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.colVis.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="~/Content/AdminLTE/plugins/sweetalert2/sweetalert2.min.js"></script>
    <!-- Select2 -->
    <script src="~/Content/AdminLTE/plugins/select2/js/select2.full.min.js"></script>
    <!-- Tempusdominus Bootstrap 4 -->
    <script src="~/Content/AdminLTE/plugins/tempusdominus-bootstrap-4/js/tempusdominus-bootstrap-4.min.js"></script>
    <!-- jquery-validation -->
    <script src="~/Content/AdminLTE/plugins/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/jquery-validation/additional-methods.min.js"></script>
    <!-- InputMask -->
    <script src="~/Content/AdminLTE/plugins/moment/moment.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/inputmask/jquery.inputmask.min.js"></script>
    @* < SCRIPTS / >*@
</head>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <div class="content-wrapper">
            <!-- Encabezado -->
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1>@Name</h1>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="@Url.Action("Manager", "Inicio")">@Resources.views.inicio</a></li>
                                <li class="breadcrumb-item active">@Resources.views.cobros</li>
                                <li class="breadcrumb-item active">@Resources.views.proveedores</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </section><!-- Encabezado -->
            <!-- Muestra -->
            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <div class="overlay-wrapper">
                                        <!-- Spinner tbl -->
                                        <div id="spn_tbl_ficha_prov" class="overlay justify-content-center">
                                            <i class="fas fa-3x fa-sync-alt fa-spin"></i>
                                            <div class="text-bold pt-2">@Resources.views.cargando</div>
                                        </div> <!-- Spinner tbl -->
                                        <!-- Boton agregar -->
                                        <div class="col-12 d-flex justify-content-end">
                                            <button type="button" class="btn btn-primary float-right fa-pull-right" onclick="onClickBtnAddFichaProv()"><i class="fa fa-plus"> </i> @Resources.views.agregar</button>
                                        </div><!-- Boton agregar -->
                                        @* Mostrar tabla *@
                                        <div id="tbl_content_ficha_prov" class="dataTables_wrapper dt-bootstrap4">
                                            <table class="table table-bordered t    able-striped text-nowrap">
                                                <thead>
                                                    <tr>
                                                        <th># Contrato</th>
                                                        <th>@Resources.views.proveedor</th>
                                                        <th>Casa Comercial</th>
                                                        <th>Forma Rebajo</th>
                                                        <th>Vigencia</th>
                                                        <th>Estado</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                </tbody>
                                            </table>
                                        </div> @* Mostrar tabla *@
                                    </div>
                                    <!--tabs-->
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section><!-- Muestra -->
        </div>
    </div>

    <!-- Modal -->
    <div id="modal_ficha_proveedor" class="modal fade" role="dialog">
        <div class="modal-dialog modal-xl">
            <!-- Modal content-->
            <div class="modal-content">
                <!-- Spinner Modal -->
                <div id="spn_modal_ficha_proveedor" class="overlay">
                    <i class="fas fa-2x fa-sync fa-spin"></i>
                </div><!-- Spinner Modal -->
                <!-- Encabezado Modal -->
                <div class="modal-header text-center">
                    <h4 id="title_modal_ficha_proveedor" class="modal-title"></h4>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div><!-- Encabezado Modal -->
                <!-- Cuerpo Modal -->
                <div class="modal-body text-sm">
                    <div class="card card-outline card-primary position-relative">
                        <div class="card-header">
                            <div class="row">
                                <div class="d-flex col-6 justify-content-lg-start">
                                    <label class="col-form-label">#Contrato: </label>
                                    <p id="label_contrato" class="col-form-label" style=""></p>
                                </div>
                                <div class="d-flex col-6">
                                    <label class="col-form-label text-nowrap" style="width:150px;">Forma Rebajo: </label>
                                    <select id="select_forma" name="select_forma" class="form-control select2" style="width:100%;"></select>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            @* Fechas de vigencia - proveedor - casa comercial *@
                            <form id="form_modal_ficha_proveedor" class="row">
                                <input id="fichaID" type="hidden" />
                                <div class="form-group col-md-6 col-lg-3">
                                    <label>Vigencia Desde:</label>
                                    <div id="div_date_desde" class="input-group date" data-target-input="nearest">
                                        <input id="fecha_desde" type="text" class="form-control datetimepicker-input" data-target="#fecha_desde" name="fecha_desde" placeholder="Ingresar fecha" />
                                        <div class="input-group-append" data-target="#fecha_desde" data-toggle="datetimepicker">
                                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-6 col-lg-3">
                                    <label>Hasta:</label>
                                    <div id="div_date_hasta" class="input-group date" data-target-input="nearest">
                                        <input id="fecha_hasta" type="text" class="form-control datetimepicker-input" data-target="#fecha_hasta" name="fecha_hasta" placeholder="Ingresar fecha" />
                                        <div class="input-group-append" data-target="#fecha_hasta" data-toggle="datetimepicker">
                                            <div class="input-group-text"><i class="fa fa-calendar"></i></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group col-md-6 col-lg-3">
                                    <label>Proveedor:</label>
                                    <select id="select_proveedor" name="select_proveedor" class="form-control select2"></select>
                                </div>
                                <div class="form-group col-md-6 col-lg-3">
                                    <label>Casa comercial:</label>
                                    <select id="select_casa" name="select_casa" class="form-control select2" data-allow-clear="true" data-placeholder="Seleccione una casa"></select>
                                </div>
                                <div class="col-12 mb-2">
                                    <button id="btnSiguiente" type="submit" class="btn btn-success float-right"><i class="fa fa-arrow-alt-circle-right"></i> Siguiente</button>
                                </div>
                            </form>
                            @* IDC *@
                            <div id="div_idc" class="row">
                                <div class="col-12">
                                    <div class="card card-outline card-success collapsed-card">
                                        <div class="card-header">
                                            <h3 class="card-title">Inversión Directa a la Cadena (IDC)</h3>
                                            <div class="card-tools">
                                                <button type="button" class="btn btn-tool" data-card-widget="collapse"><i class="fas fa-plus"></i></button>
                                            </div>
                                        </div>
                                        <div class="card-body overlay-wrapper">
                                            <div>
                                                <form id="form_idc" class="row p-2">
                                                    <input hidden id="hfID_idc" />
                                                    <div class="form-group col-md-6 col-lg-3">
                                                        <label>Tipo inversión:</label>
                                                        <select id="select_idc_inversion" name="select_idc_inversion" class="form-control select2"></select>
                                                    </div>
                                                    <div class="form-group col-md-6 col-lg-3">
                                                        <label>Frecuencia de pago:</label>
                                                        <select id="select_idc_frecuencia" name="select_idc_frecuencia" class="form-control select2"></select>
                                                    </div>
                                                    <div class="form-group col-md-6 col-lg-3">
                                                        <label>Tipo negociación:</label>
                                                        <select id="select_idc_tipo_neg" name="select_idc_tipo_neg" class="form-control select2"></select>
                                                    </div>
                                                    <div id="div_idc_val_money" class="form-group col-md-6 col-lg-3">
                                                        <label for="input_idc_val_money">Valor negociación:</label>
                                                        <div class="input-group">
                                                            <div class="input-group-prepend"><span class="input-group-text"><i class="fas">@CurrencySymbol</i></span></div>
                                                            <input id="input_idc_val_money" type="text" name="input_idc_valor_money" class="form-control" data-inputmask="'alias' : 'currency', 'groupSeparator':'@CurrencyThousandSeparator', 'radixPoint':'@CurrencyDecimalSeparator'" data-mask />
                                                        </div>
                                                    </div>
                                                    <div id="div_idc_val_perc" class="form-group col-md-6 col-lg-3">
                                                        <label for="input_idc_val_perc">Valor negociación:</label>
                                                        <div class="input-group">
                                                            <input id="input_idc_val_perc" type="text" name="input_idc_val_perc" class="form-control" data-inputmask="'alias': 'decimal', 'digits':'2'" placeholder="0" data-mask />
                                                            <div class="input-group-append"><span class="input-group-text"><i class="fas">%</i></span></div>
                                                        </div>
                                                    </div>
                                                    <div class="form-group col-12">
                                                        <label>@Resources.views.categs</label>
                                                        <select id="select_idc_categs" name="select_idc_categs" class="form-control select2 w-100" multiple="multiple" data-placeholder="Buscar categorías"></select>
                                                    </div>
                                                    <button id="btn_add_idc" type="submit" class="btn btn-secondary col-12"><i class="fa fa-save"></i> Agregar</button>
                                                </form>
                                                <div class="col-12 card card-body p-0 mt-1 table-responsive" style="max-height:300px">
                                                    <table id="tbl_idc" class="table table-head-fixed table-bordered table-hover">
                                                        <thead>
                                                            <tr>
                                                                <th>Tipo de inversión</th>
                                                                <th>Frecuencia de pago</th>
                                                                <th>Tipo de negociación</th>
                                                                <th>Valor de negociación</th>
                                                                <th>Estado</th>
                                                                <th></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody></tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            @* IIC *@
                            <div id="div_iic" class="row">
                                <div class="col-12">
                                    <div class="card card-outline card-success collapsed-card">
                                        <div class="card-header">
                                            <h3 class="card-title">Inversión Indirecta en la Cadena (IIC)</h3>
                                            <div class="card-tools">
                                                <button type="button" class="btn btn-tool" data-card-widget="collapse"><i class="fas fa-plus"></i></button>
                                            </div>
                                        </div>
                                        <div class="card-body overlay-wrapper">
                                            <div class="col-12">
                                                <form id="form_iic" class="row p-2">
                                                    <input hidden id="hfID_iic" />
                                                    <div class="form-group col-md-6 col-lg-3">
                                                        <label>Tipo inversión:</label>
                                                        <select id="select_iic_inversion" name="select_iic_inversion" class="form-control select2"></select>
                                                    </div>
                                                    <div class="form-group col-md-6 col-lg-3">
                                                        <label>Frecuencia de pago:</label>
                                                        <select id="select_iic_frecuencia" name="select_iic_frecuencia" class="form-control select2"></select>
                                                    </div>
                                                    <div class="form-group col-md-6 col-lg-3">
                                                        <label>Tipo negociación:</label>
                                                        <select id="select_iic_tipo_neg" name="select_iic_tipo_neg" class="form-control select2"></select>
                                                    </div>
                                                    <div id="div_iic_val_money" class="form-group col-md-6 col-lg-3">
                                                        <label for="input_iic_val_money">Valor negociación:</label>
                                                        <div class="input-group">
                                                            <div class="input-group-prepend"><span class="input-group-text"><i class="fas">@CurrencySymbol</i></span></div>
                                                            <input id="input_iic_val_money" type="text" name="input_iic_val_money" class="form-control" data-inputmask="'alias' : 'currency', 'groupSeparator':'@CurrencyThousandSeparator', 'radixPoint':'@CurrencyDecimalSeparator'" data-mask />
                                                        </div>
                                                    </div>
                                                    <div id="div_iic_val_perc" class="form-group col-md-6 col-lg-3">
                                                        <label for="input_iic_val_perc">Valor negociación:</label>
                                                        <div class="input-group">
                                                            <input id="input_iic_val_perc" type="text" name="input_iic_val_perc" class="form-control" data-inputmask="'alias': 'decimal', 'digits':'2'" placeholder="0" data-mask />
                                                            <div class="input-group-append"><span class="input-group-text"><i class="fas">%</i></span></div>
                                                        </div>
                                                    </div>
                                                    <div class="form-group col-12">
                                                        <label>@Resources.views.categs</label>
                                                        <select id="select_iic_categs" name="select_iic_categs" class="form-control select2" multiple="multiple" data-placeholder="Buscar categorías"></select>
                                                    </div>
                                                    <button id="btn_add_iic" type="submit" class="btn btn-secondary col-12"><i class="fa fa-save"></i> Agregar</button>
                                                </form>
                                                <div class="col-12 card card-body p-0 mt-1 table-responsive" style="max-height:300px">
                                                    <table id="tbl_iic" class="table table-head-fixed table-bordered table-hover">
                                                        <thead>
                                                            <tr>
                                                                <th>Tipo de inversión</th>
                                                                <th>Frecuencia de pago</th>
                                                                <th>Tipo de negociación</th>
                                                                <th>Valor de negociación</th>
                                                                <th>Estado</th>
                                                                <th></th>
                                                            </tr>
                                                        </thead>
                                                        <tbody></tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div id="div_ficha_actions" class="col-12 d-flex justify-content-end">
                                    <div class="btn-group mr-2">
                                        <button type="button" class="btn btn-secondary dropdown-toggle" data-toggle="dropdown">Estado: <span id="spn_estado"> BORRADOR</span></button>
                                        <div class="dropdown-menu" role="menu">
                                            <button class="dropdown-item ficha_actions" action="02">Activar Ficha</button>
                                            <button class="dropdown-item ficha_actions" action="03">Enviar Ficha a Cobro</button>
                                            <button class="dropdown-item ficha_actions" action="99">Suspender Ficha</button>
                                        </div>
                                    </div>
                                    <button id="btnCancel" type="button" class="btn btn-danger" onclick="onClickBtnCancel()"><i class="fa fa-ban"></i> Cancelar</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Cuerpo Modal -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" onclick="onClickBtnNewFicha()"> <i class="fa fa-plus"></i> @Resources.views.nuevo</button>
                    <button type="button" class="btn btn-success" onclick="onClickBtnSaveFicha()"> <i class="fa fa-save"></i> @Resources.views.guardar</button>
                    <button type="button" class="btn btn-danger" data-dismiss="modal"> <i class="fa fa-ban"></i> @Resources.views.cerrar</button>
                </div>
            </div><!-- Modal content-->
        </div>
    </div><!-- Modal -->
    @* Variables *@
    <script>
        var urls = {
            init: '@Url.Action("GetInitData", "CobroProveedores")',
            categs: '@Url.Action("GetAll_BY_Supplier", "CobroProveedores")',
            detalles: '@Url.Action("GetDetalles", "CobroProveedores")',
            guardar: '@Url.Action("SaveFicha", "CobroProveedores")',
            fichas: '@Url.Action("GetAllFichasProveedor", "CobroProveedores")',
            chage_status: '@Url.Action("ChangeStatusProveedor", "CobroProveedores")'
        };
        var elements = {
            div_table: "tbl_content_ficha_prov", spn_table: "spn_tbl_ficha_prov",
            spn_modal: "spn_modal_ficha_proveedor", modal: "modal_ficha_proveedor",
            title_modal: "title_modal_ficha_proveedor", form: "form_modal_ficha_proveedor",
            spn_idc: "spn_idc", spn_iic: "spn_iic"
        };
        var estados = { '01': 'BORRADOR', '02': 'ACTIVO', '03': 'ENVIADO A COBRO', '99': 'SUSPENDIDO' };
        var estadosColor = { '01': 'primary', '02': 'success', '03': 'info', '99': 'danger' };
        var Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 4000 }); // Variable para mostrar los mensajes.
        var lists = {
            ficha_proveedores: [], proveedores: [], forma_rebajos: [], casas: [],
            IDCsTipo: [], IICsTipo: [], frecuencias: [], negociaciones: [], categorias: [],
            IDCs: [], IICs: []
        };
        var rules = {
            idc: {
                select_idc_inversion: { required: true },
                select_idc_frecuencia: { required: true },
                select_idc_tipo_neg: { required: true },
                input_idc_valor_money: { required: function () { return (+$("#select_idc_tipo_neg").val()) === 2 } },
                input_idc_val_perc: { required: function () { return (+$("#select_idc_tipo_neg").val()) === 1 }, min: 0, max: 100 },
                select_idc_categs: { required: true }
            },
            iic: {
                select_iic_inversion: { required: true },
                select_iic_frecuencia: { required: true },
                select_iic_tipo_neg: { required: true },
                input_iic_valor_money: { required: function () { return (+$("#select_iic_tipo_neg").val()) === 2 } },
                input_iic_val_perc: { required: function () { return (+$("#select_iic_tipo_neg").val()) === 1 }, min: 0, max: 100 },
                select_iic_categs: { required: true }
            },
            ficha: {
                fecha_desde: { required: true },
                fecha_hasta: { required: true },
                select_proveedor: { required: true },
            }
        };
        var messages = {
            idc: {
                select_idc_inversion: { required: "@Resources.messages.validacion_req" },
                select_idc_frecuencia: { required: "@Resources.messages.validacion_req" },
                select_idc_tipo_neg: { required: "@Resources.messages.validacion_req" },
                input_idc_valor_money: { required: "@Resources.messages.validacion_req", decimal: true},
                input_idc_val_perc: { required: "@Resources.messages.validacion_req" },
                select_idc_categs: { required: "@Resources.messages.validacion_req" }
            },
            iic: {
                select_iic_inversion: { required: "@Resources.messages.validacion_req" },
                select_iic_frecuencia: { required: "@Resources.messages.validacion_req" },
                select_iic_tipo_neg: { required: "@Resources.messages.validacion_req" },
                input_iic_valor_money: { required: "@Resources.messages.validacion_req", decimal: true},
                input_iic_val_perc: { required: "@Resources.messages.validacion_req" },
                select_iic_categs: { required: "@Resources.messages.validacion_req" }
            },
            ficha: {
                fecha_desde: { required: "@Resources.messages.validacion_req" },
                fecha_hasta: { required: "@Resources.messages.validacion_req" },
                select_proveedor: { required: "@Resources.messages.validacion_req" },
            }
        }
        var fichaProveedor = null;
        var flag = null;
    </script>

    @* Funciones *@
    <script>
        /** funcion Initialize */
        $(function () {
            applyInitPlugins();
            hideInitElements();
            fillMenuItemsLayout();
            setOnActions();
            setAllValidationsForm();
            getAllInitialData();
            fillTableIDC();
            fillTableIIC();
            $(".ficha_actions").click(function () { onClickBtnChangeStatus($(this).attr("action")); });
        })

        function hideInitElements() {
            $("#div_idc_val_money").hide();
            $("#div_iic_val_money").hide();
            $("#div_idc").hide();
            $("#div_iic").hide();
            $("#div_ficha_actions button").hide();
            $("#" + elements.spn_modal).hide();
            $("#" + elements.spn_idc).hide();
            $("#" + elements.spn_iic).hide();
        }

        function applyInitPlugins() {
            $('#fecha_desde').datetimepicker({ format: 'DD/MM/YYYY', });
            $('#fecha_hasta').datetimepicker({ format: 'DD/MM/YYYY', });
            $(".select2").select2({ theme: "bootstrap4" });
            $('[data-mask]').inputmask();
