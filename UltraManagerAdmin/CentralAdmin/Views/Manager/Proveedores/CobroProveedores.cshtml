                        row.append($("<td><button class='btn btn-primary' title='" + title + "' data-toggle='modal' data-target='' onClick='onClickBtnEditFichaProveedor(" + p.ID + ")'> <i class='fa fa-edit' aria-hidden='true'></i></button></td>"));
