        function getNameCategories(listIDs) {
            if (listIDs) {
                var names = "", list = listIDs.split(",");
                for (var i = 0; i < list.length; i++) {
                    var categ = lists.categorias.find(c => c.ID === (+list[i]));
                    if (categ) names += "<span class='badge bg-success'>" + categ.Name + "</span> ";
                }
                return names;
            } else return null;
        }

