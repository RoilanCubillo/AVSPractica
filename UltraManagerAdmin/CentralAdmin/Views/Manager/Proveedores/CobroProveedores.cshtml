        function setAllValidationsForm() {
            setValidationForm("form_idc", rules.idc, messages.idc, onSubmitFormIDC);
            setValidationForm("form_iic", rules.iic, messages.iic, onSubmitFormIIC);
            setValidationForm("form_modal_ficha_proveedor", rules.ficha, messages.ficha, onSubmitFormFichaProveedor);
        }

        function setValidationForm(formID, rules, messages, onSubmit) {
            $.validator.setDefaults({ submitHandler: function () { onSubmit(); } });

            $('#' + formID).validate({
                rules: rules, messages: messages, errorElement: 'span',
                errorPlacement: function (err, element) {
                    err.addClass('invalid-feedback ml-2');
                    element.closest('.form-group').append(err);
                },
                highlight: function (element, errorClass, validClass) {
                    $(element).addClass('is-invalid');
                },
                unhighlight: function (element, errorClass, validClass) {
                    $(element).removeClass('is-invalid');
                }
            });
        }

        function setFichaProveedor(ficha) {
            $("#select_proveedor").val(ficha.ProveedorID).trigger("change");
            $("#fichaID").val(ficha.ID);
            $("#label_contrato").text(ficha.NumeroContrato);
            $("#select_forma").val(ficha.FormaRebajoID).trigger("change");

            $('#fecha_desde').datetimepicker('date', moment(ficha.VigenciaDesdeAux, "DD/MM/YYYY"));
            $('#fecha_hasta').datetimepicker('date', moment(ficha.VigenciaHastaAux, "DD/MM/YYYY"));

            $("#select_casa").val(ficha.CasaComercialID).trigger("change");
            $("#spn_estado").text(estados[ficha.Estado]);
        }

        function setChangeDetail(list, idAux, status) {
            console.log(list);
            console.log("auxxx");
            console.log(idAux);
            var estado = list.find(x => x.IDAux === idAux).Estado;
            if (estado === 0) {
                if (status) list.find(x => x.IDAux === idAux).Estado = 2
                else list.find(x => x.IDAux === idAux).Estado = 3;
            } else if (estado === -1){
                if (status) list.find(x => x.IDAux === idAux).Estado = -2
                else list.find(x => x.IDAux === idAux).Estado = -3;
            }
        }

        async function setNewStatesAfterSave(idcStates, iicStates) {
            for (var i = 0; i < idcStates.length; i++) await setChangeDetail(lists.IDCs, idcStates[i].idAux, idcStates[i].status);
            for (var i = 0; i < iicStates.length; i++) await setChangeDetail(lists.IICs, iicStates[i].idAux, iicStates[i].status);

            await fillTableIDC();
            await fillTableIIC();
        }

        function deleteIDCList(idAux) {
            var lAux = [];
            lists.IDCs.forEach(function (x) {
                if (x.IDAux === idAux) {
                    if (x.ID !== 0) {
                        x.Estado = -1;
                        lAux.push(x);
                    }
                } else lAux.push(x);
            });
            lists.IDCs = lAux;
        }

        function deleteIICList(idAux) {
            var lAux = [];
            lists.IICs.forEach(function (x) {
                if (x.IDAux === idAux) {
                    if (x.ID !== 0) {
                        x.Estado = -1;
                        lAux.push(x);
                    }
                } else lAux.push(x);
            });
            lists.IICs = lAux;
        }

        function onClickBtnAddFichaProv() {
            openModal(true);
        }

        function onClickBtnEditFichaProveedor(id) {
            $("#" + elements.spn_modal).show();
            openModal(false);
            flag = id;
            limpiarFichaProveedor();
            var ficha = lists.ficha_proveedores.find(x => x.ID === id);
            fichaProveedor = ficha;
            setFichaProveedor(ficha);
            if (ficha) habilitarDetallesFicha(ficha.Estado === '01');
        }

        function onClickBtnNewFicha() {
            Swal.fire({
                title: "@Resources.messages.msj_continuar", html: "@Resources.messages.msj_campos_limpiar", icon: 'warning', showCancelButton: true,
            }).then((result) => {
                if (result.isConfirmed) {
                    openModal(true);
                    fichaProveedor = null;
                    onClickBtnCancel();
                    limpiarFichaProveedor();
                    habilitarDetallesFicha(true);
                }
            });
        }

        function onClickBtnDeleteIDC(idAux) {
            deleteIDCList(idAux);
            fillTableIDC();
        }

        function onClickBtnDeleteIIC(idAux) {
            deleteIICList(idAux);
            fillTableIIC();
        }

        function onClickBtnCancel() {
            if (fichaProveedor && fichaProveedor.ID > 0) {
                error("FICHA YA GUARDADA", "ACCIÓN ERRONEA. EL ENCABEZADO DE LA FICHA DE PROVEEDOR NO PUEDE SER MODIFICADA");
            } else {
                habilitarFicha(true);
                fichaProveedor = null;
                limpiarDetallesFicha();
            }
        }

        async function onClickBtnSaveFicha() {
            if (fichaProveedor && (lists.IDCs.length > 0 || lists.IICs.length > 0)) {
                $("#" + elements.spn_modal).show();
                try {
                    await $.ajax({
                        url: urls.guardar, type: 'post', dataType: 'json', contentType: 'application/json',
                        data: JSON.stringify({ ficha: fichaProveedor, IDCs: lists.IDCs, IICs: lists.IICs }), cache: false,
                        success: async function (data) {
                            if (data.Status) {
                                Toast.fire({ icon: 'success', title: data.Message });
                                lists.IDCs = [];
                                lists.IICs = [];

                                await getAllFichasProveedor();
                                await onClickBtnEditFichaProveedor(data.Result.result_ficha.SCOPE);

                                openModal(false);
                            } else {
                                $("#" + elements.spn_modal).hide();
                                error(data.InternalMessage, data.Message);
                            }
                        },
                        error: function (xhr, ajaxOptions, thrownError) {
                            $("#spn_modal_cabeceras").hide();
                            console.log("error al guardar");
                            error(thrownError, "@Resources.messages.error_guardar");
                        }
                    });
                } catch (e) {
                    $("#" + elements.spn_modal).hide();
                    error(e, "@Resources.messages.error_intento_guardar");
                }
            } else error("FALTAN CAMPOS", "@Resources.messages.validacion_campos_vacios");
        }

        function onClickBtnChangeStatus(action) {
            if (fichaProveedor && fichaProveedor.ID > 0 && (+fichaProveedor.Estado) < (+action)) {
                if (action === '03' && fichaProveedor.Estado !== '02') Toast.fire({ icon: 'error', title: "Error al enviar la ficha a cobro. La ficha no está activa." });
                else {
                    Swal.fire({
                        title: "@Resources.messages.msj_continuar", html: 'La ficha pasará de estado "' + estados[fichaProveedor.Estado] + '" a estado "' + estados[action] + '".', icon: 'warning', showCancelButton: true,
                    }).then((result) => {
                        if (result.isConfirmed) {
                            $("#" + elements.spn_modal).show();
                            $.post(urls.chage_status, { 'proveedorID': fichaProveedor.ID, status: action }, "json").done(async function (data) {
                                Toast.fire({ icon: (data.Status ? 'success' : error), title: data.Message });
                                if (data.Status) {
                                    fichaProveedor.Estado = action;

                                    await getAllFichasProveedor();
                                    await onClickBtnEditFichaProveedor(fichaProveedor.ID);
                                }
                                $("#" + elements.spn_modal).hide();
                            }).fail(function () {
                                error("ERROR CAMBIAR ESTADO DE: " + fichaProveedor.ID + ", CON " + action, "Error al intentar cambiar el estado de la ficha");
                                $("#" + elements.spn_modal).hide();
                            });
                        }
                    });
                }
            } else if (fichaProveedor.Estado === action) Toast.fire({ icon: 'success', title: "La ficha ya se encuentra en estado: " + estados[action] });
            else Toast.fire({ icon: 'error', title: "Error. No es permitido cambiar a un estado anterior." });
        }

        function onChangeSelectProveedor() {
            lists.categorias = [];
            getCategorias();
        }

        function onChangeSelectIdcNegociacion() {
            if ($("#select_idc_tipo_neg").val() === "1") {
                $("#div_idc_val_perc").show();
                $("#div_idc_val_money").hide();
            } else {
                $("#div_idc_val_perc").hide();
                $("#div_idc_val_money").show();
            }
        }

        function onChangeSelectIicNegociacion() {
            if ($("#select_iic_tipo_neg").val() === "1") {
                $("#div_iic_val_perc").show();
                $("#div_iic_val_money").hide();
            } else {
                $("#div_iic_val_perc").hide();
                $("#div_iic_val_money").show();
            }
        }

        function onSubmitFormIIC() {
            var iic = getIICFromForm();
            lists.IICs.push(iic);
            fillTableIIC();
        }

        function onSubmitFormIDC() {
            var idc = getIDCFromForm();
            lists.IDCs.push(idc);
            fillTableIDC();
        }

        function onSubmitFormFichaProveedor() {
            if ($("#select_forma").val()) {
                fichaProveedor = getFichaFromModal();
                habilitarFicha(false);
            } else error("CAMPOS REQUERIDOS", "@Resources.messages.validacion_forma_req");
        }

        function habilitarFicha(estado) {
            $("#div_ficha_actions button").hide();
            if (!estado) {
                $("#btnSiguiente").slideUp("slow");
                $("#div_idc").slideDown("slow");
                $("#div_iic").slideDown("slow");

                if (fichaProveedor && fichaProveedor.ID > 0) $("#div_ficha_actions > div button").slideDown("slow")
                else $("#btnCancel").slideDown("slow");
            } else {
                $("#btnSiguiente").slideDown("slow");
                $("#div_idc").slideUp("slow");
                $("#div_iic").slideUp("slow");
            }
            $("#select_forma").prop("disabled", !estado);
            $("#fecha_desde").prop("disabled", !estado);
            $("#fecha_hasta").prop("disabled", !estado);
            $("#select_proveedor").prop("disabled", !estado);
            $("#select_casa").prop("disabled", !estado);
        }

        function habilitarDetallesFicha(estado) {
            $("#div_idc input").prop("disabled", !estado);
            $("#div_idc select").prop("disabled", !estado);
            $("#div_idc #btn_add_idc").prop("disabled", !estado);
            $("#form_idc button").prop("hidden", !estado);

            $("#div_iic input").prop("disabled", !estado);
            $("#div_iic select").prop("disabled", !estado);
            $("#div_iic #btn_add_iic").prop("disabled", !estado);
            $("#form_iic button").prop("hidden", !estado);
        }

        function limpiarDetallesFicha() {
            lists.IDCs = [];
            lists.IICs = [];

            $("#input_idc_val_money").val("");
            $("#input_iic_val_money").val("");

            $("#select_idc_categs").val(null).trigger("change");
            $("#select_iic_categs").val(null).trigger("change");

            fillTableIDC();
            fillTableIIC();
        }

        function limpiarFichaProveedor() {
            $("#fichaID").val("");
            $("#select_forma").val(1).trigger("change");
            $("#select_casa").val(null).trigger("change");
            $("#form_modal_ficha_proveedor input").val("");
            $("#label_contrato").text("");
            limpiarDetallesFicha();
        }

        function numberWithCommas(x) {
            return x.toString().replace(/\B(?<!\.\d*)(?=(\d{3})+(?!\d))/g, "@CurrencyThousandSeparator");
        }

        /** Abre la modal */
        function openModal(is_new) {
            $("#" + elements.title_modal).html((is_new ? "@Resources.views.agregar" : "@Resources.views.editar") + " Ficha de Proveedor");
            $('#' + elements.modal).modal({ backdrop: 'static', keyboard: false });
        }

        /** Muestra un error, recibe excepcion para mostrar en consola y el mensaje para el usuario. */
        function error(e, msj) {
            Toast.fire({ icon: 'error', title: msj });
            console.error(e);
        }
    </script>
</body>
</html>
