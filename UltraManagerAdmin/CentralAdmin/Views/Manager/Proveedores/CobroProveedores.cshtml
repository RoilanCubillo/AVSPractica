        async function fillTableIDC() {
            try {
                $("#tbl_idc > tbody").html(null);
                if (lists.IDCs.length > 0) {
                    var idAux = 1;
                    await lists.IDCs.forEach(function (i) {
                        if (i.Estado != -2 && i.Estado != -3) {
                            i.IDAux = idAux;
                            var row_expand = $("<tr class='expandable-body d-none'><td colspan='6'><div>Categorías: " + getNameCategories(i.ListaCategorias) + "</div></td></tr>"),
                                row = $("<tr data-widget='expandable-table' aria-expanded='false'/>"), inv = findTipoIDC(i.IDCTipoID),
                                frec = findFrecuenciaPago(i.FrecuenciaPagoID),
                                neg = findNegociacion(i.NegociacionID),
                                badge = $('<span class="badge bg-' + ((i.Estado === 1 || i.Estado === 2) ? 'success' : i.Estado === 0 ? 'primary' : 'danger') + '"></span>'),
                                td = $("<td />"),
                                btnDel = (fichaProveedor && fichaProveedor.Estado === '01') ? ("<button class='btn btn-danger' onClick='onClickBtnDeleteIDC(" + i.IDAux + ")'> <i class='fa fa-trash' aria-hidden='true'></i></button>") : '';
                            badge.text((i.Estado === 1 ? 'Asignado' : i.Estado === 0 ? 'Por Guardar' : i.Estado === 2 ? 'Guardado' : i.Estado === -1 ? 'Por Eliminar' : 'NO GUARDADO'));
                            td.append(badge);
                            $("#tbl_idc > tbody").append(row);
                            $("#tbl_idc > tbody").append(row_expand);
                            row.append($("<td> " + inv.Nombre + "</td>"));
                            row.append($("<td> " + frec.Nombre + "</td>"));
                            row.append($("<td> " + neg.Nombre + "</td>"));
                            row.append($("<td> " + (neg.ID === 1 ? ((i.ValorNegPorcentaje) + "%") : ("@CurrencySymbol" + numberWithCommas(i.ValorNegMonetizado))) + "</td>"));
                            row.append(td);
                            row.append($("<td> " + btnDel + "</td>"));
                            idAux += 1;
                        }
                    });
                } else $("#tbl_idc > tbody").append($("<tr><td colspan='6'><span class='d-flex justify-content-center'>Vacío</span></td></tr>"));
            } catch (e) { error(e, "@Resources.messages.error_llenar_registros"); }
        }

