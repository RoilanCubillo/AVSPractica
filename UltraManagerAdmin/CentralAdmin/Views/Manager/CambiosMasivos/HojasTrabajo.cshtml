    @* VARIABLES *@
    <script>
        var urls = {
            GetAll_Worksheets: '@Url.Action("GetAll_Worksheets", "HojasTrabajo")',
            Get_Worksheet: '@Url.Action("Get_Worksheet", "HojasTrabajo")',
            Change_Status: '@Url.Action("Change_Status", "HojasTrabajo")'
        };
        var elementsIDs = {
            div_table: 'tbl_content_worksheets',
            modal: 'modal_worksheet',
            spinner_modal: 'spn_modal_worksheet',
            title_modal: 'modal_title',
            worksheetID: 'WorksheetID',
        }
        var elementsObj = {
            dataTableWorksheet: null,
            dataTableWorksheetHistory: null,
            dataTableWorksheetContent: null,
            worksheet: null,
            worksheetStores: [],
            worksheetHistory: [],
            worksheetContents: []
        }
        var Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 4000 });
        var dataView = {
            styles: {
                251: 'Actualizar Inventario - Precio de Producto',
                261: 'Descarga de Productos',
                320: 'Ajuste de Impuestos'
            },
            statusText: ['Suspendido', 'Sin aprobar', 'Aprobado', 'En proceso', 'Completado con éxito', 'Completado con errores', 'Completado con Advertencias', 'Reconocido y grabado', 'Completado sin Cambios'],
            statusColor: ['info', 'light', 'blue', 'yellow', 'success', 'danger', 'purple', 'info', 'success'],
            dataTableWorksheetContentColums: {
                251: [
                    {
                        data: 'StoreAvailibity', render: function (data, type, row, meta) {
                            return type === 'display' ? `<span class="badge bg-${data ? 'success' : 'danger'}">${row.StoreName}</span>` : data;
                        }
                    },
                    { title: 'Cód. Producto', data: 'ItemLookupcode' },
                    { title: 'Descrip. Corta', data: 'Description' },
                    { title: 'Descrip. Extendida', data: 'ExtendedDescription' },
                    { title: 'Precio Liquidación', data: 'SalePrice' },
                    { title: 'Inicio de Liquidación', data: 'SaleStartDateString' },
                    { title: 'Fin de Liquidación', data: 'SaleEndDateString' },
                    { title: 'Límite Inferior', data: 'LowerBound', visible: false },
                    { title: 'Límite Superior', data: 'UpperBound', visible: false },
                    { title: 'Precio Liquidación Cantidad', data: 'BuydownPrice' },
                    { title: 'Cantidad en Liquidación', data: 'BuydownQuantity' },
                ],
                261: [
                    {
                        data: 'StoreAvailibity', render: function (data, type, row, meta) {
                            return type === 'display' ? `<span class="badge bg-${data ? 'success' : 'danger'}">${row.StoreName}</span>` : data;
                        }
                    },
                    { title: 'Cód. Producto', data: 'ItemLookupcode' },
                    { title: 'Descrip. Corta', data: 'Description' },
                    { title: 'Descrip. Extendida', data: 'ExtendedDescription' },
                ],
                320: [
                    {
                        data: 'StoreAvailibity', render: function (data, type, row, meta) {
                            return type === 'display' ? `<span class="badge bg-${data ? 'success' : 'danger'}">${row.StoreName}</span>` : data;
                        }
                    },
                    { title: 'Cód. Producto', data: 'ItemLookupcode' },
                    { title: 'Descrip. Corta', data: 'Description' },
                    { title: 'Descrip. Extendida', data: 'ExtendedDescription' },
                    { title: 'Impuesto', data: 'ItemTaxDescription' },
                ]
            }
        };
    </script>

    @* FUNCIONES *@
    <script>
        $(function () {
            initMenuItemsLayout();
            initDataPlugins();
        });

        function initMenuItemsLayout() {
            openMenu(["#nav-item-camb-masivos"]);
            activeItemMenu([".nav-item-camb-masivos", "#nav-link-camb-masivos-worksheet"])
        }

        function initDataPlugins() {
            $('#fecha_desde').datetimepicker({ format: 'DD/MM/YYYY', defaultDate: new Date() });
            $('#fecha_hasta').datetimepicker({ format: 'DD/MM/YYYY', defaultDate: new Date() });
            initDataTableWorksheet();
            initDataTableWorksheetHistory();
            $(document).on('shown.bs.modal', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
            $('a[data-toggle="pill"]').on('shown.bs.tab', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
            $('#inputSearch').keyup(function (e) { if (e.keyCode == 13) onClickBtnSearch(); });
            $('#fecha_desde').keyup(function (e) { if (e.keyCode == 13) onClickBtnSearch(); });
            $('#fecha_hasta').keyup(function (e) { if (e.keyCode == 13) onClickBtnSearch(); });
        }

        async function initDataTableWorksheet() {
            elementsObj.dataTableWorksheet = $("#" + elementsIDs.div_table + " > table").DataTable({
                ajax: {
                    url: urls.GetAll_Worksheets, type: 'POST', datatype: 'json',
                    data: function (d) {
                        var data = $.extend({}, d, {
                            searchValue: $('#inputSearch').val(),
                            fromDate: $('#fecha_desde').datetimepicker('date') == null ? '' : $('#fecha_desde').datetimepicker('date').toDate().toDateString(),
                            toDate: $('#fecha_hasta').datetimepicker('date') == null ? '' : $('#fecha_hasta').datetimepicker('date').toDate().toDateString(),
                        });
                        return data;
                    },
                },
                columns: [
                    { title: 'Ref #', data: 'ID' },
                    { title: 'Estilo', data: 'Style', visible: false },
                    {
                        title: 'Estado', data: 'Status', render: function (data, type, row, meta) {
                            return type === 'display'
                                ? `<span class="badge bg-${dataView.statusColor[data]}">${dataView.statusText[data]}</span>`
                                : dataView.statusText[data];
                        }
                    },
                    { title: 'Título', data: 'Title' },
                    { title: 'Fecha Creada', data: 'DateAppliedString' },
                    { title: 'Fecha a Aplicar', data: 'EffectiveDateString' },
                    { title: 'Tarea', data: 'TaskDescription' },
                    { title: 'Cód. Tarea', data: 'TaskCode', visible: false },
                    { title: 'Cód. Tiendas', data: 'StroresID', visible: false },
                    { title: 'Tiendas', data: 'StoresName' },
                    { title: 'Notas', data: 'Notes', visible: false },
                    { title: 'Usuario', data: 'UserName', visible: false },
                    {
                        orderable: false, data: 'ID', render: function (data, type, row, meta) {
                            var title = "Ver Hoja de Trabajo";
                            return type == 'display' ? `<td>
                                                            <button class='btn btn-primary' title="${title}"
                                                                onClick='onClickBtnEditWorksheet(${data})'>
                                                                <i class='fa fa-eye' aria-hidden='true'></i>
                                                            </button>
                                                            ${row.WorksheetContentID > 0 ? `<a class='btn btn-success' target="_blank"
                                                                href='@Url.Action("DownloadFile", "HojasTrabajo")?worksheetContentID=${row.WorksheetContentID}&worksheetID=${data}'>
                                                                <i class='fa fa-download' aria-hidden='true'></i>
                                                            </button>` : ''}
                                                        </td>` : data;
                        }
                    }
                ],
                order: [[0, 'desc']],
                dom: `<'row' <'col-md-6'l><'#dtButtons.col-md-6'B>>
                    <'row' <'col-12'tr>>
                    <'row' <'col-12 col-md-6'i><'col-12 col-md-6'p>>`,
                language: dtable_i18n, paging: true, lengthChange: true,
                serverSide: true, autoWidth: false, ordering: true,
                processing: true, responsive: true, deferLoading: 0,
                buttons: ['colvis', 'pdf', 'excel'],
            });
            $('#dtButtons > .dt-buttons').addClass('float-right');
        }

        function initDataTableWorksheetHistory() {
            elementsObj.dataTableWorksheetHistory = $("#tbl_content_worksheetHistories > table").DataTable({
                data: elementsObj.worksheetHistory,
                columns: [
                    {
                        title: 'Estado', data: 'Status', render: function (data, type, row, meta) {
                            return type == 'display' ? `<span class="badge bg-${dataView.statusColor[data]}">${dataView.statusText[data]}</span>` : data;
                        }
                    },
                    { title: 'Fecha/Hora', data: 'HistoryDateString' },
                    { title: 'Tienda', data: 'StoreName' },
                    { title: 'Comment', data: 'Comment' },
                ],
                dom: `<'row' <'col-12'l><'col-md-6'B><'col-md-6'f>>
                    <'row' <'col-12'tr>>
                    <'row' <'col-12 col-md-6'i><'col-12 col-md-6'p>>`,
                order: [[1, 'desc']],
                language: dtable_i18n, paging: true, lengthChange: true,
                autoWidth: false, ordering: true,
                processing: true, responsive: true,
                buttons: ['colvis', 'pdf', 'excel'],
            });
        }

        function initDataTableWorksheetContent(cols) {
            if (elementsObj.dataTableWorksheetContent != null) elementsObj.dataTableWorksheetContent.destroy();

            $(`#tbl_content_worksheetContent > table`).empty();

            elementsObj.dataTableWorksheetContent = $("#tbl_content_worksheetContent > table").DataTable({
                data: elementsObj.worksheetContents,
                columns: cols,
                dom: `<'row' <'col-12'l><'col-md-6'B><'col-md-6'f>>
                    <'row' <'col-12'tr>>
                    <'row' <'col-12 col-md-6'i><'col-12 col-md-6'p>>`,
                language: dtable_i18n, paging: true, lengthChange: true,
                autoWidth: false, ordering: true, destroy: true, remove: true,
                processing: true, responsive: true,
                buttons: ['colvis', 'pdf', 'excel'],
            });
        }

        function getWorksheetData(id) {
            $(`#${elementsIDs.spinner_modal}`).show();

            $.get(urls.Get_Worksheet, { workSheetID: id }).done(async function (data) {
                if (data.Status) {
                    elementsObj.worksheet = data.Result.worksheet;
                    elementsObj.worksheetStores = data.Result.worksheetStores;
                    elementsObj.worksheetHistory = data.Result.worksheetHistory;
                    elementsObj.worksheetContents = data.Result.worksheetContents;

                    setWorksheetInModal(elementsObj.worksheet);
                    setWorksheetStoresInModal(elementsObj.worksheetStores);

                    await elementsObj.dataTableWorksheetHistory.clear().rows.add(elementsObj.worksheetHistory).draw();
                    await initDataTableWorksheetContent(elementsObj.worksheet.Style === 320 ? (dataView.dataTableWorksheetContentColums[320]) : (elementsObj.worksheet.Style === 251 ? (dataView.dataTableWorksheetContentColums[251]) : dataView.dataTableWorksheetContentColums[261]));

                    $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
                } else error(data.InternalMessage, data.Message);
                $(`#${elementsIDs.spinner_modal}`).hide();
            }).fail(function (jqXHR, textStatus, errorThrown) {
                error(errorThrown, '@Resources.messages.error_obt_reg');
                console.error(jqXHR);
                console.error(textStatus);
                $(`#${elementsIDs.spinner_modal}`).hide();
            });
        }

        function setWorksheetInModal(w) {
            $(`#title`).val(w.Title);
            $(`#style`).val(`${w.Style}-${dataView.styles[w.Style]}`);
            $(`#reference`).val(w.ID);
            $(`#notes`).val(w.Notes);
            $(`#status`).val(dataView.statusText[w.Status]);
            $(`#task`).val(w.TaskDescription);
            $(`#task`).val(w.TaskDescription);

            $('#date_effective').val(w.EffectiveDateString);
        }

        function setWorksheetStoresInModal(stores) {
            $("#tbl_stores > tbody").html(null);

            for (var i = 0; i < stores.length; i++) {
                var row = $("<tr/>")
                $("#tbl_stores > tbody").append(row);
                row.append($(`<td>${stores[i].StoreID}-${stores[i].StoreName}</td>`))
                row.append($(`<td><span class="badge bg-${dataView.statusColor[stores[i].Status]}">${dataView.statusText[stores[i].Status]}</span></td>`))
            }
        }

        function onClickBtnSearch(flag = true) {
            elementsObj.dataTableWorksheet.ajax.reload();
        }

        function onClickBtnEditWorksheet(id) {
            clearObjectWorksheet();
            clearModal();

            $(`#${elementsIDs.worksheetID}`).val(id);
            getWorksheetData(id);
            openModal();
        }

        function onClickBtnChangeStatus(status) {
            if (elementsObj.worksheet != null) {
                if (elementsObj.worksheet.Status == (status == 1 ? 2 : 1)) {
                    if (elementsObj.worksheetContents.length <= 0 && status === 2) {
                        Swal.fire({
                            title: "Hoja de trabajo vacía", html: `La hoja de trabajo se encuentra vacía ¿Enviar hoja de trabajo a estado "${dataView.statusText[8]}"?`, icon: 'info', showCancelButton: true,
                        }).then((result) => {
                            if (result.isConfirmed) applyChangeStatus(8);
                        });
                    } else {
                        Swal.fire({
                            title: "¿Continuar?", html: `La hoja de trabajo cambiará de estado "${dataView.statusText[elementsObj.worksheet.Status]}" a  estado "${dataView.statusText[status]}"`, icon: 'warning', showCancelButton: true,
                        }).then((result) => {
                            if (result.isConfirmed) applyChangeStatus(status);
                        });
                    }

                } else {
                    error(`Estado diferente de ${status == 1 ? 2 : 1}`, `No se puede ${status == 1 ? 'desaprobar' : (status == 2 ? 'aprobar' : 'suspender')} la hoja de trabajo, porque ya se encuentra en estado "${dataView.statusText[elementsObj.worksheet.Status]}"`);
                }
            } else {
                error("Worksheet no cargado", "No se ha seleccionado una hoja de trabajo")
            }
        }

        function onClickBtnDownloadFile(w, wc) {
            if (w > 0 && wc > 0) {
                var obj = elementsObj.dataTableWorksheet.data().toArray().find(x => x.ID === w && x.WorksheetContentID === wc);

                if (obj) {
                    $(`#modal-overlay`).modal({ backdrop: 'static', keyboard: false });

                    $.fileDownload('@Url.Action("DownloadFile", "HojasTrabajo")', {
                        httpMethod: "POST",
                        data: { worksheetContentID: wc, worksheetID: w },
                        successCallback: function () {
                            $(`#modal-overlay`).modal('toggle');
                            Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: true }).fire({ icon: 'success', title: ' Documento descargado' });
                        }
                    }).done(function () {
                        $(`#modal-overlay`).modal('toggle');
                        Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: true }).fire({ icon: 'success', title: ' Documento descargado' });
                    });/*.fail(function () {
                        error("", "Hubo un problema al descargar el archivo de los cambios aplicados, verifique con el administrador que tenga los permisos necesarios para visualizar la información.")
                    });*/
                    return false;
                } else {
                    error("Contenido no pertenece a hoja de trabajo. Notificación de alerta por modifición de código en cliente.", "No se puede descargar el documento ya que este no pertence a la hoja de trabajo seleccionada.")
                }
            } else error("Sin IDS", "Hoja de tabajo con contiene registrado un documento de cambios realizados.")
        }

        function applyChangeStatus(status) {
            $(`#${elementsIDs.spinner_modal}`).show();
            $.post(urls.Change_Status, { worksheetID: elementsObj.worksheet.ID, status: status }).done(function (data) {
                if (data.Status) Toast.fire({ icon: 'success', title: ' Cambios aplicados' });
                else error(data.InternalMessage, `No se pudieron aplicar los cambios: ${data.Message}`);

                $(`#${elementsIDs.spinner_modal}`).show();
                onClickBtnSearch();
                onClickBtnEditWorksheet(elementsObj.worksheet.ID);
            }).fail(function () {
                $(`#${elementsIDs.spinner_modal}`).show();
                error(errorThrown, '@Resources.messages.error_intento_editar');
                console.log(jqXHR);
                console.log(textStatus);
            });
        }

        function clearObjectWorksheet() {
            elementsObj.worksheet = null;
            elementsObj.worksheetStores = [];
            elementsObj.worksheetHistory = [];
            elementsObj.worksheetContents = [];
        }

        function clearModal() {
            $(`#${elementsIDs.modal} input`).val("");
            $("#tbl_stores > tbody").html(null);
        }

        /** Abre la modal */
        function openModal() {
            $(`#${elementsIDs.title_modal}`).html(`@Resources.views.editar Hoja de Trabajo`);
            $(`#${elementsIDs.modal}`).modal({ backdrop: 'static', keyboard: false });
        }

    </script>
</body>
</html>
