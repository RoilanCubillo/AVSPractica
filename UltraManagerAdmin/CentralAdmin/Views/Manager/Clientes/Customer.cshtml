    function selectAndRemoveOptions(optionIds, isFirstIteration) {
        var select_categs = $('#AccountIdTienda');
        var data = getStoresToDataSelect2();

        // Asegúrate de que optionIds sea un array de cadenas
        if (!Array.isArray(optionIds)) {
            optionIds = [optionIds.toString()];
        }

        if (isFirstIteration === true) {
            select_categs.empty();
        }

        var selectedStores = data.filter(function (item) {
            return optionIds.includes(item.id.toString());
        });

        // Limpia la selección anterior
        select_categs.val(null).trigger('change');

        // Agrega las tiendas correspondientes
        select_categs.select2({
            data: selectedStores,
            theme: 'bootstrap4'
        });

        select_categs.val(optionIds).trigger('change');
    }


    function convertirFormatoFecha(cadenaFecha) {
        // Verificar si la cadena de fecha es null o indefinida
        if (cadenaFecha === null || cadenaFecha === undefined) {
            return "No hay fecha";
        }

        // Verificar si la cadena de fecha contiene un número de milisegundos
        var match = cadenaFecha.match(/\d+/);
        if (match) {
            var fechaEnMilisegundos = parseInt(match[0], 10);
            var fechaObjeto = new Date(fechaEnMilisegundos);
            var dia = fechaObjeto.getDate();
            var mes = fechaObjeto.getMonth() + 1; // Sumar 1 al mes (comienza desde 0)
            var año = fechaObjeto.getFullYear();
            return `${dia < 10 ? '0' : ''}${dia}-${mes < 10 ? '0' : ''}${mes}-${año}`;
        } else {
            // Si la cadena no contiene milisegundos, asumimos que es una fecha válida
            var fechaObjeto = new Date(cadenaFecha);
            if (!isNaN(fechaObjeto.getTime())) {
                var dia = fechaObjeto.getDate();
                var mes = fechaObjeto.getMonth() + 1; // Sumar 1 al mes (comienza desde 0)
                var año = fechaObjeto.getFullYear();
                return `${dia < 10 ? '0' : ''}${dia}-${mes < 10 ? '0' : ''}${mes}-${año}`;
            }
        }

        return "Fecha inválida";
    }

