    function tieneCuenta(num) {
        var cuentaEncontrada = listAccounts.find(x => x.Number === num);
        return cuentaEncontrada ? false : true;
    }

     function findCustomer(id) {
         return list_customers.find(x => x.ID === id);
    }

    function findCustomerAccountNumber(accountNumber) {
        return list_customers.find(x => x.AccountNumber === accountNumber);
    }

    function findExtCentralCustomer(id) {
        return listExtCentralCustomer.find(x => x.CustomerID === id);
    }
    function findAccount(accountNumber) {
        return listAccounts.find(x => x.Number === accountNumber);
    }

    function findBalCuenta(accountid) {
        return listAccountBalance.find(x => x.ID === accountid);
    }

    function findBalCliente(accountid) {
        return listCustomerBalance.find(x => x.ID === accountid);
    }

    function findStoreAccount(accountGroupID) {
        return listExtCentralAccountGroup.find(x => x.AccountGroupID === accountGroupID)
    }
    function findStore(storeId) {
        if (storeId.includes(',')) {
            const storeIdsArray = storeId.split(',').map(id => id.trim());
            return listStores.filter(x => storeIdsArray.includes(x.CodeS));
        } else {
            return listStores.find(x => x.CodeS === storeId);
        }
    }
    function findAccountGroup(accountGroupID) {
        return listAccountGroups.find(x => x.ID === accountGroupID)
    }

    function findEstadoTienda(accountID) {
        return listAccountDynamic.find(x => x.AccountID === accountID)
    }

    function onClickBtnEditCustomer(id) {
        var customer = findCustomer(id);
        var extcentralCustomer = findExtCentralCustomer(id);
        if (customer) {
            newModal(false);
            setCustomerInModal(extcentralCustomer, customer);
        } else Toast.fire({ icon: "warning", title: "@Resources.messages.error_reg_edit_inval" });
    }

    function onClickBtnCuenta(accountNumber) {
        var account = findAccount(accountNumber);
        var AutoId = findCustomerAccountNumber(accountNumber);
        var balCuenta = findBalCuenta(account.ID);
        var balCliente = findBalCliente(account.ID);
        var estadoTienda = findEstadoTienda(account.ID);
        var storesGroupID = findStoreAccount(account.GroupID);
        var accountGroup = findAccountGroup(account.GroupID);
        var stores = findStore(storesGroupID.StoreID);

        // Llamamos a getAccountStoreBalance y manejamos la promesa
        getAccountStoreBalance(account.ID, account.GroupID)
            .then(function (balances) {
                if (account) {
                    newModalAccount(true);
                    setAccountInModal(account, balCuenta, balCliente, stores, accountGroup, balances, AutoId, estadoTienda);
                } else {
                    Toast.fire({ icon: "warning", title: "@Resources.messages.error_reg_edit_inval" });
                }
