        newModalAccount(true);
    }
    function onClickBtnNewMsgItem() {
            Swal.fire({
                title: '@Resources.messages.msj_continuar', html: "@Resources.messages.msj_campos_limpiar", icon: 'warning', showCancelButton: true,
            }).then((result) => { if (result.isConfirmed) newModal(true); });
    }

    function onClickBtnNewCuenta() {
            Swal.fire({
                title: '@Resources.messages.msj_continuar', html: "@Resources.messages.msj_campos_limpiar", icon: 'warning', showCancelButton: true,
            }).then((result) => { if (result.isConfirmed) newModalAccount(true); });
    }
    function newModal(is_new) {
        CleanForm("form_customer");
        $("#title_modal_customer").html((is_new ? "@Resources.views.agregar " : "@Resources.views.editar ") + "@ViewBag.Title");
        $('#modal_customer').modal({ backdrop: 'static', keyboard: false });
    }

    function newModalAccount(is_new) {
        CleanForm("form_account");
        $("#title_modal_account").html((is_new ? "@Resources.views.agregar " : "@Resources.views.editar ") + "@ViewBag.Title");
        $('#modal_account').modal({ backdrop: 'static', keyboard: false });
    }

    function initDataTable() {

        DataCustomers = $("#TableCustomer").DataTable({
            columns: [
                { title: "Número de Cuenta", data: "AccountNumber" },
                { title: "Nombre", data: "FirstName" },
                { title: "Apellido", data: "LastName" },
                { title: "Compañía", data: "Company" },
                { title: "Número de Teléfono", data: "PhoneNumber" },
                { title: "Dirección", data: "Address" },
                { title: "Correo Electrónico", data: "EmailAddress" },
                { title: "Número de Fax", data: "FaxNumber" },
                { title: "Descuento", data: "CurrentDiscount" },
                {
                    orderable: false, // Para que no se pueda ordenar esta columna
                    data: "ID", // La propiedad de tus datos que se utilizará para esta columna
                    render: function (data, type, row, meta) {
                        var title = "Editar";
                        return type === 'display' ?
                            `<button class='btn btn-primary' title="${title}" onClick='onClickBtnEditCustomer(${data})'>
                            <i class='fa fa-pencil' aria-hidden='true'></i>
                            </button>` : data;
                    }
                },
                {
                    orderable: false, // Para que no se pueda ordenar esta columna
                    data: "AccountNumber", // La propiedad de tus datos que se utilizará para esta columna
                    render: function (data, type, row, meta) {
                        var title = "Cuenta";
                        var hasAccount = tieneCuenta(data);

                        if (type === 'display') {
                            if (hasAccount) {
                                // Si tiene cuenta, crea un botón para crear una cuenta
                                return `<button class='btn btn-success' title="${title}" onClick='onClickBtnCrearCuenta("${data}")'>
                                Crear Cuenta
                                </button>`;
                            } else {
                                // Si no tiene cuenta, crea un botón para la acción normal
                                return `<button class='btn btn-primary' title="${title}" onClick='onClickBtnCuenta("${data}")'>
                                Editar Cuenta
                                </button>`;
                            }
                        } else {
                            return data;
                        }
                    }
                }
            ],
            language: dtable_i18n, paging: true, lengthChange: true,
            autoWidth: false, ordering: true,
            responsive: true, buttons: ['colvis', 'pdf', 'excel'],
            data: []
        })
    }

    /** Método encargado de consultar al servidor por la lista de Payment Terms */
    async function getAllCustomers() {
        try {
            await $.get(url_getAllCustomers).done(async function (data) {
                    if (data.Status) {
                        list_customers = data.Result.list_customers;
                        listExtCentralAccountGroup = data.Result.listExtCentralAccountGroup;
                        listExtCentralCustomer = data.Result.listExtCentralCustomer;
                        listCustomCaption = data.Result.listCustomCaption;
                        listAccounts = data.Result.listAccounts;
                        listAccountGroups = data.Result.listAccountGroups;
                        listAccountManager = data.Result.listAccountManager;
                        listPaymentTerms = data.Result.listPaymentTerms;
                        listFinanceCharge = data.Result.listFinanceCharge;
                        listStatementType = data.Result.listStatementType;
                        listAccountBalance = data.Result.listAccountBalance;
                        listCustomerBalance = data.Result.listCustomerBalance;
                        listStores = data.Result.listStores;
                        listAccountDynamic = data.Result.listAccountDynamic;
                        await DataCustomers.clear().rows.add(list_customers).draw();
                        await fillSelect2ExtCentralAccountGroup();
                        await fillCustomTextInputLabel();
                        await fillCustomDateInputLabel();
                        await fillCustomTelfInputLabel();
                        await fillSelect2AccountGroups();
                        await fillSelect2ManagerAccount();
                        await fillSelect2Payterms();
                        await fillSelect2FinanceCharge();
                        await fillSelect2StatementType();
                        await fillSelect2Stores();
                        $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
                    } else {
                        error(data.InternalMessage, data.Message);
                        $("#" + elements.spn_table).hide();
                    }
                }).fail(function (data) { error(data, "@Resources.messages.error_obt_regs"); });
            } catch (e) { error(e, "@Resources.messages.error_obt_regs"); }
    }

    function getAccountStoreBalance(accountID, groupID) {
        return $.get(url_getAccountStoreBalance, { accountID: accountID, groupID: groupID })
            .then(function (data) {
                AccountStoreBalance = data.Result.AccountStoreBalance;
                return AccountStoreBalance; // Resolvemos la promesa con el valor deseado
            })
            .fail(function (error) {
                // Handle errors here, for example, display an error message.
                handleError(error);
                throw error; // Rechazamos la promesa en caso de error
            });
    }


