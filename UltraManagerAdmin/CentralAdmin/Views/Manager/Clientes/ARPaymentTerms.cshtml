</body>
</html>

@* Variables *@
<script>
    var url_getAllPaymentTerms = '@Url.Action("GetAll", "ARPaymentTerms")'; // URL del evento obtener PaymenteTerms
    var url_savePaymentTerms = '@Url.Action("Save", "ARPaymentTerms")'; // URL del evento guardar PaymentTerms
    var list_paymentterms = [];

    var DataPaymenterms = null;
    var Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 4000 }); // Variable para mostrar los mensajes.

    //var elements = { div_table: "tbl_content_family", spn_table: "spn_tbl_family", spn_modal: "spn_modal_family", modal: "modal_family", title_modal: "title_modal_family", form: "form_modal_family" };

</script>

@* Funciones *@
<script>
    $(function () {
        initDataTable();
        getAllPaymentTerms();
    });


    function initDataTable() {

        DataPaymenterms = $("#PaymentTable").DataTable({
            columns: [
                { title: "Código", data: "Code" },
                { title: "Nombre", data: "Name" },
                { title: "Inactivo", data: "Inactive" },
                { title: "Tipo de Fecha de Vencimiento", data: "DateDueType" },
                { title: "Período de Gracia", data: "GracePeriod" },
                { title: "Pago Mínimo", data: "MinimunPayment" },
                {
                    orderable: false, // Para que no se pueda ordenar esta columna
                    data: "Code", // La propiedad de tus datos que se utilizará para esta columna
                    render: function (data, type, row, meta) {
                        var title = "Editar";
                        return type === 'display' ?
                            `<button class='btn btn-primary' title="${title}" onClick='onClickBtnEditPaymentTerm("${data}")'>
                            <i class='fa fa-pencil' aria-hidden='true'></i>
                            </button>` : data;
                    }
                }


            ],
            language: dtable_i18n, paging: true, lengthChange: true,
            autoWidth: false, ordering: true,
            responsive: true, buttons: ['colvis', 'pdf', 'excel'],
            data:[]
        })
    }


    function onClickBtnAddMsgItem() {
        newModal(true);
    }

    function findPayterm(code) {
        return list_paymentterms.find(x => x.Code === code);
    }

    function onClickBtnEditPaymentTerm(code) {
        var paymentTermData = findPayterm(code);
        if (paymentTermData) {
            newModal(false);
            setPaymentTermInModal(paymentTermData);
        } else Toast.fire({ icon: "warning", title: "@Resources.messages.error_reg_edit_inval" });
    }


    function onClickBtnNewMsgItem() {
            Swal.fire({
                title: '@Resources.messages.msj_continuar', html: "@Resources.messages.msj_campos_limpiar", icon: 'warning', showCancelButton: true,
            }).then((result) => { if (result.isConfirmed) newModal(true); });
    }
    /** Limpia la modal. is_new ? "Agregar Registro" : "Editar Registro" */
    function newModal(is_new) {
        CleanForm("form_paymentterms");
        $("#title_modal_paymentterms").html((is_new ? "@Resources.views.agregarTermPag " : "@Resources.views.editTermpag ") + "@ViewBag.Title");
        $('#modal_paymentterms').modal({ backdrop: 'static', keyboard: false });
    }

    function setPaymentTermInModal(paymentTermData) {
        try {
            $("#PayCode").val(paymentTermData.Code);
            $("#PayName").val(paymentTermData.Name);
            $("#chk_pay_inactivo").prop("checked", paymentTermData.Inactive);
            $("#PayTFechaV").val(paymentTermData.DateDueType).trigger("change");
            $("#PayPariodo").val(paymentTermData.GracePeriod);
            $("#PayPagoM").val(paymentTermData.MinimunPayment);
        }
        catch (e) {
            error(e, "@Resources.messages.error_mostrar_reg_edit");
        }
    }


    function getPaymentTermFromModal() {
        var data = {
            Code: $("#PayCode").val(),
            Name: $("#PayName").val(),
            Inactive: $("#chk_pay_inactivo").is(":checked"),
            DateDueType: $("#PayTFechaV").val(),
            GracePeriod: $("#PayPariodo").val(),
            MinimunPayment: $("#PayPagoM").val(),
        }

        return data;
    }

    /** Método encargado de consultar al servidor por la lista de Payment Terms */
    async function getAllPaymentTerms() {
        try {
                await $.get(url_getAllPaymentTerms).done(async function (data) {
                    if (data.Status) {
                        list_paymentterms = data.Result;
                        await DataPaymenterms.clear().rows.add(list_paymentterms).draw();
                        $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
                    } else {
                        error(data.InternalMessage, data.Message);
                        $("#" + elements.spn_table).hide();
                    }
                }).fail(function (data) { error(data, "@Resources.messages.error_obt_regs"); });
            } catch (e) { error(e, "@Resources.messages.error_obt_regs"); }
    }

    async function SavePaymentTerm() {
        try {
            var paymentTermData = getPaymentTermFromModal();
            await $.post(url_savePaymentTerms, paymentTermData, "json")
            .done(function (data) {
                if (data.Status) {
                    Toast.fire({ icon: 'success', title: data.Message });
                    $('#modal_paymentterms').modal('hide');
                    getAllPaymentTerms();
                } else {
                    Toast.fire({ icon: 'error', title: data.Message });
                }
            })
            .fail(function () {
                error("ERROR AL GUARDAR", "@Resources.messages.error_intento_guardar");
            })
            .always(function () {
            });
        } catch (e) { error(e, "@Resources.messages.error_intento_guardar"); }
    }


    function setValidationForPaymentTermsForm() {
        var rules = {
            PayCode: {
                required: true,
                pattern: /^(1000|[1-9]\d{0,2})[A-Za-z]$/,
            },
            PayName: {
                required: true,
                pattern: /^[A-Za-z0-9\sáéíóúÁÉÍÓÚüÜñÑ]+$/,
            },
            chk_pay_inactivo: {
            },
            PayPariodo: {
                required: true,
                number: true 
            },
            PayPagoM: {
                required: true,
                number: true 
            }
        };
        var messages = {
            PayCode: {
                required: "El código es obligatorio.",
                pattern: "El código debe ser un número seguido de una letra."
            },
            PayName: {
                required: "El nombre es obligatorio.",
                pattern: "El nombre solo puede contener letras, números y espacios."
            },
            PayPariodo: {
                required: "El período de gracia es obligatorio.",
                number: "Ingrese solo números en el período de gracia."
            },
            PayPagoM: {
                required: "El pago mínimo es obligatorio.",
                number: "Ingrese solo números en el pago mínimo."
            },
        };
        $.validator.setDefaults({
            submitHandler: function () {
                SavePaymentTerm();
            }
        });
        $('#form_paymentterms').validate({
            rules: rules,
            messages: messages,
            errorElement: 'span',
            errorPlacement: function (err, element) {
                err.addClass('invalid-feedback ml-2');
                element.closest('.form-group').append(err);
            },
            highlight: function (element, errorClass, validClass) {
                $(element).addClass('is-invalid');
            },
            unhighlight: function (element, errorClass, validClass) {
                $(element).removeClass('is-invalid');
            }
        });
    }

</script>


