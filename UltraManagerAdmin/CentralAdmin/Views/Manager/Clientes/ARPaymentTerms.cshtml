<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6"><h1>Términos de Pago</h1></div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="@Url.Action("Manager", "Inicio")">@Resources.views.inicio</a></li>
                                <li class="breadcrumb-item active">@Resources.views.clientes</li>
                                <li class="breadcrumb-item active">@Resources.views.termPago</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </section><!-- Encabezado -->
            <!-- Muestra de Artículos -->
            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <div class="col-md-12 mb-3" style="overflow: auto;">
                                        <div class="row-cols-md-6">
                                            <button type="button" class="btn btn-primary float-right fa-pull-right" onclick="onClickBtnAddMsgItem()"><i class="fa fa-plus"> </i> @Resources.views.agregar</button>
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div id="tbl_paymentterms" class="dataTables_wrapper dt-bootstrap4 col-12">
                                            <table id="PaymentTable" class="table table-bordered table-striped">
                                            </table>
                                        </div><!-- Table msg -->
                                    </div>
                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Modal -->
            <div class="modal fade" id="modal_paymentterms">
                <div class="modal-dialog modal-dialog-scrollable">
                    <form id="form_paymentterms" class="modal-content">
                        <!-- Encabezado Modal -->
                        <div class="modal-header">
                            <h4 id="title_modal_paymentterms" class="modal-title"></h4>
                            <button type="button" class="close" data-dismiss="modal" aria-label="Cerrar"><span aria-hidden="true">&times;</span></button>
                        </div><!-- Encabezado Modal -->
                        <!-- Content of the modal goes here -->
                        <!-- Cuerpo Modal -->
                        <div class="modal-body">
                            <input type="hidden" id="PayID" />
                            <div class="form-group">
                                <label for="PayCode" class="col-sm-1 control-label">@Resources.views.cod</label>
                                <input id="PayCode" name="PayCode" type="text" class="form-control" placeholder="@Resources.views.ingresar_cod" />
                            </div>
                            <div class="form-group">
                                <label for="PayName" class="col-sm-1 control-label">@Resources.views.nom</label>
                                <input id="PayName" name="PayName" type="text" class="form-control" placeholder="@Resources.views.ingresar_nom" />
                            </div>
                            <div class="icheck-primary ml-3">
                                <label for="chk_pay_inactivo">@Resources.views.inactivo</label>
                                <input type="checkbox" id="chk_pay_inactivo" name="chk_pay_inactivo">
                            </div>
                            <div class="form-group">
                                <label for="PayTFechaV" class="col-sm-12 control-label">@Resources.views.tipoFechaVecimento</label>
                                <select id="PayTFechaV" name="PayTFechaV" class="form-control select2bs4" style="width: 100%;">
                                    <option value="1">Factura</option>
                                    <option value="0">Cierre</option> 
                                </select>
                            </div>

                            <div class="form-group">
                                <label for="PayPariodo" class="col-sm-12 control-label">@Resources.views.periodoGracia</label>
                                <input id="PayPariodo" name="PayPariodo" type="text" class="form-control" placeholder="@Resources.views.ingresar_periodoGracia" />
                            </div>

                            <div class="form-group">
                                <label for="PayPagoM" class="col-sm-12 control-label">@Resources.views.pagoMinimo</label>
                                <input id="PayPagoM" name="PayPagoM" type="text" class="form-control" placeholder="@Resources.views.ingresar_pagoMinimo" />
                            </div>
                        </div><!-- Cuerpo Modal -->
                        <div class="modal-footer">
                            <button type="button" class="btn btn-primary" onclick="onClickBtnNewMsgItem()"> <i class="fa fa-plus"></i> @Resources.views.nuevo</button>
                            <button type="submit" class="btn btn-success" onclick="setValidationForPaymentTermsForm()"> <i class="fa fa-save"></i> @Resources.views.guardar</button>
                            <button type="button" class="btn btn-danger" data-dismiss="modal"> <i class="fa fa-ban"></i> @Resources.views.cerrar</button>
                        </div>
                    </form><!-- Form Modal Content -->
                </div><!-- Modal Dialog -->
            </div><!-- Modal -->

        </div><!-- Cierre de content-wrapper -->
