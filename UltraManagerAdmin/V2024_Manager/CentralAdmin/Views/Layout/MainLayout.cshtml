    <script>
        var asking = false;

        $(function () {
            $(".uerp-lang").click(function () { onClickLang($(this)); })
            $("#img-lang").attr("src", "../Content/AdminLTE/dist/img/flags/" + "@System.Threading.Thread.CurrentThread.CurrentCulture.Name" + ".png")
            $("#opcLangDefault").click(function () { onClickOpcLangDefault(); });

            $(this).mousemove(function (e) {
                validateSession();
            });

            $(this).click(function (e) {
                validateSession();
            });

            $(this).keydown(function (e) {
                validateSession();
            });
        });

        function sleep(ms) {
            return new Promise(resolve => setTimeout(resolve, ms));
        }

        function validateSession() {
            if (!asking) {
                asking = true;

                $.post('@Url.Action("ValidateSession", "Inicio")').done(async function (data, x, y) {
                    if (data != 1) {
                        await sleep(1);
                        await alert(`La sesión se cerrará por: ${data === 0 ? "Solucitud del administrador" : "Inactividad"}`);

                        location.reload();
                    } else {
                        await sleep(1000);
                        asking = false;
                    }
                }).fail(function (jqXHR, textStatus, errorThrown) {
                    asking = false;
                });
            }
        }

        function openMenu(menus) {
            menus.forEach((m) => { $(m).addClass("menu-open") })
        }

        /** Método para activar los menú del page principal */
        function activeItemMenu(items) {
            items.forEach((i) => { $(i).addClass("active") });
        }

        function onClickLang(item) {
            $.cookie("ultraerp-language", item.attr("lang"), { expires: 365, path: '/' });
        }

        function onClickOpcLangDefault() {
            $.removeCookie("ultraerp-language", { path: '/' });
        }

        /** Muestra un error, recibe excepcion para mostrar en consola y el mensaje para el usuario. */
        function error(e, msj) {
            Toast.fire({ icon: 'error', title: msj });
            console.error(e);
        }


    </script>
