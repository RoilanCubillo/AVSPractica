    <title>AVS | Central Manager</title>
    <link href="~/Content/AdminLTE/Local/favicon2.ico" rel="shortcut icon" type="image/x-icon" />
    <!-- Google Font: Source Sans Pro -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&amp;display=fallback">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/fontawesome-free/css/all.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/fontawesome-free/css/fontawesome.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/fontawesome-free/css/solid.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/fontawesome-free/css/regular.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/fontawesome-free/css/v4-shims.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/fontawesome-free/css/svg-with-js.min.css">
    <!-- icheck bootstrap -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/Content/AdminLTE/dist/css/adminlte.min.css">

    <script src="~/Content/AdminLTE/plugins/jquery/jquery.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/jquery-ui/jquery-ui.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/AdminLTE/dist/js/adminlte.min.js"></script>

    <script>

        var dtable_i18n = {
            search: '@Resources.views.buscar',
            info: '@Resources.views.dtable_info',
            infoEmpty: '@Resources.views.dtable_infoEmpty',
            lengthMenu: '@Resources.views.dtable_lengthMenu',
            zeroRecords: '@Resources.views.dtable_zeroRecords',
            infoFiltered: '@Resources.views.dtable_infoFiltered',
            paginate: {
                first: '@Resources.views.dtable_first',
                last: '@Resources.views.dtable_last',
                next: '@Resources.views.dtable_sig',
                previous: '@Resources.views.dtable_previa'
            },
            buttons: {
                copySuccess: {
                    1: '@Resources.views.dtable_copy1',
                    _: '@Resources.views.dtable_copyMore'
                },
                copyTitle: '@Resources.views.dtable_copyTitle',
                colvis: '@Resources.views.column_visib',
                print: '@Resources.views.imprimir',
                copy: '@Resources.views.copiar',
            },
            processing: '<div class="justify-content-center">' +
                            '<i class="fas fa-3x fa-sync-alt fa-spin"></i>' +
                            '<div class="text-bold pt-2">@Resources.views.cargando</div>' +
                        '</div>',
        };

    </script>

    <!-- Scripts general-->
    <script src="~/Scripts/Custom/plugins-init.js"></script>
    <script src="~/Scripts/Custom/java-script-general.js"></script>
    <script src="~/Scripts/Custom/views-tools.js"></script>

    <!-- jQuery Cookies -->
    <script src="~/Content/AdminLTE/plugins/jquery-cookie/jquery.cookie.js"></script>

    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">

</head>

<!-- the fixed layout is not compatible with sidebar-mini -->
<body id="main_body" class="hold-transition skin-blue fixed sidebar-mini layout-fixed layout-navbar-fixed">
    <form id="frmMain">
        <div class="wrapper">
            <div class="preloader flex-column justify-content-center align-items-center">
