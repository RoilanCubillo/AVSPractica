                                    <img src="~/Content/AdminLTE/dist/img/flags/es-CR.png" alt="Flag CR" class="img-size-32 img-rounded mr-3">
                                    <div class="media-body">
                                        <h3 class="dropdown-item-title">Español - Costa Rica</h3>
                                    </div>
                                </div>
                            </a>
                            <div class="dropdown-divider"></div>
                            <a href="" class="dropdown-item uerp-lang" lang="en-US">
                                <div class="media">
                                    <img src="~/Content/AdminLTE/dist/img/flags/en-US.png" alt="Flag CR" class="img-size-32 img-rounded mr-3">
                                    <div class="media-body">
                                        <h3 class="dropdown-item-title">English - United States</h3>
                                    </div>
                                </div>
                            </a>
                            <div class="dropdown-divider"></div>

                            <a id="opcLangDefault" href="" class="dropdown-item dropdown-footer">@Resources.views.idioma_x_def</a>
                        </div>
                    </li>
                </ul>
