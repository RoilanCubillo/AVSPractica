@{
    Layout = "~/Views/Layout/MainLayout.cshtml";
    var Name = "Mantenimiento de Casas Comerciales";
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">

    @* < CSS > *@
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
    <!-- iCheck for checkboxes and radio inputs -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/icheck-bootstrap/icheck-bootstrap.min.css">
    @* < CSS / >*@

    @* < SCRIPTS > *@
    <!-- DataTables  & Plugins -->
    <script src="~/Content/AdminLTE/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/jszip/jszip.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/pdfmake/pdfmake.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/pdfmake/vfs_fonts.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.html5.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.print.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.colVis.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="~/Content/AdminLTE/plugins/sweetalert2/sweetalert2.min.js"></script>
    <!-- jquery-validation -->
    <script src="~/Content/AdminLTE/plugins/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/jquery-validation/additional-methods.min.js"></script>
    @* < SCRIPTS / >*@
</head>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <div class="content-wrapper">
            <!-- Encabezado -->
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6">
                            <h1>@Name</h1>
                        </div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="@Url.Action("Manager","Inicio")">@Resources.views.inicio</a></li>
                                <li class="breadcrumb-item active">@Resources.views.inventario</li>
                                <li class="breadcrumb-item active">Casas Comerciales</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </section><!-- Encabezado -->
            <!-- Muestra de Casas Comerciales -->
            <section class="content">
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-body">
                                    <div class="overlay-wrapper">
                                        <div id="spn_tbl" class="overlay justify-content-center">
                                            <i class="fas fa-3x fa-sync-alt fa-spin"></i>
                                            <div class="text-bold pt-2">@Resources.views.cargando</div>
                                        </div>
                                        <div class="col-12 d-flex justify-content-end">
                                            <button type="button" class="btn btn-primary float-right fa-pull-right" onclick="onClickBtnAddPurchaser()"><i class="fa fa-plus"> </i> @Resources.views.agregar</button>
                                        </div>
                                        <div id="tbl" class="dataTables_wrapper dt-bootstrap4">
                                            <table class="table table-bordered table-striped">
                                                <thead>
                                                    <tr>
                                                        <th>@Resources.views.cod</th>
                                                        <th>Código Extra</th>
                                                        <th>@Resources.views.nom</th>
                                                        <th>Correo Electrónico</th>
                                                        <th>Teléfono</th>
                                                        <th>Estado</th>
                                                        <th>Última Actualización</th>
                                                        <th></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section> <!-- Muestra de Casas Comerciales -->
            <!-- Modal -->
            <div id="modal" class="modal fade" role="dialog">
                <div class="modal-dialog modal-dialog-scrollable">
                    <!-- Modal content-->
                    <form id="form" class="modal-content">
                        <!-- Spinner Modal -->
                        <div id="spn_modal" class="overlay">
                            <i class="fas fa-2x fa-sync fa-spin"></i>
                        </div><!-- Spinner Modal -->
                        <!-- Encabezado Modal -->
                        <div class="modal-header text-center">
                            <h4 id="title_modal" class="modal-title"></h4>
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                        </div><!-- Encabezado Modal -->
                        <!-- Cuerpo Modal -->
                        <div class="modal-body" style="overflow: auto">
                            <input type="hidden" id="id" />
                            <div class="form-group">
                                <label for="code" class="control-label">@Resources.views.cod</label>
                                <input id="code" type="text" class="form-control" placeholder="@Resources.views.ingresar_cod" />
                            </div>
                            <div class="form-group">
                                <label for="extcode" class="control-label">Código Extra</label>
                                <input id="extcode" type="text" class="form-control" placeholder="@Resources.views.ingresar_cod extra" />
                            </div>
                            <div class="form-group">
                                <label for="name" class="control-label">@Resources.views.nom</label>
                                <input id="name" name="name" type="text" class="form-control" placeholder="@Resources.views.ingresar_nom" />
                            </div>
                            <div class="form-group">
                                <label for="email" class="control-label">Correo electrónico</label>
                                <input id="email" name="email" type="text" class="form-control" placeholder="Ingresar correo electrónico" />
                            </div>
                            <div class="form-group">
                                <label for="telephone" class="control-label">Teléfono</label>
                                <input id="telephone" name="telephone" type="text" class="form-control" placeholder="Ingresar teléfono" />
                            </div>
                            <div class="form-group col-12  clearfix ">
                                <div class="checkbox icheck-turquoise d-inline">
                                    <input type="checkbox" id="inactive">
                                    <label for="inactive">Inactivo</label>
                                </div>
                            </div>
                        </div><!-- Cuerpo Modal -->
                        <div class="modal-footer">
                            <button type="button" class="btn btn-primary" onclick="onClickBtnNewPurchaser()"> <i class="fa fa-plus"></i> @Resources.views.nuevo</button>
                            <button type="submit" class="btn btn-success"> <i class="fa fa-save"></i> @Resources.views.guardar</button>
                            <button type="button" class="btn btn-danger" data-dismiss="modal"> <i class="fa fa-ban"></i> @Resources.views.cerrar</button>
                        </div>
                    </form><!-- Modal content-->
                </div>
            </div><!-- Modal -->
        </div>
    </div>

    <script>
        var urls = {
            init: '@Url.Action("GetInitData", "CasasComerciales")',
            save: '@Url.Action("Save", "CasasComerciales")',
        };
        var elements = {
            div_table: "tbl", spn_table: "spn_tbl",
            spn_modal: "spn_modal", modal: "modal",
            title_modal: "title_modal", form: "form"
        };
        var Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 4000 }); // Variable para mostrar los mensajes.
        var lists = { purchasers: [] }
        var rules = {
            name: { required: true, maxlength: 50 },
            email: { required: true, maxlength: 225 },
            telephone: { required: true, maxlength: 30 },
        }; // Roles que cumplirán los componentes del formulario
        var messages = {
            name: { required: "@Resources.messages.validacion_req", maxlength: "@Resources.messages.validacion_desc_maxLen" },
            email: { required: "@Resources.messages.validacion_req", email: "Debe ingresar un correo válido.", maxlength: "@Resources.messages.validacion_desc_maxLen" },
            telephone: { required: "@Resources.messages.validacion_req", maxlength: "@Resources.messages.validacion_desc_maxLen" },
        }; // Ménsajes de error para el formulario
    </script>

    <script>
        $(function () {
            fillMenuItemsLayout();
            applyInitPlugins();
            hideInitElements();
            getInitialData();
        });

        function applyInitPlugins() {
            StartLoadTable(elements.div_table, true);
            EndLoadTable("@Name", elements.div_table, true);
            setValidationForm();
        }

        function hideInitElements() {
            $("#" + elements.spn_modal).hide();
        }

        function findPurchaser(id) {
            return lists.purchasers.find(x => x.ID === id);
        }

        function fillMenuItemsLayout() {
            openMenu(["#nav-item-compras"]);
            activeItemMenu([".nav-item-compras", "#nav-link-compras-casas"])
        }

        function fillTable() {
            try {
                StartLoadTable(elements.div_table, true);
                $("#" + elements.spn_table).show();
                console.log(lists.purchasers)
                if (lists.purchasers) {
                    $("#" + elements.div_table + " > table > tbody").html("");
                    lists.purchasers.forEach(function (d) {
                        var row = $("<tr />");
                        $("#" + elements.div_table + " > table").append(row);
                        row.append($("<td> " + d.Code + "</td>"));
                        row.append($("<td> " + d.ExtCode + "</td>"));
                        row.append($("<td> " + d.Name + "</td>"));
                        row.append($("<td> " + d.EmailAddress + "</td>"));
                        row.append($("<td> " + d.Telephone + "</td>"));
                        row.append($(`<td><span class="badge bg-${d.Inactive ? 'danger' : 'success'}">${d.Inactive ? 'INACTIVO' : 'ACTIVO'}</span></td>`));
                        row.append($("<td> " + d.LastUpdatedAux + "</td>"));
                        var title = "@Resources.views.editar Casa Comercial";
                        row.append($("<td><button class='btn btn-primary' title='" + title + "' data-toggle='modal' data-target='' onClick='onClickBtnEditPurchaser(" + d.ID + ")'> <i class='fa fa-edit' aria-hidden='true'></i></button></td>"));
                    });
                } else Toast.fire({ icon: 'warning', title: '@Resources.messages.msj_lista_vacia' });
                EndLoadTable("@ViewBag.Head", elements.div_table, true);
                $("#" + elements.spn_table).hide();
            } catch (e) { error(e, "@Resources.messages.error_llenar_registros"); }
        }

        async function getInitialData() {
            try {
                $("#" + elements.spn_table).show();
                await $.get(urls.init).done(async function (data) {
                    if (data.Status) {
                        lists.purchasers = data.Result.purchasers;
                        await fillTable();
                        $("#" + elements.spn_table).hide();
                    } else {
                        error(data.InternalMessage, data.Message);
                        $("#" + elements.spn_table).hide();
                    }
                }).fail(function (data) { error(data, "@Resources.messages.error_obt_regs"); });
            } catch (e) { error(e, "@Resources.messages.error_obt_regs"); }
        }

        function getPurchaserFromModal() {
            var data = {
                ID: $("#id").val(),
                Code: $("#code").val(),
                ExtCode: $("#extcode").val(),
                Name: $("#name").val(),
                EmailAddress: $("#email").val(),
                Telephone: $("#telephone").val(),
                Inactive: $('#inactive').is(":checked")
            }

            return data;
        }

        function setPurchaserInModal(pur) {
            try {
                $("#id").val(pur.ID)
                $("#code").val(pur.Code)
                $("#extcode").val(pur.ExtCode)
                $("#name").val(pur.Name)
                $("#email").val(pur.EmailAddress)
                $("#telephone").val(pur.Telephone)
                $('#inactive').prop("checked", pur.Inactive);
            } catch (e) {
                error(e, "@Resources.messages.error_mostrar_reg_edit");
            }
        }

        function setValidationForm() {
            $.validator.setDefaults({ submitHandler: function () { onSubmitSave(); } });

            $('#' + elements.form).validate({
                rules: rules, messages: messages, errorElement: 'span',
                errorPlacement: function (err, element) {
                    err.addClass('invalid-feedback ml-2');
                    element.closest('.form-group').append(err);
                },
                highlight: function (element, errorClass, validClass) {
                    $(element).addClass('is-invalid');
                },
                unhighlight: function (element, errorClass, validClass) {
                    $(element).removeClass('is-invalid');
                }
            });
        }

        function onClickBtnAddPurchaser() {
            if ($("#id").val() !== "") openModal(false);
            else openModal(true);
        }

        function onClickBtnEditPurchaser(id) {
            var purchaser = findPurchaser(id);
            if (purchaser) {
                setPurchaserInModal(purchaser);
                openModal(false);
            } else Toast.fire({ icon: "warning", title: "@Resources.messages.error_reg_edit_inval" });
        }

        function onClickBtnNewPurchaser() {
            Swal.fire({
                title: "@Resources.messages.msj_continuar", html: "@Resources.messages.msj_campos_limpiar", icon: 'warning', showCancelButton: true,
            }).then((result) => {
                if (result.isConfirmed) {
                    openModal(true);
                    limpiarModal();
                }
            });
        }

        async function onSubmitSave() {
            try {
                var purchaser = getPurchaserFromModal();
                $("#" + elements.spn_modal).show();
                $.post(urls.save, { 'purchaser': purchaser }, "json").done(async function (data) {
                    Toast.fire({ icon: (data.Status ? 'success' : 'error'), title: data.Message });
                    if (data.Status) {
                        await getInitialData();
                        onClickBtnEditPurchaser(data.Result);
                        $("#" + elements.spn_modal).hide();
                    }
                    $("#" + elements.spn_modal).hide();
                }).fail(function () {
                    error("ERROR GUARDAR", "@Resources.messages.error_intento_guardar");
                    $("#" + elements.spn_modal).hide();
                });
            } catch (e) { error(e, "@Resources.messages.error_intento_guardar"); }
        }

        function limpiarModal() {
            $("#" + elements.form + " input").val("");
        }

        /** Abre la modal */
        function openModal(is_new) {
            $("#" + elements.title_modal).html((is_new ? "@Resources.views.agregar" : "@Resources.views.editar") + " Casa Comercial");
            $('#' + elements.modal).modal({ backdrop: 'static', keyboard: false });
        }
    </script>
</body>
</html>
