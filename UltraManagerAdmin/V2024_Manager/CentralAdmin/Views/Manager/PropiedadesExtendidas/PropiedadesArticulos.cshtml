
@{
    Layout = "~/Views/Layout/MainLayout.cshtml";
    var culture = System.Threading.Thread.CurrentThread.CurrentCulture;
    var CurrencySymbol = culture.NumberFormat.CurrencySymbol;
    var CurrencyDecimalSeparator = culture.Name.ToUpper() == "ES-CR" ? "." : culture.NumberFormat.CurrencyDecimalSeparator;
    var CurrencyThousandSeparator = culture.Name.ToUpper() == "ES-CR" ? "," : culture.NumberFormat.NumberGroupSeparator;
    string Name = "Propiedades de Artículos";
}

<script>
    var CultureInfo = {
        culture: '@culture',
        CurrencySymbol: '@CurrencySymbol',
        CurrencyDecimalSeparator: '@CurrencyDecimalSeparator',
        CurrencyThousandSeparator: '@CurrencyThousandSeparator'
    }
</script>

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <!-- Tell the browser to be responsive to screen width -->
    <meta content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" name="viewport">
    <!-- DataTables -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-bs4/css/dataTables.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-responsive/css/responsive.bootstrap4.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/datatables-buttons/css/buttons.bootstrap4.min.css">
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/sweetalert2-theme-bootstrap-4/bootstrap-4.min.css">
    <!-- Select2 -->
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/select2/css/select2.min.css">
    <link rel="stylesheet" href="~/Content/AdminLTE/plugins/select2-bootstrap4-theme/select2-bootstrap4.min.css">

    <!-- SweetAlert2 -->
    <script src="~/Content/AdminLTE/plugins/sweetalert2/sweetalert2.min.js"></script>
    <!-- DataTables  & Plugins -->
    <script src="~/Content/AdminLTE/plugins/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-responsive/js/responsive.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/dataTables.buttons.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.bootstrap4.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/jszip/jszip.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/pdfmake/pdfmake.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/pdfmake/vfs_fonts.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.html5.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.print.min.js"></script>
    <script src="~/Content/AdminLTE/plugins/datatables-buttons/js/buttons.colVis.min.js"></script>
    <!-- Toastr -->
    <script src="~/Content/AdminLTE/plugins/toastr/toastr.min.js"></script>
    <!-- Select2 -->
    <script src="~/Content/AdminLTE/plugins/select2/js/select2.full.min.js"></script>

</head>
<body class="hold-transition sidebar-mini">
    <div class="wrapper">
        <div class="content-wrapper">
            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-6"><h1>@Name</h1></div>
                        <div class="col-sm-6">
                            <ol class="breadcrumb float-sm-right">
                                <li class="breadcrumb-item"><a href="@Url.Action("Manager", "Inicio")">@Resources.views.inicio</a></li>
                                <li class="breadcrumb-item active">@Resources.views.inventario</li>
                                <li class="breadcrumb-item active">@Name</li>
                            </ol>
                        </div>
                    </div>
                </div>
                <section class="content">
                    <div class="container-fluid">
                        <div class="row">
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-body">
                                        <div id="tbl_content_items" class="dataTables_wrapper dt-bootstrap4">
                                            <table class="table table-striped table-bordered"></table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </section>

            <div class="modal fade" id="modal_item_propertty">
                <div class="modal-dialog modal-md modal-dialog-scrollable">
                    <div class="modal-content">
                        <!-- Spinner Modal -->
                        <div id="spn_modal_item_propertis" class="overlay">
                            <div class="d-table-cell justify-content-center">
                                <i class="fas fa-2x fa-sync fa-spin d-flex justify-content-center"></i>
                                <h3 id="spn_modal_text">Cargando...</h3>
                            </div>
                        </div><!-- Spinner Modal -->
                        <!-- Encabezado Modal -->
                        <div class="modal-header text-center">
                            <h4 id="modal_title" class="modal-title">Actualizar propiedades de artículos</h4>
                            <button type="button" class="close" data-dismiss="modal">&times;</button>
                        </div><!-- Encabezado Modal -->

                        <div class="modal-body row">
                            <div class="col-12">
                                <label>Tiendas a actualizar:</label>
                                <div class="d-inline-flex w-100">
                                    <div class="form-group m-0 p-0 w-100">
                                        <select id="stores" name="stores" class="form-control select2 w-100" multiple="multiple" data-placeholder="Seleccionar tiendas a actualizar"></select>
                                    </div>
                                    <div class="d-flex align-items-center input-group-text p-0">
                                        <div class="icheck-primary d-inline px-1 ml-1">
                                            <input type="checkbox" id="chkAllStore">
                                            <label for="chkAllStore"></label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <form id="formProps" class="col-12 mt-4"><div class="row"></div></form>
                        </div>

                        <div class="modal-footer">
                            <button id="btnSave" type="button" class="btn btn-success"> <i class="fa fa-save"></i> @Resources.views.guardar</button>
                            <button type="button" class="btn btn-danger" data-dismiss="modal"> <i class="fa fa-ban"></i> @Resources.views.cerrar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        var urls = {
            GetInit: '@Url.Action("GetInitData", "PropiedadesArticulos")',
            GetAll_Items: '@Url.Action("GetAll_ItemProperties", "PropiedadesArticulos")',
            GetProperty_Item: '@Url.Action("Get_Item_Properties", "PropiedadesArticulos")',
            Save_Item_Property: '@Url.Action("Save_Item_Properties", "PropiedadesArticulos")'
        };

        var elementsIDs = {
            div_table: 'tbl_content_items',
            modal: 'modal_item_propertty',
            spinner_modal: 'spn_modal_item_propertis',
            form: 'formProps'
        }

        var elementsObj = {
            ItemID: 0,
            ItemExtID: 0,
            DataTableItems: null,
            ItemCustomProperties: [],
            ItemExtProperties: [],
            StoresAvailable: [],
            selStores: null
        }

        var Toast = Swal.mixin({ toast: true, position: 'top-end', showConfirmButton: false, timer: 4000 });
    </script>

    <script>
        $(function () {
            initMenuItemsLayout();
            initDataPlugins();
        });

        function initMenuItemsLayout() {
            openMenu(["#nav-prop-ext"]);
            activeItemMenu([".nav-prop-ext", "#nav-link-prop-ext-items"])
        }

        function initDataPlugins() {
            initSelectStore();
            getInitData();
            initDataTableItems();
            $(document).on('shown.bs.modal', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
            $('a[data-toggle="pill"]').on('shown.bs.tab', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
            $("#btnSave").on("click", onClickBtnSaveProperties);
        }

        async function initDataTableItems() {
            elementsObj.DataTableItems = $(`#${elementsIDs.div_table} > table`).DataTable({
                ajax: {
                    url: urls.GetAll_Items, type: 'POST', datatype: 'json',
                    data: function (d) {
                        var data = $.extend({}, d, { searchValue: $('#inputSearch').val() });
                        return data;
                    },
                },
                columns: [
                    { title: 'Cód. Producto', data: 'ItemLookupCode' },
                    { title: 'Descrip. Corta', data: 'Description' },
                    { title: 'Descrip. Larga', data: 'ExtDescription' },
                    {
                        title: 'Propiedades', data: 'Properties', render: function (data, type, row, meta) {
                            var props = data.split(',');
                            var rows = '';

                            for (var i = 0; i < props.length; i++) {
                                rows += `<span><strong>${props[i].split(':')[0]}:</strong> ${props[i].split(':')[1]}</span>&nbsp;`
                            }

                            return type === 'display' ? rows : data
                        }
                    },
                    {
                        orderable: false, title: '', data: 'ID', render: function (data, type, row, meta) {
                            var title = "Editar propiedades de artículo";
                            return type == 'display' ? `<button class='btn btn-primary' title='${title}' onclick='onClickBtnEditItem(${data})'> <i class='fa fa-edit' aria-hidden='true'></i></button>` : data;
                        }
                    },
                ],
                order: [[0, 'asc']],
                dom: `<'row' <'col-md-6'l><'col-md-6'f><'col-12 col-md-6'B>>
                                    <'row' <'col-12'tr>>
                                    <'row' <'col-12 col-md-6'i><'col-12 col-md-6'p>>`,
                language: dtable_i18n, paging: true, lengthChange: true,
                serverSide: true, autoWidth: false, ordering: true,
                processing: true, deferLoading: 0, responsive: true, buttons: ['colvis', 'pdf', 'excel'],
            });
            $(".dataTables_filter").html($(`<div class="input-group justify-content-end p-0 mb-2 mb-md-0">
                                                    <input id="inputSearch" type="text" name="table_search" class="form-control" placeholder="Buscar..." style="max-width:450px">
                                                    <button id="btnClearSearch" class="btn bg-transparent position-absolute mr-5" style="z-index: 100;" onclick="onClickCBtnClearSearch()"><i class="fa fa-times"></i></button>
                                                    <div class="input-group-append">
                                                        <button type="button" class="btn btn-default" onclick="onClickBtnSearch()"><i class="fas fa-search"></i></button>
                                                    </div>
                                                </div>`));
            $('#inputSearch').keyup(function (e) { if (e.keyCode == 13) onClickBtnSearch(); });
        }

        function initSelectStore() {
            elementsObj.selStores = $('#stores').select2();
            $('#chkAllStore').click(function () {
                var status = $('#chkAllStore').is(":checked");
                if (status) {
                    $('#stores').find('option').prop("selected", true);
                    $('#stores').trigger('change');
                } else $('#stores').val(null).trigger("change");
            });
            $('#stores').on('select2:select', function (e) {
                if ($('#stores').find(':selected').length === elementsObj.StoresAvailable.length) $('#chkAllStore').prop("checked", true);
                else $('#chkAllStore').prop("checked", false);
            });
            $('#stores').on('select2:unselect', function (e) {
                if ($('#stores').find(':selected').length === elementsObj.StoresAvailable.length) $('#chkAllStore').prop("checked", true);
                else $('#chkAllStore').prop("checked", false);
            });
            $('#stores').on('select2:clear', function (e) { $('#chkAllStore').prop("checked", false); });
        }

        function fillFormProperties() {
            var formgroup = `<div class="form-group col-12 row">
                                <label for="$name" class="col-sm-4 col-form-label">$name:</label>
                                <div class="col-sm-8">$input</div>
                            </div>`;
            var inputText = `<input type="$type" class="form-control" id="$name" name="$name" placeholder="$name">`;
            var inputBool = `<div class="icheck-success d-inline"><input type="checkbox" id="$name" name="$name"><label for="$name"></label></div>`;

            for (var i = 0; i < elementsObj.ItemCustomProperties.length; i++) {
                var propForm = formgroup;

                propForm = propForm.replaceAll('$input', inputText);

                propForm = propForm.replaceAll('$name', elementsObj.ItemCustomProperties[i].Name);

                $(`#${elementsIDs.form} > div`).append($(propForm));
            }
        }

        function fillSelectStores() {
            if (elementsObj.selStores) {
                elementsObj.selStores.val(null).trigger("change");
                elementsObj.selStores.html(null).trigger("change");
                elementsObj.selStores.select2("destroy");
            }

            elementsObj.selStores = $('#stores').select2({
                closeOnSelect: false,
                allowClear: true,
                data: elementsObj.StoresAvailable.map(s => { return { id: s.IDS, text: s.NameS }; })
            });
        }

        function getInitData() {
            $.get(urls.GetInit).done(function (data) {
                elementsObj.ItemCustomProperties = data.customProperties;
                elementsObj.StoresAvailable = data.stores;
                fillFormProperties();
                fillSelectStores();
            }).fail(function (data) {
                error(data, "@Resources.messages.error_obt_regs");
            });
        }

        function getItemData(id) {
            $.get(`${urls.GetProperty_Item}?itemID=${id}`).done(function (data) {
                elementsObj.ItemExtProperties = data.itemProperties;
                setItemPropertiesToForm();
                $(`#${elementsIDs.spinner_modal}`).hide()
            }).fail(function (data) {
                error(data, "@Resources.messages.error_obt_regs");
                $(`#${elementsIDs.spinner_modal}`).hide()
            });
        }

        function getPropertiesFromForm() {
            var props = [];
            for (var i = 0; i < elementsObj.ItemCustomProperties.length; i++) {
                var iExt = elementsObj.ItemExtProperties.find(x => x.PropertyName === elementsObj.ItemCustomProperties[i].Name);
                iExt.Value = $(`input[id='${iExt.PropertyName}']`).val();//$(`#${iExt.PropertyName}`).val();
            }
        }

        function setItemPropertiesToForm() {
            for (var i = 0; i < elementsObj.ItemExtProperties.length; i++) {
                if (elementsObj.ItemCustomProperties.find(x => x.Name === elementsObj.ItemExtProperties[i].PropertyName)) {
                    $(`#${elementsObj.ItemExtProperties[i].PropertyName}`).val(elementsObj.ItemExtProperties[i].Value);
                }
            }
        }

        function onClickBtnSearch(flag = true) {
            if ($('#inputSearch').val().length >= 4) elementsObj.DataTableItems.ajax.reload();
            else if (flag) Toast.fire({ icon: 'warning', title: 'Debe ingresar por lo menos 5 caracteres para aplicar la búsqueda' });
        }

        function onClickCBtnClearSearch() {
            $('#inputSearch').val('');
        }

        function onClickBtnEditItem(itemID) {
            $(`#${elementsIDs.spinner_modal}`).show()
            clearForm();
            fillFormProperties();
            openModal();
            getItemData(itemID);
            elementsObj.ItemID = itemID;
        }

        function onClickBtnSaveProperties() {
            if (elementsObj.ItemCustomProperties.length > 0) {
                if (elementsObj.selStores.val().toString() !== '') {
                    Swal.fire({
                        title: "@Resources.messages.msj_continuar", html: "Las propiedades serán aplicadas al producto seleccionado.", icon: 'warning', showCancelButton: true,
                    }).then((result) => {
                        if (result.isConfirmed) saveProperties();
                    });
                } else error("NO TIENDAS SELECCIONADAS", "No se han seleccionado a qué tiendas aplicar los cambios.");
            } else error("NO PROPERTIES AVAILABLE", "No hay propiedades qué aplicar");
        }

        function saveProperties() {
            $(`#${elementsIDs.spinner_modal}`).show()
            getPropertiesFromForm();
            $.post(urls.Save_Item_Property, { properties: elementsObj.ItemExtProperties, stores: elementsObj.selStores.val().toString(), itemID: elementsObj.ItemID }).done(function (data) {
                if (data.Status) {
                    Toast.fire({ icon: 'success', title: data.Message });
                    elementsObj.DataTableItems.ajax.reload();
                    onClickBtnEditItem(elementsObj.ItemID);
                } else error(data.Message, data.Message + " | " + data.InternalMessage);

                $(`#${elementsIDs.spinner_modal}`).hide()
            }).fail(function (xhr, ajaxOptions, thrownError) {
                $(`#${elementsIDs.spinner_modal}`).hide()
                error(thrownError, "@Resources.messages.error_intento_guardar");
            });
        }

        function clearForm() {
            $(`#${elementsIDs.form} > div`).html(null);
        }

        function openModal() {
            $(`#${elementsIDs.modal}`).modal({ backdrop: 'static', keyboard: false });
        }
    </script>
</body>
</html>
