                                                            <div class="card-header pb-1">
                                                                <h3 class="card-title">Segmentación Adicional</h3>
                                                            </div>
                                                            <div class="card-body">
                                                                <div class="row">
                                                                    <div class="form-group col-12">
                                                                        <label for="manufacturer" class="text-truncate">Fabricante:</label>
                                                                        <select class="form-control select2" id="manufacturer" name="manufacturer" data-placeholder="Seleccionar fabricante" style="width: 100%;"></select>
                                                                    </div>
                                                                    <div class="form-group col-12">
                                                                        <label for="brand" class="text-truncate">Marca:</label>
                                                                        <select class="form-control select2" id="brand" name="brand" data-placeholder="Seleccionar marca" style="width: 100%;"></select>
                                                                    </div>
                                                                    <div class="form-group col-12">
                                                                        <label for="purchaser" class="text-truncate">Casa comercial:</label>
                                                                        <select class="form-control select2" id="purchaser" name="purchaser" data-placeholder="Seleccionar Casa Comercial" style="width: 100%;"></select>
                                                                    </div>
                                                                    <div class="form-group col-12">
                                                                        <label for="supplier" class="text-truncate">Proveedor:</label>
                                                                        <select class="form-control select2 W-100" id="supplier" name="supplier" data-placeholder="Seleccionar Proveedor" style="width: 100%;"></select>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-lg-6">
                                                        <div class="card card-teal">
