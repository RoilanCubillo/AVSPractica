        function onKeyUpToGetFinalPriceCost() {
            if ((+$("#cost").val().replaceAll("@CurrencyThousandSeparator", "")) <= 0) { $("#cost").val(null); }
            if ((+$("#msrp").val().replaceAll("@CurrencyThousandSeparator", "")) <= 0) { $("#msrp").val(0); }

            var iva = list_dtItems.taxes.find(x => x.ID === +$("#select2_iva").val());
            var cost = (+$("#cost").val().replaceAll("@CurrencyThousandSeparator", ""));
            var utility = +$("#utility").val();
            var customer_discount = +$("#customer-discount").val();
            var invoice_discount = +$("#invoice-discount").val();
            var msrp = +$("#msrp").val().replaceAll("@CurrencyThousandSeparator", "");
            var final_cost = (cost - (cost * (invoice_discount / 100)) + msrp);
            var final_price = (cost - (cost * (customer_discount / 100)) + msrp) * (1 + (utility / 100));
            var final_price_sin_utilidad = (cost - (cost * (customer_discount / 100)) + msrp);
            var final_price_iva = iva ? (final_price * (1 + (iva.Percentage / 100))) : 0;

            var real_price = Math.round(final_price_iva / 5) * 5;
            var real_utility = iva ? (((real_price - (final_price * (iva.Percentage / 100))) / final_price_sin_utilidad) - 1) * 100 : 0;

            $("#final-cost").val(final_cost);
            $("#final-price").val(final_price);
            $("#final-price-iva").val(final_price_iva);

            $("#real-utility").val(real_utility);
            $("#real-price").val(real_price);
        }

        function AskSelectStores(stores) {
            return Swal.fire({
                title: 'Seleccionar Tiendas a Actualizar',
                input: 'select',
                inputOptions: stores,
                inputPlaceholder: 'Seleccionar tienda/s..',
                showCancelButton: true,
                allowOutsideClick: false,
                inputAttributes: { 'multiple': 'multiple', },
                inputValidator: (value) => {
                    return new Promise((resolve) => {
