                                                                    <input type="text" class="form-control" id="subdescription9" name="subdescription9" />
                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="subdescription10" class="text-truncate">Subdescripción 10</label>
                                                                    <input type="text" class="form-control" id="subdescription10" name="subdescription10" />
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="card card-teal">
                                                            <div class="card-header pb-1">
                                                                <h3 class="card-title">Costos/Precios</h3>
                                                            </div>
                                                            <div class="card-body">
                                                                <div class="row">
                                                                    <div class="col-12">
                                                                        <label>Tiendas a actualizar:</label>
                                                                        <div class="d-inline-flex w-100">
                                                                            <div class="form-group m-0 p-0 w-100">
                                                                                <select id="stores" name="stores" class="form-control select2 w-100" multiple="multiple" data-placeholder="Seleccionar tiendas a actualizar"></select>
                                                                            </div>
                                                                            <div class="d-flex align-items-center input-group-text p-0">
                                                                                <div class="icheck-primary d-inline px-1 ml-1">
                                                                                    <input type="checkbox" id="chkAllStore">
                                                                                    <label for="chkAllStore"></label>
                                                                                </div>
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <div class="col-12">
                                                                        <div class="form-group">
                                                                            <label class="control-label">@Resources.views.IVA:</label>
                                                                            <select id="select2_iva" name="select2_iva" class="form-control select2" data-placeholder="@Resources.views.buscar" style="width: 100%;"></select>
                                                                            <input type="hidden" id="porcentaje" />
                                                                        </div>
                                                                    </div>

                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label for="cost" class="col-12 text-truncate">Costo:</label>
                                                                            <div class="input-group">
                                                                                <div class="input-group-prepend"><span class="input-group-text"><i class="fas">@CurrencySymbol</i></span></div>
                                                                                <input id="cost" type="text" name="cost" class="form-control" data-inputmask="'alias' : 'currency', 'groupSeparator':'@CurrencyThousandSeparator', 'radixPoint':'@CurrencyDecimalSeparator'" data-mask />
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group">
                                                                            <label for="msrp" class="col-12 text-truncate">Impuesto específico:</label>
                                                                            <div class="input-group">
                                                                                <div class="input-group-prepend"><span class="input-group-text"><i class="fas">@CurrencySymbol</i></span></div>
                                                                                <input id="msrp" type="text" name="msrp" class="form-control" data-inputmask="'alias' : 'currency', 'groupSeparator':'@CurrencyThousandSeparator', 'radixPoint':'@CurrencyDecimalSeparator'" data-mask />
                                                                            </div>
                                                                        </div>
                                                                    </div>

                                                                    <div class="col-md-6">
                                                                        <div class="form-group">
                                                                            <label for="invoice-discount" class="col-12 text-truncate">Descuento en factura:</label>
                                                                            <div class="input-group">
                                                                                <input id="invoice-discount" type="text" name="invoice-discount" class="form-control" data-inputmask="'alias': 'decimal', 'digits':'2'" placeholder="0~99" data-mask />
                                                                                <div class="input-group-append"><span class="input-group-text"><i class="fas">%</i></span></div>
                                                                            </div>
                                                                        </div>
                                                                        <div class="form-group">
                                                                            <label for="customer-discount" class="col-12 text-truncate">Descuento para cliente:</label>
                                                                            <div class="input-group">
                                                                                <input id="customer-discount" type="text" name="customer-discount" class="form-control" data-inputmask="'alias': 'decimal', 'digits':'2'" placeholder="0~99" data-mask />
                                                                                <div class="input-group-append"><span class="input-group-text"><i class="fas">%</i></span></div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-12">
                                                                        <div class="form-group row">
