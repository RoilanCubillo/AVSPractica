                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="description" class="text-truncate">Descripción Corta:</label>
                                                                    <input class="form-control" id="description" placeholder="Descripción corta..." name="description" />
                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="extdescription" class="text-truncate" title="Descripción extra">Descripción Larga:</label>
                                                                    <textarea class="form-control" id="extdescription" placeholder="Descripción larga..." name="extdescription" s="2"></textarea>
                                                                </div>
                                                            </div>
                                                        </div>
                                                        <div class="card card-teal">
                                                            <div class="card-header pb-1">
                                                                <h3 class="card-title">Segmentación del producto</h3>
                                                            </div>
                                                            <div class="card-body">
                                                                <div class="form-group">
                                                                    <label for="family" class="text-truncate">@Resources.views.familia:</label>
                                                                    <select class="form-control select2" id="family" name="family" data-placeholder="Seleccionar familia" style="width: 100%;"></select>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="department" class="text-truncate">@Resources.views.depart (Categoría):</label>
                                                                    <select class="form-control select2" id="department" name="department" data-placeholder="Seleccionar departamento" style="width: 100%;"></select>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="category" class="text-truncate">@Resources.views.categ (Subcategoría):</label>
                                                                    <select class="form-control select2" id="category" name="category" data-placeholder="Seleccionar categoría" style="width: 100%;"></select>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="subcategory" class="text-truncate">@Resources.views.subCategoria (Segmento):</label>
                                                                    <select class="form-control select2" id="subcategory" name="subcategory" data-placeholder="Seleccionar subcategoría" style="width: 100%;"></select>
                                                                </div>
                                                                <div class="form-group">
                                                                    <label for="segment" class="text-truncate">@Resources.views.segmento (Subsegmento):</label>
                                                                    <select class="form-control select2" id="segment" name="segment" data-placeholder="Seleccionar segmento" style="width: 100%;"></select>
                                                                </div>
                                                            </div>
                                                        </div>
