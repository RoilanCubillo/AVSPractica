    <script>
        /** Función initialize */
        $(async function () {
            fillMenuItemsLayout();
            initStutasElements();
            initDataPlugins();
            setOnChanges();
            getInitialData();
            setAllValidationsForm();
        });

        function initStutasElements() {
            $("#div_select_categories").hide();
            $("#div_select_subCategories").hide();
            $("#div_select_segments").hide();
            $("#" + elements.spn_table).hide();
            $("#" + elements.spn_modal).hide();
            $("#" + elements.spn_filter).hide();
            $("#category").prop('disabled', true);
            $("#subcategory").prop('disabled', true);
            $("#segment").prop('disabled', true);
            $("#department").prop('disabled', true);
        }

        function initDataPlugins() {
            $('[data-mask]').inputmask();
            $(".select2").select2();
            $('.datetimepicker-input').datetimepicker({ format: 'DD/MM/YYYY', });
            initDataTable();
            initDataTableDetail();
            initDataTableDetailSupplier();
            initDataTableDetailSupplierPrice();
            $(document).on('shown.bs.modal', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
            $('a[data-toggle="pill"]').on('shown.bs.tab', function (e) {
                $.fn.dataTable.tables({ visible: true, api: true }).columns.adjust();
            });
            elements.select_stores = $('#stores').select2();
            $('#chkAllStore').click(function () {
                var status = $('#chkAllStore').is(":checked");
                if (status) {
                    $('#stores').find('option').prop("selected", true);
                    $('#stores').trigger('change');
                } else $('#stores').val(null).trigger("change");
            });
            $('#stores').on('select2:select', function (e) {
                if ($('#stores').find(':selected').length === list_dtItems.stores.length) $('#chkAllStore').prop("checked", true);
                else $('#chkAllStore').prop("checked", false);
            });
            $('#stores').on('select2:unselect', function (e) {
                if ($('#stores').find(':selected').length === list_dtItems.stores.length) $('#chkAllStore').prop("checked", true);
                else $('#chkAllStore').prop("checked", false);
            });
            $('#stores').on('select2:clear', function (e) { $('#chkAllStore').prop("checked", false); });
        }

        function initDataTableDetail() {
            dtd = $("#" + elements.tbl_detail + " > table").DataTable({
                dom: "<'row' <'mb-1 col-12'B><'col-lg-6'l><'col-lg-6'f>>" +
                    "<'row' <'col-12't>>" +
                    "<'row' <'col-md-6'i><'col-md-6'p>>",
                language: dtable_i18n, paging: true, lengthChange: true, searching: true,
                serverSide: false, autoWidth: false, ordering: true, destroy: true,
                processing: true, responsive: true, buttons: ['excel', 'colvis']
            });
        }

        function initDataTableDetailSupplier() {
            sdtd = $("#" + elements.tbl_supplier + " > table").DataTable({
                dom: "<'row' <'mb-1 col-12'B><'col-lg-6'l><'col-lg-6'f>>" +
                    "<'row' <'col-12't>>" +
                    "<'row' <'col-md-6'i><'col-md-6'p>>",
                language: dtable_i18n, paging: true, lengthChange: true, searching: true,
                serverSide: false, autoWidth: false, ordering: true, destroy: true,
                processing: true, responsive: true, buttons: ['excel', 'colvis']
            });
        }

        function initDataTableDetailSupplierPrice() {
            pdtd = $("#" + elements.tbl_supplierPrice + " > table").DataTable({
                dom: "<'row' <'mb-1 col-12'B><'col-lg-6'l><'col-lg-6'f>>" +
                    "<'row' <'col-12't>>" +
                    "<'row' <'col-md-6'i><'col-md-6'p>>",
                language: dtable_i18n, paging: true, lengthChange: true, searching: true,
                serverSide: false, autoWidth: false, ordering: true, destroy: true,
                processing: true, responsive: true, buttons: ['excel', 'colvis']
            });
        }

        async function initDataTable() {
            dt = $("#" + elements.div_table + " > table").DataTable({
                ajax: {
                    url: urls.url_getAllItemsDynamic, type: 'POST', datatype: 'json',
                    data: function (d) {
                        var data = $.extend({}, d, {
                            "filtered": $('#inputSearch').val(),
                            families: [], //$("#select_families").select2('data').map(d => { return d.id }),
                            departments: [], //$("#select_deparments").select2('data').map(d => { return d.id }),
                            categories: [], //$("#select_categories").select2('data').map(d => { return d.id }),
                            subCategories: [], //$("#select_subCategories").select2('data').map(d => { return d.id }),
                            segments: [], //$("#select_segments").select2('data').map(d => { return d.id }),
                        });
                        return data;
                    },
                },
                columns: [
                    { title: 'Código', data: 'ItemLookupCode' },
                    { title: 'Descripción', data: 'Description' },
                    { title: 'Descripción extendida', visible: false, data: 'ExtendedDescription' },
                    { title: 'Tipo de artículo', data: 'ItemType', render: function (data, type, row, meta) { return type == 'display' ? item_type[data] : data; } },
                    { title: 'Cantidad', data: 'Quantity' },
                    { title: 'Precio', data: 'Price' },
                    { title: 'Precio A', data: 'PriceA' }, { title: 'Precio B', data: 'PriceB' }, { title: 'Precio C', data: 'PriceC' },
                    { title: 'Cod. Familia', visible: false, data: 'FamilyCode' }, { title: 'Familia', data: 'FamilyName' },
                    { title: 'Cod. Departamento', visible: false, data: 'DepartmentCode' }, { title: 'Departamento', data: 'DepartmentName' },
                    { title: 'Cod. Categoría', visible: false, data: 'CategoryCode' }, { title: 'Categoría', data: 'CategoryName' },
                    { title: 'Cod. Subcategoría', visible: false, data: 'SubCategoryCode' }, { title: 'Subcategoría', data: 'SubCategoryName' },
                    { title: 'Cod. Segmento', visible: false, data: 'SegmentCode' }, { title: 'Segmento', data: 'SegmentName' },
                    { title: 'Cod. Fabricante', visible: false, data: 'ManufacturerID' }, { title: 'Fabricante', data: 'ManufacturerDescription' },
                    { title: 'Cod. Marca', visible: false, data: 'BrandID' }, { title: 'Marca', data: 'BrandDescription' },
                    { title: 'Cod. Casa Comercial', visible: false, data: 'PurchaserCode' }, { title: 'Casa Comercial', data: 'PurchaserName' },
                    { title: 'Última actualización', data: 'LastUpdatedAux' },
                    {
                        orderable: false, data: 'ID', render: function (data, type, row, meta) {
                            var title = "@Resources.views.editar @Resources.views.articulo";
                            return type == 'display' ? "<td><button class='btn btn-primary' title='" + title + "' data-toggle='modal' data-target='' onClick='onClickBtnEditItem(" + data + ")'> <i class='fa fa-edit' aria-hidden='true'></i></button></td>" : data;
                        }
                    }
                ],
                dom: `<'row' <'col-md-6'l><'col-md-6'f><'col-12 col-md-6'B>>
                    <'row' <'col-12'tr>>
                    <'row' <'col-12 col-md-6'i><'col-12 col-md-6'p>>`,
                language: dtable_i18n, paging: true, lengthChange: true,
                serverSide: true, autoWidth: false, ordering: true,
                processing: true, deferLoading: 0, responsive: true, buttons: ['colvis', 'pdf', 'excel'],
            });
            $(".dataTables_filter").html($(`<div class="input-group justify-content-end p-0 mb-2 mb-md-0">
                                        <input id="inputSearch" type="text" name="table_search" class="form-control" placeholder="Buscar..." style="max-width:450px">
                                        <button id="btnClearSearch" class="btn bg-transparent position-absolute mr-5" style="z-index: 100;" onclick="onClickCBtnClearSearch()"><i class="fa fa-times"></i></button>
                                        <div class="input-group-append">
                                            <button type="button" class="btn btn-default" onclick="onClickBtnSearch()"><i class="fas fa-search"></i></button>
                                        </div>
                                    </div>`));
            $('#inputSearch').keyup(function (e) { if (e.keyCode == 13) onClickBtnSearch(); });
        }

        async function fillTableDetails() {
            try {
                dtd.destroy();
                $("#" + elements.tbl_detail + " table > tbody").html(null);
                if (list_details.length > 0) {
                    await list_details.forEach(function (i) {
                        var row = $("<tr />");
                        $("#" + elements.tbl_detail + " > table").append(row);
                        row.append($("<td> " + i.StoreName + "</td>"));
                        row.append($("<td> " + i.Quantity + "</td>"));
                        row.append($("<td> " + i.Cost + "</td>"));
                        row.append($("<td> " + i.GrossCost + "</td>"));
                        row.append($("<td> " + i.Utility + "</td>"));
                        row.append($("<td> " + i.InvoiceDiscount + "</td>"));
                        row.append($("<td> " + i.CustomerDiscount + "</td>"));
                        row.append($("<td> " + i.SupplierName + "</td>"));
                        row.append($("<td> " + i.LastReceivedAux + "</td>"));

                    });
                }
                initDataTableDetail();
            } catch (e) { error(e, "@Resources.messages.error_llenar_registros"); }
        }

        async function fillTableDetailSuppliers() {
            try {
                sdtd.destroy();
                $("#" + elements.tbl_supplier + " table > tbody").html(null);
                if (list_dtItems.suppliers.length > 0) {
                    await list_dtItems.suppliers.forEach(function (i) {
                        var row = $("<tr />");
                        $("#" + elements.tbl_supplier + " > table").append(row);
                        row.append($(`<td>${i.IsPrimary ? '<span class="badge bg-success">PRIMARIO</span>' : ''}</td>`));
                        row.append($("<td> " + i.SupplierCode + "</td>"));
                        row.append($("<td> " + i.SupplierName + "</td>"));
                        row.append($("<td> " + i.ReorderNumber + "</td>"));
                        row.append($("<td> " + i.Cost + "</td>"));
                        row.append($("<td> " + i.TaxRate + "</td>"));
                    });
                }
                initDataTableDetailSupplier();
            } catch (e) { error(e, "@Resources.messages.error_llenar_registros"); }
        }

        async function fillTableDetailSuppliersPrices() {
            try {
                pdtd.destroy();
                $("#" + elements.tbl_supplierPrice + " table > tbody").html(null);
