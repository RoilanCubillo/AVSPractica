                    await list_dtItems.supplierPrices.forEach(function (i) {
                        var row = $("<tr />");
                        $("#" + elements.tbl_supplierPrice + " > table").append(row);
                        row.append($("<td> " + i.SupplierCode + "</td>"));
                        row.append($("<td> " + i.SupplierName + "</td>"));
                        row.append($("<td> " + i.MinQuantity + "</td>"));
                        row.append($("<td> " + i.StartingDateAux + "</td>"));
                        row.append($("<td> " + i.EndingDateAux + "</td>"));
                        row.append($("<td> " + i.UnitCost + "</td>"));
