                                                                                <input id="utility" type="text" name="utility" class="form-control" data-inputmask="'alias': 'decimal', 'digits':'2'" placeholder="0~100" data-mask />
                                                                                <div class="input-group-append"><span class="input-group-text"><i class="fas">%</i></span></div>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-12">
                                                                        <div class="form-group row">
                                                                            <label for="real-utility" class="col-sm-5 col-form-label text-truncate">Utilidad Real:</label>
                                                                            <div class="input-group col-sm-7">
                                                                                <input id="real-utility" type="text" disabled name="real_utility" class="form-control" data-inputmask="'alias': 'decimal', 'digits':'8'" data-mask placeholder="0" />
