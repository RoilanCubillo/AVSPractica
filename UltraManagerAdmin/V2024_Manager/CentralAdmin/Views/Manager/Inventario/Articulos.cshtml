                                                                <div class="row">
                                                                    <div class="col-12">
                                                                        <div class="form-group">
                                                                            <label for="cabys" class="text-truncate" title="Cabys">Cabys:</label>
                                                                            <div class="d-inline-flex w-100">
                                                                                <input type="text" class="form-control w-100" id="cabys" name="cabys" placeholder="Código cabys" />
                                                                                <a href="https://api.hacienda.go.cr/fe/cabys/test" class="btn btn-primary ml-1" title="Buscar código cabys" target="_blank"> <i class="fa fa-search"></i></a>
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-12">
                                                                        <div class="form-group">
                                                                            <label for="subdescription4" class="text-truncate">Contenido</label>
                                                                            <input type="text" class="form-control" id="subdescription4" name="subdescription4" />
                                                                        </div>
                                                                    </div>
                                                                    <div class="col-12">
