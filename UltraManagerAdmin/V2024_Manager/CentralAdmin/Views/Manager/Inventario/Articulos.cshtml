        function fillSelectStores() {
            if (elements.select_stores) {
                elements.select_stores.val(null).trigger("change");
                elements.select_stores.html(null).trigger("change");
                elements.select_stores.select2("destroy");
            }
            elements.select_stores = $('#stores').select2({
                closeOnSelect: false,
                allowClear: true,
                data: list_dtItems.stores.map(s => { return { id: s.IDS, text: s.NameS }; })
            });

            elements.select_stores.val(gItem.StoresSelected.split(',')).trigger("change");

            if ($('#stores').find(':selected').length === list_dtItems.stores.length) $('#chkAllStore').prop("checked", true);
            else $('#chkAllStore').prop("checked", false);
