        function clearObjectWorksheet() {
            elementsObj.worksheet = null;
            elementsObj.worksheetStores = [];
            elementsObj.worksheetHistory = [];
            elementsObj.worksheetContents = [];
        }

        function clearModal() {
            $(`#${elementsIDs.modal} input`).val("");
            $("#tbl_content_sync_docsmh > tbody").html(null);
        }


        function onClickDocsAceptados() {
            IsmodalActiveDocsAceptados = true;
            openModal(true);
            clearModalDocsMH();
        }

        function onClickDocsRechazados() {
            IsmodalActiveDocsAceptados = false;
            openModal(false);
            clearModalDocsMH();
        }

        function onClickDocsERP(val) {

            for (var prop in modalActiveDocsERP) {
                if (modalActiveDocsERP.hasOwnProperty(prop)) {
                    if (prop = val) {
                        modalActiveDocsERP[prop] = true;
                    }
                    else{
                        modalActiveDocsERP[prop] = false;
                    }
                }
            }
            clearModalDocsERP();
            openModalDocsERP(val);
        }

        function onClickCBtnClearSearch() {
            $('#inputSearch').val('');
        }

        function clearModalDocsMH() {
            $(`#${elementsIDs.modal} input`).val("");
            $("#tbl_content_sync_docsmh > tbody").html(null);
            $('#DataTables_Table_0 >tbody').empty();
        }

        function clearModalDocsERP() {
            $(`#${elementsIDs.modal_docsErp} input`).val("");
            $("#tbl_content_sync_docserp > tbody").html(null);
            $('#DataTables_Table_1>tbody').empty();
            $('#DataTables_Table_1_wrapper>tbody').empty();

        }


        /** Abre la modal docs MH */
        function openModal(is_new) {
            $("#" + elementsIDs.title_modal).html((is_new ? "Documentos Aceptados" : "Documentos Rechazados") + " Ministerio de Hacienda");
            $('#' + elementsIDs.modal).modal({ backdrop: 'static', keyboard: false });
        }

        /** Abre la modal docs ERP */
        function openModalDocsERP(val) {
            if (val == 'ventas') {
                $("#" + elementsIDs.title_modalDocsERP).html(("Sincronización Documentos Ventas") + " - ERP");
            }else if(val == 'ncventas') {
                $("#" + elementsIDs.title_modalDocsERP).html(("Sincronización Documentos NC Ventas") + " - ERP");
            }else if(val == 'compras') {
                $("#" + elementsIDs.title_modalDocsERP).html(("Sincronización Documentos Compras") + " - ERP");
            } else if (val == 'nccompras') {
                $("#" + elementsIDs.title_modalDocsERP).html(("Sincronización Documentos NC Compras") + " - ERP");
            } else if (val == 'depositos') {
                $("#" + elementsIDs.title_modalDocsERP).html(("Sincronización Documentos Depósitos") + " - ERP");
            }

            $('#' + elementsIDs.modal_docsErp).modal({ backdrop: 'static', keyboard: false });
        }

        /** Indica cual tipo de documento se va a mostrar en la ventana modal */
        function getTipoComprobante(modalActiveDocsERP) {
            var tipoComprobante = "";
            for (var key in modalActiveDocsERP) {
                if (modalActiveDocsERP.hasOwnProperty(key) && modalActiveDocsERP[key]) {
                    tipoComprobante = key;
                }
            }
            return tipoComprobante;
        }

        /** Clona la lista de categorias a otra lista data con elementos de {id, text} para el select2bs4*/
        function storeToData() {
            return list_Store.map(d => { return { 'id': d.IDS, 'text': d.NameS } });
        }

        async function getAllStores() {
                try {
                   /* $("#" + elements.spn_modal).show();*/
                    await $.get(urls.GetAll_Store).done(async function (data) {
                        list_Store = data.store;
                        fillSelectStores();
                        fillSelectStore();
                    });
                } catch (e) { error(e, "@Resources.messages.error_obt_regs"); }
        }


        /** Clona la lista de departamentos a otra lista data con elementos de {id, text} para el select2bs4*/
        function storesToData() {
            return list_Store.map(d => { return { 'id': d.ID, 'text': d.Description } });
        }

        /**
         * Se encarga de cargar el componente select con el plugin select2bs4
         */
        function fillSelectStores() {
            select_store= $('.select2bs4').select2({
                placeholder: '@Resources.views.selec_depart', data: storesToData(), language: "@ViewBag.Lang", theme: 'bootstrap4'
            });

            select_storeDocsERP= $('.select2bs4').select2({
                placeholder: '@Resources.views.selec_depart', data: storesToData(), language: "@ViewBag.Lang", theme: 'bootstrap4'
            });

            select_storeAsientosERP= $('.select2bs4').select2({
                placeholder: '@Resources.views.selec_depart', data: storesToData(), language: "@ViewBag.Lang", theme: 'bootstrap4'
            });
        }

        function fillSelectStore() {
            $("#select_store").select2("destroy");
            select_store = $("#select_store").select2({
                data: storesToData(), theme: 'bootstrap4'
            });

            $("#select_storeDocsERP").select2("destroy");
            select_storeDocsERP = $("#select_storeDocsERP").select2({
                data: storesToData(), theme: 'bootstrap4'
            });

            $("#select_storeAsientosERP").select2("destroy");
            select_storeAsientosERP = $("#select_storeAsientosERP").select2({
                data: storesToData(), theme: 'bootstrap4'
            });
        }

    </script>

    @*CHART*@

    <script>

        //-------------
        //- BAR CHART - Documentos Enviados Ministerio de Hacienda
        //-------------
        function chartDocsMH_getInfo() {
        //var x = document.getElementById("reportrange").value;
            var fechaInicio = $('#dtpDocsMH').data('daterangepicker').startDate._d;
            var fechaFin = $('#dtpDocsMH').data('daterangepicker').endDate._d;
            var id = $("#select_store").val();

            $.get(urls.GetAll_BarChart + "?fromDate=" + fechaInicio + "&toDate=" + fechaFin + "&idStore=" + (id !== null ? id : '0')).done(async function (data) {
                    if (data.Status) {
                        var arrayMeses = [];
                        var arrayDocAceptados = [];
                        var arrayDocRechazados = [];

                        document.getElementById("Docs_aceptados").innerHTML = data.Result.graphics[0].Tot_Doc_Aceptados;
                        document.getElementById("Docs_rechazados").innerHTML = data.Result.graphics[0].Tot_Doc_Rechazados;

                        for (var i = 0; i < data.Result.graphics.length; i++) {

                            arrayMeses.push(data.Result.graphics[i].Meses)
                            arrayDocAceptados.push(data.Result.graphics[i].Doc_Aceptados)
                            arrayDocRechazados.push(data.Result.graphics[i].Doc_Rechazados)
                        }

                        var controlBar1 = document.getElementById("barChartMH");
                        var barChartOptions = {
                            responsive: true,
                            maintainAspectRatio: false,
                            datasetFill: false
                        }

                        var graficoBar1 = null;

                        /*Limpiar grafico*/
                        if (controlBar1 != null) {
                            var BarChartContent = document.getElementById('chartContainer');
                                BarChartContent.innerHTML = '&nbsp;';
                                $('#chartContainer').append('<canvas id="barChartMH" style="min-height: 250px; height: 250px; max-height: 250px; max-width: 100%; display: block; width: 337px; margin-top: 17px;" width="337" height="250" class="chartjs-render-monitor"></canvas>');
                                controlBar1 = $("#barChartMH").get(0).getContext("2d");
                        }

                         graficoBar1 = new Chart(controlBar1, {
                            type: 'bar',
                            data: {
                                labels: arrayMeses,
                                datasets: [{
                                    label: 'Docs. Aceptados',
                                    backgroundColor: '#28a745',//Green
                                    borderColor: 'rgba(60,141,188,0.8)',
                                    pointRadius: false,
                                    pointColor: '#3b8bba',
                                    pointStrokeColor: 'rgba(60,141,188,1)',
                                    pointHighlightFill: '#fff',
                                    pointHighlightStroke: 'rgba(60,141,188,1)',
                                    data: arrayDocAceptados,
                                },
                                {
                                    label: 'Docs. Rechazados',
                                    backgroundColor: '#dc3535',//Red
                                    borderColor: 'rgba(210, 214, 222, 1)',
                                    pointRadius: false,
                                    pointColor: 'rgba(210, 214, 222, 1)',
                                    pointStrokeColor: '#c1c7d1',
                                    pointHighlightFill: '#fff',
                                    pointHighlightStroke: 'rgba(220,220,220,1)',
                                    data: arrayDocRechazados
                                },
                                ],
                            },
                            options: barChartOptions
                        });

                    } else {
                        error(data.InternalMessage, data.Message);
                        //$("#" + elements.spn_table).hide();
                    }
                }).fail(function (data) {
                    error(data, "@Resources.messages.error_obt_regs");
                    //$("#" + elements.spn_table).hide();
                    //$("#spn_modal_text").html("");
                });

        }

       
        //-------------
        //- PIE CHART - Sincronización Documentos ERP
        //-------------
        function chartDocsERP_getInfo() {

            var fechaInicio = $('#dtpDocsERP').data('daterangepicker').startDate._d;
            var fechaFin = $('#dtpDocsERP').data('daterangepicker').endDate._d;
            var id = $("#select_storeDocsERP").val();

            $.get(urls.GetAll_PieChart + "?fromDate=" + fechaInicio + "&toDate=" + fechaFin + "&idStore=" + (id !== null ? id : '0')).done(async function (data) {
                    if (data.Status) {
                        var arrayDocumentos = [];

                        /*Total Documentos*/
                        document.getElementById("spVentas").innerHTML = "<b>" + data.Result.graphics[0].Total_Ventas_Sync + "</b>/" + data.Result.graphics[0].Total_Ventas;
                        document.getElementById("spNcVentas").innerHTML = "<b>" + data.Result.graphics[0].Total_NcVentas_Sync + "</b>/" + data.Result.graphics[0].Total_NcVentas;
                        document.getElementById("spCompras").innerHTML = "<b>" + data.Result.graphics[0].Total_Compras_Sync + "</b>/" + data.Result.graphics[0].Total_Compras;
                        document.getElementById("spNcCompras").innerHTML = "<b>" + data.Result.graphics[0].Total_NcCompras_Sync + "</b>/" + data.Result.graphics[0].Total_NcCompras;
                        document.getElementById("spDepositosB").innerHTML = "<b>" + data.Result.graphics[0].Total_Depositos_Sync + "</b>/" + data.Result.graphics[0].Total_Depositos;

                        /*Total Documentos Menu Inferior*/
                        document.getElementById("ventasErp").innerHTML = data.Result.graphics[0].Total_Ventas_Sync;
                        document.getElementById("ncVentasErp").innerHTML = data.Result.graphics[0].Total_NcVentas_Sync;
                        document.getElementById("comprasErp").innerHTML = data.Result.graphics[0].Total_Compras_Sync;
                        document.getElementById("nccomprasErp").innerHTML = data.Result.graphics[0].Total_NcCompras_Sync;
                        document.getElementById("depositosErp").innerHTML = data.Result.graphics[0].Total_Depositos_Sync;

                        /*Grafico Documentos*/
                        arrayDocumentos.push(data.Result.graphics[0].Total_Ventas_Sync)
                        arrayDocumentos.push(data.Result.graphics[0].Total_NcVentas_Sync)
                        arrayDocumentos.push(data.Result.graphics[0].Total_Compras_Sync)
                        arrayDocumentos.push(data.Result.graphics[0].Total_NcCompras_Sync)
                        arrayDocumentos.push(data.Result.graphics[0].Total_Depositos_Sync)
                        arrayDocumentos.push(data.Result.graphics[0].Total_Docs_NoSync)

                        /*ProgressBar Documentos*/
                        progressBar.progressVentas = (data.Result.graphics[0].Total_Ventas_Sync / data.Result.graphics[0].Total_Ventas) * 100;
                        document.getElementById("progressbarVentas").style.width = progressBar.progressVentas + "%";
                        progressBar.progressNcVentas = (data.Result.graphics[0].Total_NcVentas_Sync / data.Result.graphics[0].Total_NcVentas) * 100;
                        document.getElementById("progressbarNcVentas").style.width = progressBar.progressNcVentas + "%";
                        progressBar.progressCompras = (data.Result.graphics[0].Total_Compras_Sync / data.Result.graphics[0].Total_Compras) * 100;
                        document.getElementById("progressbarCompras").style.width = progressBar.progressCompras + "%";
                        progressBar.progressNcCompras = (data.Result.graphics[0].Total_NcCompras_Sync / data.Result.graphics[0].Total_NcCompras) * 100;
                        document.getElementById("progressbarNcCompras").style.width = progressBar.progressNcCompras + "%";
                        progressBar.progressDepositos = (data.Result.graphics[0].Total_Depositos_Sync / data.Result.graphics[0].Total_Depositos) * 100;
                        document.getElementById("progressbarDepositos").style.width = progressBar.progressDepositos + "%";

                        var controlPie = document.getElementById("barChartDocsERP");
                        var graficoPie = null;

                        /*Limpiar grafico*/
                        if (controlPie != null) {
                            var PieChartContent = document.getElementById('chartPieContainer');
                            PieChartContent.innerHTML = '&nbsp;';
                            $('#chartPieContainer').append('<canvas id="barChartDocsERP" height="180" style="height: 180px; display: block; width: 484px;" width="484" class="chartjs-render-monitor"></canvas>');
                            controlPie = $("#barChartDocsERP").get(0).getContext("2d");
                        }

                         graficoPie = new Chart(controlPie, {
                            type: 'pie',
                            data: {
                                labels: ["Ventas", "NC Ventas", "Compras", "NC Compras", "Depósitos Bancarios","No Sincronizado"],
                                datasets: [{
                                    data: arrayDocumentos,
                                    backgroundColor: ['#007bff', '#17A2B8', '#28a745', '#3D9970', '#ffc107','#e9ecef'],
                                }],
                            },
                        });

                    } else {
                        error(data.InternalMessage, data.Message);
                        //$("#" + elements.spn_table).hide();
                    }
                }).fail(function (data) {
                    error(data, "@Resources.messages.error_obt_regs");
                    //$("#" + elements.spn_table).hide();
                    //$("#spn_modal_text").html("");
                });

        }


        //-------------
        //- DONUT CHART - Sincronización de Asientos ERP
        //-------------
        function chartAsientosERP_getInfo() {

            var fechaInicio = $('#dtpAsientosERP').data('daterangepicker').startDate._d;
            var fechaFin = $('#dtpAsientosERP').data('daterangepicker').endDate._d;
            var id = $("#select_storeAsientosERP").val();

            $.get(urls.GetAll_DonutChart + "?fromDate=" + fechaInicio + "&toDate=" + fechaFin + "&idStore=" + (id !== null ? id : '0')).done(async function (data) {
                    if (data.Status) {
                        var arrayAsientos = [];

                        document.getElementById("spAsientosEnviados").innerHTML = data.Result.graphics[0].Total_Asientos_Sync;
                        document.getElementById("spAsientosSinEnviar").innerHTML = data.Result.graphics[0].Total_Asientos_No_Sync;
                        document.getElementById("spAsientosConError").innerHTML = data.Result.graphics[0].Total_Asientos_Error;

                        arrayAsientos.push(data.Result.graphics[0].Total_Asientos_Sync)
                        arrayAsientos.push(data.Result.graphics[0].Total_Asientos_No_Sync)
                        arrayAsientos.push(data.Result.graphics[0].Total_Asientos_Error)

                        var donutChartCanvas = $('#donutChart').get(0).getContext('2d')
                        var donutData = null;

                        /*Limpiar grafico*/
                        if (donutChartCanvas != null) {
                            var BarChartContent = document.getElementById('chartDonutContainer');
                            BarChartContent.innerHTML = '&nbsp;';
                            $('#chartDonutContainer').append('<canvas id="donutChart" style="min-height: 250px; height: 250px; max-height: 250px; max-width: 100%; display: block; width: 565px;" width="565" height="250" class="chartjs-render-monitor"></canvas>');
                            donutChartCanvas = $("#donutChart").get(0).getContext("2d");
                        }


                        var donutData = {
                            labels: [
                                'Enviados',
                                'Sin Enviar',
                                'Con Error',
                            ],
                            datasets: [
                                {
                                    data: arrayAsientos,
                                    backgroundColor: ['#00a65a','#ffc107','#f56954'],
                                }
                            ]
                        }
                        var donutOptions = {
                            maintainAspectRatio: false,
                            responsive: true,
                        }
                        //Create pie or douhnut chart
                        // You can switch between pie and douhnut using the method below.
                        new Chart(donutChartCanvas, {
                            type: 'doughnut',
                            data: donutData,
                            options: donutOptions
                        })

                    } else {
                        error(data.InternalMessage, data.Message);
                        //$("#" + elements.spn_table).hide();
                    }
                }).fail(function (data) {
                    error(data, "@Resources.messages.error_obt_regs");
                    //$("#" + elements.spn_table).hide();
                    //$("#spn_modal_text").html("");
                });

        }



    </script>

