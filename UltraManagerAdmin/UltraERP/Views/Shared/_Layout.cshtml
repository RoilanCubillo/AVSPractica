<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - UltraERP Inventario</title>
    <link rel="stylesheet" href="~/Content/bootstrap.min.css" />
    <link rel="stylesheet" href="~/Content/Site.css" />
</head>
<body>
    <div id="appPageLoader" class="page-loader" aria-live="polite" aria-hidden="true">
        <div class="page-loader-card">
            <div class="page-loader-mark">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <strong>Preparando pantalla</strong>
            <small>Un momento, estamos cargando la informaci&oacute;n...</small>
        </div>
    </div>
    <div class="app-shell">
        @if (Request.IsAuthenticated)
        {
            <aside class="app-sidebar">
                <a class="brand" href="@Url.Action("Inicio", "DocumentosInventario")">
                    <span class="brand-mark">U</span>
                    <span>
                        <strong>UltraERP</strong>
                        <small>Inventario</small>
                    </span>
                </a>
                @{
                    var catalogMenus = new[] { "Familias", "Departamentos", "Categorias", "SubCategorias", "Segmentos", "Marcas", "Fabricantes", "Descuentos" };
                    var processMenus = new[] { "HojasTrabajo", "CambiosMasivos", "MonitoreoDatos" };
                    var isCatalogMenu = Array.IndexOf(catalogMenus, Convert.ToString(ViewBag.ActiveMenu)) >= 0;
                    var isProcessMenu = Array.IndexOf(processMenus, Convert.ToString(ViewBag.ActiveMenu)) >= 0;
                }
                <nav id="appNavAccordion" class="app-nav">
                    <a class="@(ViewBag.ActiveMenu == "Documentos" ? "active" : "")" href="@Url.Action("Inicio", "DocumentosInventario")">Documentos</a>
                    <a class="@(ViewBag.ActiveMenu == "Articulos" ? "active" : "")" href="@Url.Action("Inicio", "Articulos")">Art&iacute;culos</a>
                    <a class="@(ViewBag.ActiveMenu == "PropiedadesArticulos" ? "active" : "")" href="@Url.Action("Inicio", "PropiedadesArticulos")">Propiedades de Art&iacute;culos</a>
                    <a class="@(ViewBag.ActiveMenu == "CasasComerciales" ? "active" : "")" href="@Url.Action("Inicio", "CasasComerciales")">Casas Comerciales</a>
                    <a id="catalogosToggle" class="nav-section-toggle @(isCatalogMenu ? "active" : "") @(isCatalogMenu ? "" : "collapsed")" href="#catalogosMenu" role="button" data-bs-toggle="collapse" data-bs-target="#catalogosMenu" aria-expanded="@(isCatalogMenu ? "true" : "false")" aria-controls="catalogosMenu">
                        <span>Cat&aacute;logos</span>
                        <span class="nav-section-icon @(isCatalogMenu ? "open" : "")" aria-hidden="true">
                            <svg class="nav-arrow-svg" width="26" height="26" viewBox="0 0 26 26" focusable="false">
                                <circle cx="13" cy="13" r="12" style="fill: rgba(255, 255, 255, .08); stroke: rgba(217, 155, 39, .34); stroke-width: 1;" />
                                <path class="nav-arrow-path" d="@(isCatalogMenu ? "M8 10 L13 15 L18 10" : "M8 16 L13 11 L18 16")" style="fill: none; stroke: #ffffff; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round;" />
                            </svg>
                        </span>
                    </a>
                    <div id="catalogosMenu" class="nav-section collapse @(isCatalogMenu ? "show" : "")" data-bs-parent="#appNavAccordion">
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Familias" ? "active" : "")" href="@Url.Action("Inicio", "Familias")">Familias</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Departamentos" ? "active" : "")" href="@Url.Action("Inicio", "Departamentos")">Departamentos</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Categorias" ? "active" : "")" href="@Url.Action("Inicio", "Categorias")">Categor&iacute;as</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "SubCategorias" ? "active" : "")" href="@Url.Action("Inicio", "SubCategorias")">Subcategor&iacute;as</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Segmentos" ? "active" : "")" href="@Url.Action("Inicio", "Segmentos")">Segmentos</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Marcas" ? "active" : "")" href="@Url.Action("Inicio", "Marcas")">Marcas</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Fabricantes" ? "active" : "")" href="@Url.Action("Inicio", "Fabricantes")">Fabricantes</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "Descuentos" ? "active" : "")" href="@Url.Action("Inicio", "Descuentos")">Descuentos</a>
                    </div>
                    <a id="procesosToggle" class="nav-section-toggle @(isProcessMenu ? "active" : "") @(isProcessMenu ? "" : "collapsed")" href="#procesosMenu" role="button" data-bs-toggle="collapse" data-bs-target="#procesosMenu" aria-expanded="@(isProcessMenu ? "true" : "false")" aria-controls="procesosMenu">
                        <span>Procesos</span>
                        <span class="nav-section-icon @(isProcessMenu ? "open" : "")" aria-hidden="true">
                            <svg class="nav-arrow-svg" width="26" height="26" viewBox="0 0 26 26" focusable="false">
                                <circle cx="13" cy="13" r="12" style="fill: rgba(255, 255, 255, .08); stroke: rgba(217, 155, 39, .34); stroke-width: 1;" />
                                <path class="nav-arrow-path" d="@(isProcessMenu ? "M8 10 L13 15 L18 10" : "M8 16 L13 11 L18 16")" style="fill: none; stroke: #ffffff; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round;" />
                            </svg>
                        </span>
                    </a>
                    <div id="procesosMenu" class="nav-section collapse @(isProcessMenu ? "show" : "")" data-bs-parent="#appNavAccordion">
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "HojasTrabajo" ? "active" : "")" href="@Url.Action("Inicio", "HojasTrabajo")">Hojas de Trabajo</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "CambiosMasivos" ? "active" : "")" href="@Url.Action("Inicio", "CambiosMasivosWizard")">Cambios Masivos</a>
                        <a class="nav-sub-link @(ViewBag.ActiveMenu == "MonitoreoDatos" ? "active" : "")" href="@Url.Action("Inicio", "MonitoreoDatos")">Monitoreo de Datos</a>
                    </div>
                    <a class="@(ViewBag.ActiveMenu == "Historico" ? "active" : "")" href="@Url.Action("Historico", "DocumentosInventario")">Historico de Ajustes</a>
                </nav>
                <div class="user-panel">
                    <span>@User.Identity.Name</span>
                    <a href="@Url.Action("Logout", "Account")">Cerrar sesion</a>
                </div>
            </aside>
        }
        <main class="app-main @(Request.IsAuthenticated ? "" : "app-main-login")">
            @RenderBody()
        </main>
    </div>
    <script src="~/Scripts/jquery-3.6.0.min.js"></script>
    <script src="~/Scripts/bootstrap.bundle.min.js"></script>
    <script>
        (function () {
            var loader = document.getElementById("appPageLoader");
            var loaderTimer = null;
            var downloadFrame = null;

            function showPageLoader(message) {
                if (!loader) return;
                var title = loader.querySelector("strong");
                if (title && message) {
                    title.textContent = message;
                }

                window.clearTimeout(loaderTimer);
                loader.classList.add("show");
                loader.setAttribute("aria-hidden", "false");
            }

            function hidePageLoader() {
                if (!loader) return;
                loader.classList.remove("show");
                loader.setAttribute("aria-hidden", "true");
            }

            function downloadFile(url) {
                if (!url) return;
                hidePageLoader();

                if (!downloadFrame) {
                    downloadFrame = document.createElement("iframe");
                    downloadFrame.style.display = "none";
                    downloadFrame.setAttribute("aria-hidden", "true");
                    document.body.appendChild(downloadFrame);
                }

                downloadFrame.src = url + (url.indexOf("?") >= 0 ? "&" : "?") + "_download=" + Date.now();
            }

            function isPlainLeftClick(event) {
                return event.button === 0 && !event.ctrlKey && !event.metaKey && !event.shiftKey && !event.altKey;
            }

            function shouldShowForLink(anchor) {
                if (!anchor) return false;
                if (anchor.getAttribute("data-no-loader") === "true") return false;
                if (anchor.getAttribute("data-download") === "true") return false;
                var href = anchor.getAttribute("href");
                if (!href || href.charAt(0) === "#" || href.indexOf("javascript:") === 0) return false;
                if (anchor.target && anchor.target !== "_self") return false;
                if (anchor.hasAttribute("download")) return false;

                var url;
                try {
                    url = new URL(anchor.href, window.location.href);
                } catch (e) {
                    return false;
                }

                if (url.origin !== window.location.origin) return false;
                if (/\/(Descargar|Download)/i.test(url.pathname)) return false;
                if (url.pathname === window.location.pathname && url.search === window.location.search) return false;
                return true;
            }

            document.addEventListener("click", function (event) {
                var anchor = event.target.closest ? event.target.closest("a") : null;
                if (!isPlainLeftClick(event) || !shouldShowForLink(anchor)) return;
                showPageLoader(anchor.textContent && anchor.textContent.trim() ? "Abriendo " + anchor.textContent.trim() : "Cargando pantalla");
            }, true);

            document.addEventListener("submit", function (event) {
                var form = event.target;
                if (!form || form.getAttribute("data-no-loader") === "true") return;
                if (form.checkValidity && !form.checkValidity()) return;
                showPageLoader(form.classList.contains("login-form") ? "Ingresando" : "Guardando cambios");
            }, true);

            window.addEventListener("beforeunload", function () {
                loaderTimer = window.setTimeout(function () {
                    showPageLoader("Cargando pantalla");
                }, 60);
            });

            window.addEventListener("pageshow", hidePageLoader);
            document.addEventListener("DOMContentLoaded", hidePageLoader);

            window.UltraERP = window.UltraERP || {};
            window.UltraERP.showPageLoader = showPageLoader;
            window.UltraERP.hidePageLoader = hidePageLoader;
            window.UltraERP.downloadFile = downloadFile;
            window.UltraERP.createTablePager = function (options) {
                var settings = options || {};
                var currentPage = 1;
                var pageSizeSelector = settings.pageSizeSelector || "#page_size";
                var previousSelector = settings.previousSelector || "#btnPrevPage";
                var nextSelector = settings.nextSelector || "#btnNextPage";
                var pageHintSelector = settings.pageHintSelector || "#page_hint";
                var resultsSelector = settings.resultsSelector || "#results_hint";
                var label = settings.label || "resultados";

                function getPageSize() {
                    return Number($(pageSizeSelector).val() || settings.defaultPageSize || 10);
                }

                function getTotalPages(totalRows) {
                    return Math.max(1, Math.ceil(totalRows / getPageSize()));
                }

                function clamp(totalRows) {
                    var totalPages = getTotalPages(totalRows);
                    if (currentPage > totalPages) {
                        currentPage = totalPages;
                    }
                    if (currentPage < 1) {
                        currentPage = 1;
                    }
                    return totalPages;
                }

                function pageRows(rows) {
                    rows = rows || [];
                    clamp(rows.length);
                    var pageSize = getPageSize();
                    var start = (currentPage - 1) * pageSize;
                    return rows.slice(start, start + pageSize);
                }

                function update(rows, rowsOnPage) {
                    rows = rows || [];
                    rowsOnPage = rowsOnPage || [];
                    var pageSize = getPageSize();
                    var totalPages = clamp(rows.length);
                    var total = rows.length;
                    var start = total === 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
                    var end = total === 0 ? 0 : start + rowsOnPage.length - 1;

                    $(resultsSelector).text(start + "-" + end + " de " + total + " " + label);
                    $(pageHintSelector).text("Pagina " + currentPage + " de " + totalPages);
                    $(previousSelector).prop("disabled", currentPage <= 1);
                    $(nextSelector).prop("disabled", currentPage >= totalPages);
                }

                function reset() {
                    currentPage = 1;
                }

                function onChange() {
                    if (typeof settings.onChange === "function") {
                        settings.onChange();
                    }
                }

                $(previousSelector).off("click.ultraPager").on("click.ultraPager", function () {
                    if (currentPage <= 1) return;
                    currentPage -= 1;
                    onChange();
                });
                $(nextSelector).off("click.ultraPager").on("click.ultraPager", function () {
                    currentPage += 1;
                    onChange();
                });
                $(pageSizeSelector).off("change.ultraPager").on("change.ultraPager", function () {
                    reset();
                    onChange();
                });

                return {
                    reset: reset,
                    pageRows: pageRows,
                    update: update
                };
            };

            document.addEventListener("DOMContentLoaded", function () {
                function bindSectionToggle(toggleId, menuId) {
                    var toggle = document.getElementById(toggleId);
                    var menu = document.getElementById(menuId);
                    if (!toggle || !menu) return;

                    var icon = toggle.querySelector(".nav-section-icon");
                    var arrowPath = toggle.querySelector(".nav-arrow-path");
                    if (!icon || !arrowPath) return;

                    function syncSectionArrow(isOpen) {
                        toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
                        toggle.classList.toggle("section-open", isOpen);
                        toggle.classList.toggle("collapsed", !isOpen);
                        icon.classList.toggle("open", isOpen);
                        arrowPath.setAttribute("d", isOpen ? "M8 10 L13 15 L18 10" : "M8 16 L13 11 L18 16");
                    }

                    syncSectionArrow(menu.classList.contains("show"));
                    toggle.addEventListener("click", function () {
                        var willOpen = !menu.classList.contains("show") && !menu.classList.contains("collapsing");
                        syncSectionArrow(willOpen);
                    });
                    menu.addEventListener("shown.bs.collapse", function () { syncSectionArrow(true); });
                    menu.addEventListener("hidden.bs.collapse", function () { syncSectionArrow(false); });
                }

                bindSectionToggle("catalogosToggle", "catalogosMenu");
                bindSectionToggle("procesosToggle", "procesosMenu");
            });
        })();
    </script>
    @RenderSection("scripts", required: false)
</body>
</html>
