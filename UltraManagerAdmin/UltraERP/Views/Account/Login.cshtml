@model UltraERP.Models.LoginViewModel
@{
    ViewBag.Title = "Login";
}

<section class="login-page">
    <div class="login-panel">
        <div class="login-copy">
            <span class="eyebrow">UltraERP Inventario</span>
            <span class="login-kicker">Gestion documental</span>
            <h1>Control de documentos</h1>
            <p>Compras, entradas y salidas de inventario en una sola operacion clara y ordenada.</p>
            <div class="login-copy-note">
                <span>Documentos</span>
                <span>Inventario</span>
            </div>
        </div>

        @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "login-form" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.ReturnUrl)

            <div class="login-form-header">
                <div class="login-brand">
                    <div class="login-form-logo">
                        <img src="~/Content/images/avs_logo.png" alt="AVS Central Manager" />
                    </div>
                    <div>
                        <span>AVS</span>
                        <span class="login-brand-name">Solutions CR</span>
                    </div>
                </div>
                <span class="eyebrow">Acceso</span>
                <h2>Ingresar</h2>
                <p>Use sus credenciales para continuar.</p>
            </div>
            if (!String.IsNullOrWhiteSpace(Model.LoginMessage))
            {
                <div class="alert alert-info">@Model.LoginMessage</div>
            }
            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.UserName, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control", autofocus = "autofocus", autocomplete = "username" })
                @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger small" })
            </div>

            if (Model.RequireCompanySelection && Model.Companies != null && Model.Companies.Length > 0)
            {
                <div class="mb-3">
                    @Html.LabelFor(m => m.CompanyId, new { @class = "form-label" })
                    @Html.DropDownListFor(m => m.CompanyId, Model.Companies, "-- Seleccione empresa --", new { @class = "form-select" })
                </div>
            }

            <div class="mb-3">
                @Html.LabelFor(m => m.Password, new { @class = "form-label" })
                @Html.PasswordFor(m => m.Password, new { @class = "form-control", autocomplete = "current-password" })
                @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger small" })
            </div>

            <div class="form-check mb-4">
                @Html.CheckBoxFor(m => m.RememberMe, new { @class = "form-check-input" })
                <label class="form-check-label" for="RememberMe">Mantener sesion</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Entrar</button>
        }
    </div>
</section>
