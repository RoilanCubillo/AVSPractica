@model UltraERP.Models.ArticuloViewModel
@{
    ViewBag.Title = Model.ID > 0 ? "Editar Articulo" : "Nuevo Articulo";
    ViewBag.ActiveMenu = "Articulos";
    var unidades = ViewBag.Unidades as IEnumerable<SelectListItem>;

    if (unidades == null || !unidades.Any())
    {
        unidades = new[]
        {
            new SelectListItem { Text = "UND - Unidad", Value = "UND", Selected = String.IsNullOrWhiteSpace(Model.UnidadMedida) || Model.UnidadMedida == "UND" },
            new SelectListItem { Text = "KG - Kilogramo", Value = "KG", Selected = Model.UnidadMedida == "KG" },
            new SelectListItem { Text = "CJ - Caja", Value = "CJ", Selected = Model.UnidadMedida == "CJ" },
            new SelectListItem { Text = "GAL - Galon", Value = "GAL", Selected = Model.UnidadMedida == "GAL" },
            new SelectListItem { Text = "L - Litro", Value = "L", Selected = Model.UnidadMedida == "L" },
            new SelectListItem { Text = "QQ - Quintal", Value = "QQ", Selected = Model.UnidadMedida == "QQ" },
            new SelectListItem { Text = "BQ - Bolsa", Value = "BQ", Selected = Model.UnidadMedida == "BQ" }
        };
    }
}

<section class="document-topbar">
    <div class="document-topbar-copy">
        <span class="eyebrow">Creaci&oacute;n de art&iacute;culos</span>
        <h1>@Html.Raw(Model.ID > 0 ? "Editar art&iacute;culo" : "Nuevo art&iacute;culo")</h1>
        <p>Complete la ficha base del producto para usarlo luego en compras, entradas, salidas y b&uacute;squeda r&aacute;pida del detalle.</p>
    </div>
    <div class="topbar-actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Inicio", "Articulos")">Cancelar</a>
        <button id="btnGuardarArticulo" class="btn btn-primary" type="submit" form="articuloForm">Guardar art&iacute;culo</button>
    </div>
</section>

@if (TempData["ArticuloError"] != null)
{
    <div class="alert alert-warning">@TempData["ArticuloError"]</div>
}

@using (Html.BeginForm("Registro", "Articulos", FormMethod.Post, new { id = "articuloForm", @class = "document-form" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ID)
    @Html.HiddenFor(m => m.UsuarioCrea)
    @Html.HiddenFor(m => m.FechaCrea)
    @Html.HiddenFor(m => m.UsuarioModifica)
    @Html.HiddenFor(m => m.FechaModifica)

    if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false, "Revise los datos del art\u00edculo:")
        </div>
    }

    <section class="form-panel">
        <div class="section-title">
            <span>1.</span>
            <h2>Datos generales</h2>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label required" for="Codigo">C&oacute;digo</label>
                @Html.TextBoxFor(m => m.Codigo, new { @class = "form-control", maxlength = "25", autocomplete = "off", placeholder = "Ej: ART-001" })
                @Html.ValidationMessageFor(m => m.Codigo, "", new { @class = "text-danger small" })
            </div>
            <div class="col-12 col-md-5">
                <label class="form-label required" for="Descripcion">Descripci&oacute;n</label>
                @Html.TextBoxFor(m => m.Descripcion, new { @class = "form-control", maxlength = "80", autocomplete = "off" })
                @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger small" })
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label required" for="UnidadMedida">Unidad</label>
                @Html.DropDownListFor(m => m.UnidadMedida, unidades, new { @class = "form-select" })
                @Html.ValidationMessageFor(m => m.UnidadMedida, "", new { @class = "text-danger small" })
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label" for="Activo">Estado</label>
                <div class="article-switch">
                    @Html.CheckBoxFor(m => m.Activo)
                    <span>Activo</span>
                </div>
            </div>
            <div class="col-12">
                <label class="form-label" for="DescripcionExtendida">Descripci&oacute;n extendida</label>
                @Html.TextAreaFor(m => m.DescripcionExtendida, 3, 30, new { @class = "form-control", maxlength = "180" })
                @Html.ValidationMessageFor(m => m.DescripcionExtendida, "", new { @class = "text-danger small" })
            </div>
        </div>
    </section>

    <div class="document-grid-two">
        <section class="form-panel">
            <div class="section-title">
                <span>2.</span>
                <h2>Clasificaci&oacute;n</h2>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label required" for="FamiliaID">Familia</label>
                    @Html.DropDownListFor(m => m.FamiliaID, (IEnumerable<SelectListItem>)ViewBag.Familias, new { @class = "form-select", id = "FamiliaID" })
                    @Html.ValidationMessageFor(m => m.FamiliaID, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label required" for="DepartamentoID">Departamento</label>
                    @Html.DropDownListFor(m => m.DepartamentoID, (IEnumerable<SelectListItem>)ViewBag.Departamentos, new { @class = "form-select", id = "DepartamentoID" })
                    @Html.ValidationMessageFor(m => m.DepartamentoID, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label required" for="CategoriaID">Categor&iacute;a</label>
                    @Html.DropDownListFor(m => m.CategoriaID, (IEnumerable<SelectListItem>)ViewBag.Categorias, new { @class = "form-select", id = "CategoriaID" })
                    @Html.ValidationMessageFor(m => m.CategoriaID, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label required" for="SubCategoriaID">Subcategor&iacute;a</label>
                    @Html.DropDownListFor(m => m.SubCategoriaID, (IEnumerable<SelectListItem>)ViewBag.SubCategorias, new { @class = "form-select", id = "SubCategoriaID" })
                    @Html.ValidationMessageFor(m => m.SubCategoriaID, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="Proveedor">Proveedor principal</label>
                    @Html.DropDownListFor(m => m.Proveedor, (IEnumerable<SelectListItem>)ViewBag.Proveedores, new { @class = "form-select" })
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label" for="Bodega">Bodega inicial</label>
                    @Html.DropDownListFor(m => m.Bodega, (IEnumerable<SelectListItem>)ViewBag.Bodegas, new { @class = "form-select" })
                </div>
            </div>
        </section>

        <section class="form-panel">
            <div class="section-title">
                <span>3.</span>
                <h2>Precios e impuestos</h2>
            </div>

            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <label class="form-label required" for="Costo">Costo</label>
                    @Html.TextBoxFor(m => m.CostoTexto, new { @class = "form-control js-decimal-2", inputmode = "decimal", autocomplete = "off", id = "Costo" })
                    @Html.ValidationMessageFor(m => m.CostoTexto, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label required" for="PrecioVenta">Precio venta</label>
                    @Html.TextBoxFor(m => m.PrecioVentaTexto, new { @class = "form-control js-decimal-2", inputmode = "decimal", autocomplete = "off", id = "PrecioVenta" })
                    @Html.ValidationMessageFor(m => m.PrecioVentaTexto, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label" for="ImpuestoPorcentaje">Impuesto %</label>
                    @Html.TextBoxFor(m => m.ImpuestoPorcentajeTexto, new { @class = "form-control js-decimal-2", inputmode = "decimal", autocomplete = "off", id = "ImpuestoPorcentaje" })
                    @Html.ValidationMessageFor(m => m.ImpuestoPorcentajeTexto, "", new { @class = "text-danger small" })
                </div>
                <div class="col-12 col-md-6">
                    <div class="article-switch">
                        @Html.CheckBoxFor(m => m.Exento, new { id = "Exento" })
                        <span>Producto exento</span>
                    </div>
                </div>
                <div class="col-12 col-md-6">
                    <div class="article-switch">
                        @Html.CheckBoxFor(m => m.Inventariable)
                        <span>Controla inventario</span>
                    </div>
                </div>
            </div>
        </section>
    </div>

    <section class="form-panel">
        <div class="section-title">
            <span>4.</span>
            <h2>Inventario inicial</h2>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label" for="Existencia">Existencia</label>
                @Html.TextBoxFor(m => m.ExistenciaTexto, new { @class = "form-control js-decimal-2", inputmode = "decimal", autocomplete = "off", id = "Existencia" })
                @Html.ValidationMessageFor(m => m.ExistenciaTexto, "", new { @class = "text-danger small" })
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="ExistenciaMinima">Existencia m&iacute;nima</label>
                @Html.TextBoxFor(m => m.ExistenciaMinimaTexto, new { @class = "form-control js-decimal-2", inputmode = "decimal", autocomplete = "off", id = "ExistenciaMinima" })
                @Html.ValidationMessageFor(m => m.ExistenciaMinimaTexto, "", new { @class = "text-danger small" })
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label" for="ExistenciaMaxima">Existencia m&aacute;xima</label>
                @Html.TextBoxFor(m => m.ExistenciaMaximaTexto, new { @class = "form-control js-decimal-2", inputmode = "decimal", autocomplete = "off", id = "ExistenciaMaxima" })
                @Html.ValidationMessageFor(m => m.ExistenciaMaximaTexto, "", new { @class = "text-danger small" })
            </div>
        </div>
    </section>
}

@section scripts {
    <script>
        var clasificacion = @Html.Raw(ViewBag.ClasificacionJson ?? "{}");
        var initialDepartamentoId = @Model.DepartamentoID;
        var initialCategoriaId = @Model.CategoriaID;
        var initialSubCategoriaId = @Model.SubCategoriaID;

        $(function () {
            $("#FamiliaID").on("change", function () {
                fillDepartamentos();
                fillCategorias();
                fillSubCategorias();
            });
            $("#DepartamentoID").on("change", function () {
                fillCategorias();
                fillSubCategorias();
            });
            $("#CategoriaID").on("change", fillSubCategorias);
            fillDepartamentos(initialDepartamentoId);
            fillCategorias(initialCategoriaId);
            fillSubCategorias(initialSubCategoriaId);
            $("#Exento").on("change", syncExento);
            syncExento();
            $(".js-decimal-2").on("blur", formatDecimal2);
        });

        function fillDepartamentos(selectedId) {
            var familiaId = Number($("#FamiliaID").val() || 0);
            var selected = Number(selectedId || $("#DepartamentoID").val() || 0);
            var items = (clasificacion.departamentos || []).filter(function (item) {
                return Number(item.FamiliaID) === familiaId;
            });

            fillSelect("#DepartamentoID", items, selected);
        }

        function fillCategorias(selectedId) {
            var departamentoId = Number($("#DepartamentoID").val() || 0);
            var selected = Number(selectedId || $("#CategoriaID").val() || 0);
            var items = (clasificacion.categorias || []).filter(function (item) {
                return Number(item.DepartamentoID) === departamentoId;
            });

            if (!items.length) {
                items = clasificacion.categorias || [];
            }

            fillSelect("#CategoriaID", items, selected);
        }

        function fillSubCategorias(selectedId) {
            var categoriaId = Number($("#CategoriaID").val() || 0);
            var selected = Number(selectedId || $("#SubCategoriaID").val() || 0);
            var items = (clasificacion.subCategorias || []).filter(function (item) {
                return Number(item.CategoriaID) === categoriaId;
            });

            fillSelect("#SubCategoriaID", items, selected, "Sin subcategor\u00edas disponibles");
        }

        function fillSelect(selector, items, selectedId, emptyText) {
            var select = $(selector);

            if (!items || !items.length) {
                select.html("<option value='0'>" + escapeHtml(emptyText || "Sin opciones disponibles") + "</option>");
                select.val("0");
                return;
            }

            var html = items.map(function (item) {
                var selected = Number(item.ID) === Number(selectedId) ? " selected" : "";
                return "<option value='" + item.ID + "'" + selected + ">" + escapeHtml(item.Texto) + "</option>";
            }).join("");

            select.html(html);
            if (!select.val() && items.length) {
                select.val(String(items[0].ID));
            }
        }

        function syncExento() {
            var isExento = $("#Exento").is(":checked");
            $("#ImpuestoPorcentaje").prop("readonly", isExento);
            if (isExento) {
                $("#ImpuestoPorcentaje").val("0.00");
            }
        }

        function formatDecimal2() {
            var input = $(this);
            var value = parseDecimal(input.val());

            if (value === null) {
                return;
            }

            input.val(value.toFixed(2));
        }

        function parseDecimal(value) {
            value = String(value || "").trim();
            if (!value) {
                return 0;
            }

            value = value.replace(/\s/g, "");
            var hasComma = value.indexOf(",") >= 0;
            var hasDot = value.indexOf(".") >= 0;

            if (hasComma && hasDot && value.lastIndexOf(",") > value.lastIndexOf(".")) {
                value = value.replace(/\./g, "").replace(",", ".");
            } else if (hasComma && hasDot) {
                value = value.replace(/,/g, "");
            } else if (hasComma) {
                value = value.replace(",", ".");
            }

            var number = Number(value);
            return isNaN(number) ? null : number;
        }

        function escapeHtml(value) {
            return $("<div />").text(value || "").html();
        }
    </script>
}
