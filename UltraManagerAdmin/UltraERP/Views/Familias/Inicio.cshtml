@model IEnumerable<UltraERP.Models.FamiliaViewModel>
@{
    ViewBag.Title = "Familias";
    ViewBag.ActiveMenu = "Familias";
    var familiasJson = Newtonsoft.Json.JsonConvert.SerializeObject(Model);
}

<section class="page-header">
    <div class="page-header-copy">
        <span class="eyebrow">Catalogo de clasificacion</span>
        <h1>Familias</h1>
        <p>Organice los art&iacute;culos por familias para facilitar b&uacute;squeda, reportes y configuraci&oacute;n de cat&aacute;logos.</p>
    </div>
    <div class="topbar-actions">
        <a id="btnNuevaFamilia" class="btn btn-primary" href="@Url.Action("Registro", "Familias")">Nueva familia</a>
    </div>
</section>

@if (TempData["FamiliaMessage"] != null)
{
    <div class="alert alert-success">@TempData["FamiliaMessage"]</div>
}

@if (TempData["FamiliaError"] != null)
{
    <div class="alert alert-warning">@TempData["FamiliaError"]</div>
}

<section class="filter-panel">
    <div class="row g-3">
        <div class="col-12 col-md-5">
            <label for="table_search" class="form-label">Buscar</label>
            <input id="table_search" type="search" class="form-control" placeholder="Codigo o nombre" />
        </div>
    </div>
    <div class="filter-actions">
        <button id="btnLimpiar" class="btn btn-outline-secondary" type="button">Limpiar</button>
        <button id="btnConsultar" class="btn btn-primary" type="button">Consultar</button>
    </div>
</section>

<section class="metric-grid">
    <article>
        <span>Familias</span>
        <strong id="summary_count">0</strong>
    </article>
    <article>
        <span>C&oacute;digos visibles</span>
        <strong id="summary_codes">0</strong>
    </article>
</section>

<section class="table-panel">
    <div class="table-toolbar">
        <div class="table-toolbar-main">
            <span id="results_hint" class="toolbar-chip">0 resultados</span>
            <label class="page-size-control" for="page_size">
                Mostrar
                <select id="page_size" class="form-select form-select-sm">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </label>
        </div>
        <span id="loading_state" class="loading-state">Cargando...</span>
    </div>
    <div class="table-responsive">
        <table class="table align-middle document-table family-list-table">
            <thead>
                <tr>
                    <th>C&oacute;digo</th>
                    <th>Nombre</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="familias_body"></tbody>
        </table>
    </div>
    <div class="table-pagination">
        <button id="btnPrevPage" class="btn btn-outline-secondary btn-sm" type="button">Anterior</button>
        <span id="page_hint" class="toolbar-chip">Pagina 1 de 1</span>
        <button id="btnNextPage" class="btn btn-outline-secondary btn-sm" type="button">Siguiente</button>
    </div>
</section>

<div class="modal fade" id="familiaModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="familiaModalTitle" class="modal-title">Familia</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="document-view">
                    <section class="document-view-hero">
                        <div>
                            <span class="eyebrow">Ficha de familia</span>
                            <h2 id="fam_view_title" class="document-view-title"></h2>
                            <p id="fam_view_subtitle" class="document-view-subtitle"></p>
                        </div>
                    </section>
                    <section class="document-view-section">
                        <h3>Datos generales</h3>
                        <div id="fam_view_summary" class="document-view-grid"></div>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        var urls = {
            registro: '@Url.Action("Registro", "Familias")',
            cambiarEstado: '@Url.Action("CambiarEstado", "Familias")'
        };
        var familias = @Html.Raw(familiasJson);
        var filteredRows = [];
        var pager = null;

        $(function () {
            pager = window.UltraERP.createTablePager({ onChange: renderTable });
            bindEvents();
            renderTable();
            setLoading(false);
        });

        function bindEvents() {
            $("#btnConsultar").on("click", renderTable);
            $("#table_search").on("input", renderTable);
            $("#btnLimpiar").on("click", function () {
                $("#table_search").val("");
                if (pager) pager.reset();
                renderTable();
            });
        }

        function renderTable() {
            filteredRows = getFilteredRows();
            var pageRows = pager ? pager.pageRows(filteredRows) : filteredRows;
            var html = pageRows.map(function (f) {
                return "<tr>" +
                    "<td><strong>" + escapeHtml(f.Codigo) + "</strong></td>" +
                    "<td>" + escapeHtml(f.Nombre) + "</td>" +
                    "<td>" + getActionButtons(f) + "</td>" +
                    "</tr>";
            }).join("");

            if (pager) pager.update(filteredRows, pageRows);
            else $("#results_hint").text(filteredRows.length + " resultados");
            $("#familias_body").html(html || "<tr><td colspan='3' class='empty-state'>Sin familias para los filtros aplicados.</td></tr>");
            updateSummary();
        }

        function getFilteredRows() {
            var text = ($("#table_search").val() || "").toLowerCase();

            return familias.filter(function (f) {
                if (!text) return true;

                return [f.Codigo, f.Nombre]
                    .some(function (value) { return String(value || "").toLowerCase().indexOf(text) >= 0; });
            });
        }

        function getActionButtons(familia) {
            return "<div class='action-stack'>" +
                "<button class='icon-button info' type='button' onclick='onVer(" + familia.ID + ")'>Ver</button>" +
                "<button class='icon-button primary' type='button' onclick='onEditar(" + familia.ID + ")'>Editar</button>" +
                "</div>";
        }

        function onVer(id) {
            var familia = findFamilia(id);
            if (!familia) return;

            $("#familiaModalTitle").text("Familia " + familia.Codigo);
            $("#fam_view_title").text(familia.Codigo);
            $("#fam_view_subtitle").text(familia.Nombre);
            $("#fam_view_summary").html(renderViewGrid([
                { label: "Codigo", value: familia.Codigo },
                { label: "Nombre", value: familia.Nombre }
            ]));
            new bootstrap.Modal(document.getElementById("familiaModal")).show();
        }

        function onEditar(id) {
            if (window.UltraERP && window.UltraERP.showPageLoader) {
                window.UltraERP.showPageLoader("Abriendo familia");
            }

            window.location.href = urls.registro + "?id=" + encodeURIComponent(id);
        }

        function findFamilia(id) {
            return familias.find(function (item) { return item.ID === id; });
        }

        function updateSummary() {
            var rows = filteredRows.length ? filteredRows : getFilteredRows();
            $("#summary_count").text(rows.length);
            $("#summary_codes").text(rows.filter(function (f) { return String(f.Codigo || "").trim().length > 0; }).length);
        }

        function renderViewGrid(items) {
            return items.map(function (item) {
                return "<article class='document-view-item'><span>" + escapeHtml(item.label) + "</span><strong>" + escapeHtml(item.value) + "</strong></article>";
            }).join("");
        }

        function setLoading(isLoading) {
            $("#loading_state").toggle(isLoading);
        }

        function showToast(message) {
            var toast = $("<div class='local-toast'></div>").text(message);
            $("body").append(toast);
            setTimeout(function () { toast.addClass("show"); }, 10);
            setTimeout(function () {
                toast.removeClass("show");
                setTimeout(function () { toast.remove(); }, 250);
            }, 2600);
        }

        function formatNumber(value) {
            return Number(value || 0).toLocaleString("es-CR", { minimumFractionDigits: 0, maximumFractionDigits: 2 });
        }

        function escapeHtml(value) {
            return $("<div />").text(value || "").html();
        }
    </script>
}
