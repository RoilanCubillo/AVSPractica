@model IEnumerable<UltraERP.Models.DescuentoViewModel>
@{
    ViewBag.Title = "Descuentos";
    ViewBag.ActiveMenu = "Descuentos";
}

<section class="page-header">
    <div class="page-header-copy">
        <span class="eyebrow">Catalogo comercial</span>
        <h1>Descuentos</h1>
        <p>Administre reglas de descuento por cantidad, precio especial y promociones para tiendas del inventario.</p>
    </div>
    <div class="topbar-actions">
        <a id="btnNuevoDescuento" class="btn btn-primary" href="@Url.Action("Registro", "Descuentos")">Nuevo descuento</a>
    </div>
</section>

@if (TempData["DescuentoMessage"] != null)
{
    <div class="alert alert-success">@TempData["DescuentoMessage"]</div>
}

@if (TempData["DescuentoError"] != null)
{
    <div class="alert alert-warning">@TempData["DescuentoError"]</div>
}

<section class="filter-panel">
    <div class="row g-3">
        <div class="col-12 col-md-3">
            <label for="filter_tipo" class="form-label">Tipo</label>
            <select id="filter_tipo" class="form-select">
                <option value="Todos">Todos</option>
                <option value="Mezcle y Combine: Precio Unitario">Mezcle y Combine: Precio Unitario</option>
                <option value="Mezcle y Combine: Porcentaje de Descuento">Mezcle y Combine: Porcentaje de Descuento</option>
                <option value="Compre X y lleve Y por Z: Precio Unitario">Compre X y lleve Y por Z: Precio Unitario</option>
                <option value="Compre X y lleve Y por Z: Porcentaje de Descuento">Compre X y lleve Y por Z: Porcentaje de Descuento</option>
            </select>
        </div>
        <div class="col-12 col-md-6">
            <label for="table_search" class="form-label">Buscar</label>
            <input id="table_search" type="search" class="form-control" placeholder="Descripcion, tipo o resumen" />
        </div>
    </div>
    <div class="filter-actions">
        <button id="btnLimpiar" class="btn btn-outline-secondary" type="button">Limpiar</button>
        <button id="btnConsultar" class="btn btn-primary" type="button">Consultar</button>
    </div>
</section>

<section class="metric-grid">
    <article>
        <span>Descuentos</span>
        <strong id="summary_count">0</strong>
    </article>
    <article>
        <span>Tipos</span>
        <strong id="summary_types">0</strong>
    </article>
    <article>
        <span>Con impares</span>
        <strong id="summary_odd">0</strong>
    </article>
</section>

<section class="table-panel">
    <div class="table-toolbar">
        <div class="table-toolbar-main">
            <span id="results_hint" class="toolbar-chip">0 resultados</span>
            <label class="page-size-control" for="page_size">
                Mostrar
                <select id="page_size" class="form-select form-select-sm">
                    <option value="5">5</option>
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
            </label>
        </div>
        <span id="loading_state" class="loading-state">Cargando...</span>
    </div>
    <div class="table-responsive">
        <table class="table align-middle document-table discount-list-table">
            <thead>
                <tr>
                    <th>C&oacute;digo</th>
                    <th>Descripci&oacute;n</th>
                    <th>Tipo</th>
                    <th>Resumen</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="descuentos_body"></tbody>
        </table>
    </div>
    <div class="table-pagination">
        <button id="btnPrevPage" class="btn btn-outline-secondary btn-sm" type="button">Anterior</button>
        <span id="page_hint" class="toolbar-chip">Pagina 1 de 1</span>
        <button id="btnNextPage" class="btn btn-outline-secondary btn-sm" type="button">Siguiente</button>
    </div>
</section>

<div class="modal fade" id="descuentoCatalogoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="descuentoModalTitle" class="modal-title">Descuento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="document-view">
                    <section class="document-view-hero">
                        <div>
                            <span class="eyebrow">Ficha de descuento</span>
                            <h2 id="discount_view_title" class="document-view-title"></h2>
                            <p id="discount_view_subtitle" class="document-view-subtitle"></p>
                        </div>
                        <div class="document-view-total">
                            <span>Tipo</span>
                            <strong id="discount_view_type"></strong>
                        </div>
                    </section>
                    <section class="document-view-section">
                        <h3>Datos generales</h3>
                        <div id="discount_view_summary" class="document-view-grid"></div>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        var urls = {
            buscar: '@Url.Action("Buscar", "Descuentos")',
            detalle: '@Url.Action("Detalle", "Descuentos")',
            registro: '@Url.Action("Registro", "Descuentos")'
        };
        var descuentos = [];
        var currentPage = 1;
        var totalRows = 0;
        var totalPages = 1;
        var searchTimer = null;

        $(function () {
            bindEvents();
            loadDescuentos();
        });

        function bindEvents() {
            $("#btnConsultar").on("click", function () {
                currentPage = 1;
                loadDescuentos();
            });
            $("#table_search").on("input", function () {
                currentPage = 1;
                queueLoad();
            });
            $("#filter_tipo").on("change", function () {
                currentPage = 1;
                loadDescuentos();
            });
            $("#page_size").on("change", function () {
                currentPage = 1;
                loadDescuentos();
            });
            $("#btnPrevPage").on("click", function () {
                if (currentPage > 1) {
                    currentPage--;
                    loadDescuentos();
                }
            });
            $("#btnNextPage").on("click", function () {
                if (currentPage < totalPages) {
                    currentPage++;
                    loadDescuentos();
                }
            });
            $("#btnLimpiar").on("click", function () {
                $("#filter_tipo").val("Todos");
                $("#table_search").val("");
                currentPage = 1;
                loadDescuentos();
            });
        }

        function queueLoad() {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(loadDescuentos, 300);
        }

        function loadDescuentos() {
            setLoading(true);
            $.get(urls.buscar, {
                page: currentPage,
                pageSize: getPageSize(),
                search: $("#table_search").val() || "",
                tipo: $("#filter_tipo").val() || "Todos"
            }).done(function (response) {
                if (!response || !response.Status) {
                    descuentos = [];
                    totalRows = 0;
                    totalPages = 1;
                    renderTable();
                    return;
                }

                var result = response.Result || {};
                descuentos = result.Rows || [];
                totalRows = Number(result.Total || 0);
                totalPages = Math.max(1, Number(result.TotalPages || 1));
                currentPage = Math.min(Math.max(Number(result.Page || currentPage), 1), totalPages);
                renderTable();
            }).fail(function () {
                descuentos = [];
                totalRows = 0;
                totalPages = 1;
                renderTable();
            }).always(function () {
                setLoading(false);
            });
        }

        function renderTable() {
            var html = descuentos.map(function (d) {
                return "<tr>" +
                    "<td><strong>" + escapeHtml(d.CodigoTexto) + "</strong></td>" +
                    "<td>" + escapeHtml(d.Descripcion) + "</td>" +
                    "<td>" + escapeHtml(d.TipoTexto) + "</td>" +
                    "<td>" + escapeHtml(d.ResumenTexto) + "</td>" +
                    "<td>" + getActionButtons(d) + "</td>" +
                    "</tr>";
            }).join("");

            updatePagination();
            $("#descuentos_body").html(html || "<tr><td colspan='5' class='empty-state'>Sin descuentos para los filtros aplicados.</td></tr>");
            updateSummary();
        }

        function getPageSize() {
            return Number($("#page_size").val() || 10);
        }

        function updatePagination() {
            var pageSize = getPageSize();
            var start = totalRows === 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
            var end = totalRows === 0 ? 0 : start + descuentos.length - 1;

            $("#results_hint").text(start + "-" + end + " de " + totalRows + " resultados");
            $("#page_hint").text("Pagina " + currentPage + " de " + totalPages);
            $("#btnPrevPage").prop("disabled", currentPage <= 1);
            $("#btnNextPage").prop("disabled", currentPage >= totalPages);
        }

        function getActionButtons(descuento) {
            return "<div class='action-stack'>" +
                "<button class='icon-button info' type='button' onclick='onVer(" + descuento.ID + ")'>Ver</button>" +
                "<button class='icon-button primary' type='button' onclick='onEditar(" + descuento.ID + ")'>Editar</button>" +
                "</div>";
        }

        function onVer(id) {
            $.get(urls.detalle, { id: id }).done(function (response) {
                if (!response || !response.Status) return;

                var descuento = response.Result;
                $("#descuentoModalTitle").text("Descuento " + descuento.CodigoTexto);
                $("#discount_view_title").text(descuento.Descripcion);
                $("#discount_view_subtitle").text(descuento.TipoTexto);
                $("#discount_view_type").text(descuento.TipoTexto);
                $("#discount_view_summary").html(renderViewGrid([
                    { label: "Codigo", value: descuento.CodigoTexto },
                    { label: "Descripcion", value: descuento.Descripcion },
                    { label: "Tipo", value: descuento.TipoTexto },
                    { label: "Resumen", value: descuento.ResumenTexto },
                    { label: "Descontar impares", value: descuento.DescontarImpares ? "Si" : "No" }
                ]));
                new bootstrap.Modal(document.getElementById("descuentoCatalogoModal")).show();
            });
        }

        function onEditar(id) {
            if (window.UltraERP && window.UltraERP.showPageLoader) {
                window.UltraERP.showPageLoader("Abriendo descuento");
            }

            window.location.href = urls.registro + "?id=" + encodeURIComponent(id);
        }

        function updateSummary() {
            var types = {};
            var odd = 0;
            descuentos.forEach(function (d) {
                types[d.TipoTexto || ""] = true;
                if (d.DescontarImpares) odd += 1;
            });
            $("#summary_count").text(totalRows);
            $("#summary_types").text(Object.keys(types).filter(function (key) { return key; }).length);
            $("#summary_odd").text(odd);
        }

        function renderViewGrid(items) {
            return items.map(function (item) {
                return "<article class='document-view-item'><span>" + escapeHtml(item.label) + "</span><strong>" + escapeHtml(item.value) + "</strong></article>";
            }).join("");
        }

        function setLoading(isLoading) {
            $("#loading_state").toggle(isLoading);
        }

        function formatNumber(value) {
            return Number(value || 0).toLocaleString("es-CR", { minimumFractionDigits: 0, maximumFractionDigits: 2 });
        }

        function escapeHtml(value) {
            return $("<div />").text(value || "").html();
        }
    </script>
}
