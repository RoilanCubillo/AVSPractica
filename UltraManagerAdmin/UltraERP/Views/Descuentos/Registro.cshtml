@model UltraERP.Models.DescuentoViewModel
@{
    ViewBag.Title = Model.ID > 0 ? "Editar Descuento" : "Nuevo Descuento";
    ViewBag.ActiveMenu = "Descuentos";
}

<section class="document-topbar">
    <div class="document-topbar-copy">
        <span class="eyebrow">Catalogo de descuentos</span>
        <h1>@(Model.ID > 0 ? "Editar descuento" : "Nuevo descuento")</h1>
        <p>Configure reglas comerciales por cantidad, precio especial o porcentaje para promociones de inventario.</p>
    </div>
    <div class="topbar-actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Inicio", "Descuentos")">Cancelar</a>
        <button id="btnGuardarDescuento" class="btn btn-primary" type="submit" form="descuentoForm">Guardar descuento</button>
    </div>
</section>

@if (TempData["DescuentoError"] != null)
{
    <div class="alert alert-warning">@TempData["DescuentoError"]</div>
}

@using (Html.BeginForm("Registro", "Descuentos", FormMethod.Post, new { id = "descuentoForm", @class = "document-form" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ID)
    @Html.HiddenFor(m => m.HQID)
    @Html.HiddenFor(m => m.UsuarioCrea)
    @Html.HiddenFor(m => m.FechaCrea)
    @Html.HiddenFor(m => m.UsuarioModifica)
    @Html.HiddenFor(m => m.FechaModifica)

    if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false, "Revise los datos del descuento:")
        </div>
    }

    <section class="form-panel">
        <div class="section-title">
            <span>1.</span>
            <h2>Datos generales</h2>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-2">
                <label class="form-label" for="CodigoTexto">C&oacute;digo</label>
                <input id="CodigoTexto" class="form-control readonly-control" type="text" value="@Model.CodigoTexto" readonly />
            </div>
            <div class="col-12 col-md-4">
                <label class="form-label required" for="Descripcion">Descripci&oacute;n</label>
                @Html.TextBoxFor(m => m.Descripcion, new { @class = "form-control", maxlength = "30", autocomplete = "off", placeholder = "Ej: Cafe CR mayoreo" })
                @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger small" })
            </div>
            @Html.HiddenFor(m => m.Tipo, new { id = "Tipo" })
            <div class="col-12 col-md-4">
                <label class="form-label required">Tipo de descuento</label>
                <div class="discount-type-options">
                    <label><input type="radio" name="TipoOption" value="1" @(Model.Tipo == 1 ? "checked" : "") /> Mezcle y Combine: Precio Unitario</label>
                    <label><input type="radio" name="TipoOption" value="3" @(Model.Tipo == 3 ? "checked" : "") /> Mezcle y Combine: Porcentaje de Descuento</label>
                    <label><input type="radio" name="TipoOption" value="2" @(Model.Tipo == 2 ? "checked" : "") /> Compre X y lleve Y por Z: Precio Unitario</label>
                    <label><input type="radio" name="TipoOption" value="4" @(Model.Tipo == 4 ? "checked" : "") /> Compre X y lleve Y por Z: Porcentaje de Descuento</label>
                </div>
                @Html.ValidationMessageFor(m => m.Tipo, "", new { @class = "text-danger small" })
            </div>
            <div class="col-12 col-md-2">
                <label class="form-label" for="DescontarImpares">Impares</label>
                <div class="article-switch">
                    @Html.CheckBoxFor(m => m.DescontarImpares)
                    <span>Aplicar</span>
                </div>
            </div>
        </div>
    </section>

    <section class="form-panel">
        <div class="section-title">
            <span>2.</span>
            <h2>Regla de descuento</h2>
        </div>

        <div class="discount-matrix">
            <div class="table-responsive matrix-price matrix-section">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>Cantidad</th>
                            <th>Precio Reg.</th>
                            <th>Nivel A</th>
                            <th>Nivel B</th>
                            <th>Nivel C</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad1, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio1, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio1A, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio1B, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio1C, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                        </tr>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad2, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio2, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio2A, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio2B, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio2C, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                        </tr>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad3, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio3, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio3A, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio3B, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio3C, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                        </tr>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad4, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio4, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio4A, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio4B, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Precio4C, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="table-responsive matrix-percent matrix-section">
                <table class="table table-bordered align-middle">
                    <thead>
                        <tr>
                            <th>Cantidad</th>
                            <th>Porcentaje Reg.</th>
                            <th>Nivel A</th>
                            <th>Nivel B</th>
                            <th>Nivel C</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad1, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje1, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje1A, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje1B, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje1C, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                        </tr>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad2, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje2, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje2A, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje2B, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje2C, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                        </tr>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad3, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje3, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje3A, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje3B, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje3C, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                        </tr>
                        <tr>
                            <td>@Html.TextBoxFor(m => m.Cantidad4, new { @class = "form-control", type = "number", min = "0", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje4, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje4A, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje4B, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                            <td>@Html.TextBoxFor(m => m.Porcentaje4C, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="row g-3 xy-section">
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Cantidad1">Cantidad a comprar</label>
                    @Html.TextBoxFor(m => m.Cantidad1, new { @class = "form-control", type = "number", min = "0", step = "0.01" })
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label" for="Cantidad2">Cantidad con descuento</label>
                    @Html.TextBoxFor(m => m.Cantidad2, new { @class = "form-control", type = "number", min = "0", step = "0.01" })
                </div>
                <div class="col-12 col-md-3 xy-price">
                    <label class="form-label" for="Precio2">Precio descuento</label>
                    @Html.TextBoxFor(m => m.Precio2, new { @class = "form-control", type = "number", min = "0", step = "0.01" })
                </div>
                <div class="col-12 col-md-3 xy-percent">
                    <label class="form-label" for="Porcentaje2">Porcentaje descuento</label>
                    @Html.TextBoxFor(m => m.Porcentaje2, new { @class = "form-control", type = "number", min = "0", max = "100", step = "0.01" })
                </div>
            </div>
        </div>
    </section>

}

@section scripts {
    <script>
        $(function () {
            hydrateNumberInputs();
            $("input[name='TipoOption']").on("change", function () {
                $("#Tipo").val($(this).val());
                syncDiscountType();
            });
            $("#descuentoForm").on("submit", normalizeDiscountForm);
            syncDiscountType();
        });

        function hydrateNumberInputs() {
            $("#descuentoForm input[type='number']").each(function () {
                var input = this;
                var rawValue = input.getAttribute("value");
                if (input.value || !rawValue) return;

                var normalizedValue = normalizeNumberValue(rawValue);
                if (normalizedValue !== rawValue) {
                    input.value = normalizedValue;
                }
            });
        }

        function normalizeNumberValue(value) {
            value = String(value || "").trim();
            if (!value) return value;

            var hasComma = value.indexOf(",") >= 0;
            var hasDot = value.indexOf(".") >= 0;

            if (hasComma && hasDot && value.lastIndexOf(",") > value.lastIndexOf(".")) {
                return formatTwoDecimals(value.replace(/\./g, "").replace(",", "."));
            }

            if (hasComma && hasDot) {
                return formatTwoDecimals(value.replace(/,/g, ""));
            }

            if (hasComma) {
                return formatTwoDecimals(value.replace(",", "."));
            }

            return formatTwoDecimals(value);
        }

        function formatTwoDecimals(value) {
            var number = Number(value);
            if (!isFinite(number)) return value;

            return number.toFixed(2);
        }

        function syncDiscountType() {
            var type = Number($("#Tipo").val() || 1);
            $(".matrix-price").toggle(type === 1).find(":input").prop("disabled", type !== 1);
            $(".matrix-percent").toggle(type === 3).find(":input").prop("disabled", type !== 3);
            $(".xy-section").toggle(type === 2 || type === 4).find(":input").prop("disabled", type !== 2 && type !== 4);
            $(".xy-price").toggle(type === 2).find(":input").prop("disabled", type !== 2);
            $(".xy-percent").toggle(type === 4).find(":input").prop("disabled", type !== 4);
        }

        function normalizeDiscountForm() {
            var type = Number($("#Tipo").val() || 1);

            $("#descuentoForm input[type='number']:enabled").each(function () {
                var $input = $(this);
                if (!$input.val()) {
                    $input.val(0);
                }
            });
        }
    </script>
}
