@{
    ViewBag.Title = "Historico de Ajustes";
    ViewBag.ActiveMenu = "Historico";
}

<section class="page-header">
    <div class="page-header-copy">
        <span class="eyebrow">Consulta historica</span>
        <h1>Historico de Ajustes de Inventario</h1>
        <p>Revise documentos cerrados, detecte l&iacute;neas especiales y valide la aplicacion final del movimiento.</p>
    </div>
    <a class="btn btn-outline-primary" href="@Url.Action("Inicio", "DocumentosInventario")">Volver a documentos</a>
</section>

<section class="filter-panel">
    <div class="row g-3">
        <div class="col-12 col-md-4 col-xl-2">
            <label for="hist_tipo" class="form-label">Tipo Documento</label>
            <select id="hist_tipo" class="form-select">
                <option value="Todos">Todos</option>
                <option value="Compra">Compra</option>
                <option value="Entrada">Entrada de Inventario</option>
                <option value="Salida">Salida de Inventario</option>
            </select>
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <label for="hist_fecha_aplicacion" class="form-label">Fecha Aplicaci&oacute;n</label>
            <input id="hist_fecha_aplicacion" type="date" class="form-control" />
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <label for="hist_proveedor" class="form-label">Proveedor</label>
            <input id="hist_proveedor" type="text" class="form-control" placeholder="C&oacute;digo o nombre" />
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <label for="hist_usuario" class="form-label">Usuario</label>
            <input id="hist_usuario" type="text" class="form-control" placeholder="Persona solicita" />
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <label for="hist_factura" class="form-label">Factura Ref.</label>
            <input id="hist_factura" type="text" class="form-control" />
        </div>
        <div class="col-12 col-md-4 col-xl-2">
            <label for="hist_producto" class="form-label">Producto</label>
            <input id="hist_producto" type="text" class="form-control" />
        </div>
    </div>
    <div class="filter-actions">
        <button id="btnHistLimpiar" class="btn btn-outline-secondary" type="button">Limpiar</button>
        <button id="btnHistConsultar" class="btn btn-primary" type="button">Consultar</button>
    </div>
</section>

<section class="metric-grid">
    <article>
        <span>Documentos cerrados</span>
        <strong id="hist_count">0</strong>
    </article>
    <article>
        <span>Total aplicado</span>
        <strong id="hist_total">0.00</strong>
    </article>
    <article>
        <span>Ultima aplicacion</span>
        <strong id="hist_last">-</strong>
    </article>
</section>

<section class="table-panel">
    <div class="table-toolbar">
        <div class="table-toolbar-main">
            <input id="hist_search" type="search" class="form-control" placeholder="Buscar en historico" />
            <span id="hist_results_hint" class="toolbar-chip">0 resultados</span>
        </div>
        <span id="hist_loading" class="loading-state">Cargando...</span>
    </div>
    <div class="table-responsive">
        <table class="table align-middle document-table history-list-table">
            <thead>
                <tr>
                    <th>N&uacute;mero</th>
                    <th>Tipo</th>
                    <th>Proveedor</th>
                    <th>Producto</th>
                    <th>Factura Ref.</th>
                    <th>Fecha Aplicaci&oacute;n</th>
                    <th>Estado</th>
                    <th>Auditoria</th>
                    <th>Total</th>
                    <th>Usuario</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="historico_body"></tbody>
        </table>
    </div>
</section>

<div class="modal fade" id="historicoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 id="historicoModalTitle" class="modal-title">Documento historico</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="document-view">
                    <section class="document-view-hero">
                        <div>
                            <span class="eyebrow">Documento aplicado</span>
                            <h2 id="hist_view_title" class="document-view-title"></h2>
                            <p id="hist_view_subtitle" class="document-view-subtitle"></p>
                        </div>
                        <div class="document-view-total">
                            <span>Total aplicado</span>
                            <strong id="hist_view_total"></strong>
                        </div>
                    </section>

                    <div id="hist_view_badges" class="document-view-badges"></div>

                    <section class="document-view-section">
                        <h3>Resumen</h3>
                        <div id="hist_view_summary" class="document-view-grid"></div>
                    </section>

                    <section id="hist_view_type_section" class="document-view-section" style="display:none;">
                        <h3>Datos del movimiento</h3>
                        <div id="hist_view_type_grid" class="document-view-grid"></div>
                    </section>

                    <section class="document-view-section">
                        <h3>Auditoria</h3>
                        <div id="hist_view_audit"></div>
                    </section>

                    <section class="document-view-section">
                        <h3>Detalle</h3>
                        <div id="hist_view_lines"></div>
                    </section>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        var historicoUrls = {
            historico: '@Url.Action("GetHistoricoAjustes", "DocumentosInventario")'
        };
        var historico = [];

        $(function () {
            $("#btnHistConsultar").on("click", getHistorico);
            $("#hist_search").on("input", renderHistorico);
            $("#btnHistLimpiar").on("click", function () {
                $("#hist_tipo").val("Todos");
                $("#hist_fecha_aplicacion").val("");
                $("#hist_proveedor").val("");
                $("#hist_usuario").val("");
                $("#hist_factura").val("");
                $("#hist_producto").val("");
                $("#hist_search").val("");
                getHistorico();
            });
            getHistorico();
        });

        function getHistoricoFilters() {
            return {
                tipoDocumento: $("#hist_tipo").val(),
                fechaAplicacion: $("#hist_fecha_aplicacion").val(),
                proveedor: $("#hist_proveedor").val(),
                usuario: $("#hist_usuario").val(),
                facturaRef: $("#hist_factura").val(),
                producto: $("#hist_producto").val()
            };
        }

        function getHistorico() {
            setHistoricoLoading(true);
            $.get(historicoUrls.historico, getHistoricoFilters())
                .done(function (data) {
                    if (!data.Status) {
                        showToast(data.Message || "No se pudo consultar el historico.");
                        return;
                    }

                    historico = data.Result || [];
                    renderHistorico();
                    updateHistoricoSummary();
                })
                .fail(function () {
                    showToast("No se pudo consultar el historico.");
                })
                .always(function () {
                    setHistoricoLoading(false);
                });
        }

        function renderHistorico() {
            var text = ($("#hist_search").val() || "").toLowerCase();
            var rows = historico.filter(function (item) {
                if (!text) return true;
                return Object.keys(item).some(function (key) {
                    return String(item[key] || "").toLowerCase().indexOf(text) >= 0;
                });
            });

            var html = rows.map(function (d) {
                return "<tr>" +
                    "<td>" + escapeHtml(d.Numero) + "</td>" +
                    "<td>" + escapeHtml(d.Tipo) + "</td>" +
                    "<td>" + escapeHtml(d.Proveedor) + "</td>" +
                    "<td>" + escapeHtml(d.Producto || "-") + "</td>" +
                    "<td>" + escapeHtml(d.FacturaRef || "-") + "</td>" +
                    "<td>" + escapeHtml(d.FechaAplicacion || "-") + "</td>" +
                    "<td><span class='status-badge closed'>Cerrada</span></td>" +
                    "<td>" + getHistoricoAuditoriaBadge(d) + "</td>" +
                    "<td>" + formatMoney(d.Total) + "</td>" +
                    "<td>" + escapeHtml(d.PersonaSolicita) + "</td>" +
                    "<td><div class='action-stack'>" +
                    "<button class='icon-button info' title='Ver' onclick='onHistoricoVer(" + d.ID + ")'>Ver</button>" +
                    "<button class='icon-button neutral' title='Imprimir' onclick='onHistoricoImprimir(" + d.ID + ")'>Imprimir</button>" +
                    "</div></td>" +
                    "</tr>";
            }).join("");

            $("#hist_results_hint").text(rows.length + " resultados");
            $("#historico_body").html(html || "<tr><td colspan='11' class='empty-state'>Sin documentos cerrados para los filtros aplicados.</td></tr>");
        }

        function onHistoricoVer(id) {
            var documento = findHistorico(id);
            if (!documento) return;

            $("#historicoModalTitle").text("Historico " + documento.Numero);
            $("#hist_view_title").text(documento.Numero);
            $("#hist_view_subtitle").text(documento.Tipo + " registrado para " + (documento.Proveedor || "Proveedor no definido") + ".");
            $("#hist_view_total").text(formatMoney(documento.Total));
            $("#hist_view_total").closest(".document-view-total").toggleClass("voided-total", documento.Estado === "Anulada");
            renderHistoricoHeaderBadges(documento);
            renderHistoricoSummary(documento);
            renderHistoricoTipoDocumento(documento);
            renderHistoricoAuditoria(documento);
            renderHistoricoDetalleLineas(documento);
            new bootstrap.Modal(document.getElementById("historicoModal")).show();
        }

        function onHistoricoImprimir(id) {
            onHistoricoVer(id);
            setTimeout(function () { startDocumentPrint("historicoModal"); }, 300);
        }

        function findHistorico(id) {
            return historico.find(function (item) { return item.ID === id; });
        }

        function updateHistoricoSummary() {
            var total = historico.reduce(function (sum, item) { return sum + Number(item.Total || 0); }, 0);
            var last = historico.length ? historico[0].FechaAplicacion : "-";
            $("#hist_count").text(historico.length);
            $("#hist_total").text(formatMoney(total));
            $("#hist_last").text(last || "-");
        }

        function getHistoricoAuditoriaBadge(documento) {
            if (!documento.CantidadLineasEspeciales) {
                return "<span class='status-badge draft'>" + escapeHtml(formatLineCount(documento.CantidadLineasDetalle || 0)) + "</span>";
            }

            return "<span class='audit-pill'>" + escapeHtml(documento.ResumenAuditoria || "Regal\u00edas auditadas") + "</span>";
        }

        function renderHistoricoHeaderBadges(documento) {
            var badges = [
                "<span class='status-badge closed'>Cerrada</span>",
                getHistoricoAuditoriaBadge(documento)
            ];

            $("#hist_view_badges").html(badges.join(""));
        }

        function renderHistoricoSummary(documento) {
            var items = [
                { label: "Número", value: documento.Numero },
                { label: "Tipo", value: documento.Tipo },
                { label: "Proveedor", value: documento.Proveedor || "-" },
                { label: "Producto", value: documento.Producto || "-" },
                { label: "Factura Ref.", value: documento.FacturaRef || "-" },
                { label: "Fecha Aplicación", value: documento.FechaAplicacion || "-" },
                { label: "Usuario", value: documento.PersonaSolicita || "-" },
                { label: "Líneas", value: documento.CantidadLineasDetalle || 0 },
                { label: "Regalías", value: documento.CantidadLineasEspeciales || 0 }
            ];

            if (documento.Estado === "Anulada") {
                items.push({ label: "Motivo anulación", value: documento.MotivoAnulacion || "-" });
                items.push({ label: "Usuario anula", value: documento.UsuarioAnula || "-" });
                items.push({ label: "Fecha anulación", value: documento.FechaHoraAnula || "-" });
            }

            $("#hist_view_summary").html(renderViewGrid(items));
        }

        function renderHistoricoAuditoria(documento) {
            var html = "<div class='document-view-callout'>" +
                escapeHtml(buildHistoricoAuditSummaryText(documento)) +
                "</div>";

            if (documento.LineasEspeciales && documento.LineasEspeciales.length) {
                html += "<div class='document-view-subsection'><h4>L\u00edneas especiales</h4>" +
                    "<div class='document-view-table'><table class='table table-sm align-middle mb-0'><thead><tr><th>C\u00f3digo</th><th>Descripci\u00f3n</th><th>Cantidad</th><th>Costo</th></tr></thead><tbody>" +
                    documento.LineasEspeciales.map(function (linea) {
                        return "<tr><td>" + escapeHtml(linea.CodigoProducto) + "</td><td>" + escapeHtml(linea.Descripcion) + "</td><td>" + formatNumber(linea.Cantidad) + "</td><td>" + formatMoney(linea.Costo) + "</td></tr>";
                    }).join("") +
                    "</tbody></table></div></div>";
            }

            if (documento.EventosAuditoria && documento.EventosAuditoria.length) {
                html += "<div class='document-view-subsection'><h4>Eventos</h4>" +
                    "<div class='document-view-table'><table class='table table-sm align-middle mb-0'><thead><tr><th>Evento</th><th>Usuario</th><th>Fecha hora</th><th>Comentario</th></tr></thead><tbody>" +
                    documento.EventosAuditoria.map(function (evento) {
                        return "<tr><td>" + escapeHtml(evento.Evento) + "</td><td>" + escapeHtml(evento.Usuario) + "</td><td>" + escapeHtml(evento.FechaHora) + "</td><td>" + escapeHtml(evento.Comentario) + "</td></tr>";
                    }).join("") +
                    "</tbody></table></div></div>";
            }

            $("#hist_view_audit").html(html);
        }

        function buildHistoricoAuditSummaryText(documento) {
            var lineas = Number(documento.CantidadLineasDetalle || 0);
            var especiales = Number(documento.CantidadLineasEspeciales || 0);
            if (!especiales) return formatLineCount(lineas) + " aplicadas. Sin regal\u00edas auditables.";
            return formatLineCount(lineas) + " aplicadas. " + (documento.ResumenAuditoria || formatRegaliaCount(especiales) + " auditables") + ".";
        }

        function formatLineCount(value) {
            var count = Number(value || 0);
            return count === 1 ? "1 l\u00ednea" : formatNumber(count) + " l\u00edneas";
        }

        function formatRegaliaCount(value) {
            var count = Number(value || 0);
            return count === 1 ? "1 regal\u00eda" : formatNumber(count) + " regal\u00edas";
        }

        function renderHistoricoTipoDocumento(documento) {
            var items = [];

            if (documento.Tipo === "Salida de Inventario" && documento.TipoSalida) {
                items.push({ label: "Tipo salida", value: documento.TipoSalida });
            }

            if (documento.JustificacionSalida) {
                items.push({ label: "Justificacion salida", value: documento.JustificacionSalida });
            } else if (documento.JustificacionEntrada) {
                items.push({ label: "Justificacion entrada", value: documento.JustificacionEntrada });
            }

            $("#hist_view_type_section").toggle(items.length > 0);
            $("#hist_view_type_grid").html(renderViewGrid(items));
        }

        function renderHistoricoDetalleLineas(documento) {
            if (!documento.DetalleLineas || !documento.DetalleLineas.length) {
                $("#hist_view_lines").html("<div class='document-view-empty'>Sin l\u00edneas registradas.</div>");
                return;
            }

            var table = "<div class='document-view-table'><table class='table table-sm align-middle mb-0'><thead><tr><th>C\u00f3digo</th><th>Descripci\u00f3n</th><th>Unidad</th><th>Solicitada</th><th>Recibida</th><th>Pendiente</th><th>Total</th><th>Regal\u00eda</th></tr></thead><tbody>" +
                documento.DetalleLineas.map(function (linea) {
                    return "<tr><td>" + escapeHtml(linea.Codigo) + "</td><td>" + escapeHtml(linea.Descripcion) + "</td><td>" + escapeHtml(linea.Unidad) + "</td><td>" + formatNumber(linea.CantidadSolicitada || linea.Cantidad) + "</td><td>" + formatNumber(linea.CantidadRecibida || 0) + "</td><td>" + formatNumber(linea.CantidadPendiente || 0) + "</td><td>" + formatMoney(linea.TotalLinea) + "</td><td>" + getBooleanBadge(linea.Regalia) + "</td></tr>";
                }).join("") +
                "</tbody></table></div>";

            $("#hist_view_lines").html(table);
        }

        function renderViewGrid(items) {
            return items.map(function (item) {
                return "<article class='document-view-item'><span>" + escapeHtml(item.label) + "</span><strong>" + escapeHtml(item.value) + "</strong></article>";
            }).join("");
        }

        function getBooleanBadge(flag) {
            return flag ? "<span class='status-badge received'>Si</span>" : "<span class='status-badge draft'>No</span>";
        }

        function setHistoricoLoading(isLoading) {
            $("#hist_loading").toggle(isLoading);
        }

        function startDocumentPrint(modalId) {
            var modal = $("#" + modalId);
            var body = $("body");

            function cleanupPrintMode() {
                body.removeClass("print-document-view");
                modal.removeClass("print-active");
                window.removeEventListener("afterprint", cleanupPrintMode);
            }

            body.addClass("print-document-view");
            modal.addClass("print-active");
            window.addEventListener("afterprint", cleanupPrintMode);
            window.print();
            setTimeout(cleanupPrintMode, 300);
        }

        function showToast(message) {
            var toast = $("<div class='local-toast'></div>").text(message);
            $("body").append(toast);
            setTimeout(function () { toast.addClass("show"); }, 10);
            setTimeout(function () {
                toast.removeClass("show");
                setTimeout(function () { toast.remove(); }, 250);
            }, 2600);
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString("es-CR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function formatNumber(value) {
            return Number(value || 0).toLocaleString("es-CR", { minimumFractionDigits: 0, maximumFractionDigits: 2 });
        }

        function escapeHtml(value) {
            return $("<div />").text(value || "").html();
        }
    </script>
}
