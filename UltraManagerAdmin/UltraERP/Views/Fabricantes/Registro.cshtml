@model UltraERP.Models.FabricanteViewModel
@{
    ViewBag.Title = Model.ID > 0 ? "Editar Fabricante" : "Nuevo Fabricante";
    ViewBag.ActiveMenu = "Fabricantes";
}

<section class="document-topbar">
    <div class="document-topbar-copy">
        <span class="eyebrow">Catalogo de fabricantes</span>
        <h1>@(Model.ID > 0 ? "Editar fabricante" : "Nuevo fabricante")</h1>
        <p>Registre el fabricante para relacionarlo con la informaci&oacute;n comercial de art&iacute;culos y marcas.</p>
    </div>
    <div class="topbar-actions">
        <a class="btn btn-outline-secondary" href="@Url.Action("Inicio", "Fabricantes")">Cancelar</a>
        <button id="btnGuardarFabricante" class="btn btn-primary" type="submit" form="fabricanteForm">Guardar fabricante</button>
    </div>
</section>

@if (TempData["FabricanteError"] != null)
{
    <div class="alert alert-warning">@TempData["FabricanteError"]</div>
}

@using (Html.BeginForm("Registro", "Fabricantes", FormMethod.Post, new { id = "fabricanteForm", @class = "document-form" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(m => m.ID)
    @Html.HiddenFor(m => m.UsuarioCrea)
    @Html.HiddenFor(m => m.FechaCrea)
    @Html.HiddenFor(m => m.UsuarioModifica)
    @Html.HiddenFor(m => m.FechaModifica)

    if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false, "Revise los datos del fabricante:")
        </div>
    }

    <section class="form-panel">
        <div class="section-title">
            <span>1.</span>
            <h2>Datos del fabricante</h2>
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-3">
                <label class="form-label" for="CodigoTexto">C&oacute;digo</label>
                <input id="CodigoTexto" class="form-control readonly-control" type="text" value="@Model.CodigoTexto" readonly />
            </div>
            <div class="col-12 col-md-6">
                <label class="form-label required" for="Descripcion">Descripci&oacute;n</label>
                @Html.TextBoxFor(m => m.Descripcion, new { @class = "form-control", maxlength = "50", autocomplete = "off", placeholder = "Ej: Dos Pinos" })
                @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger small" })
            </div>
        </div>
    </section>
}
